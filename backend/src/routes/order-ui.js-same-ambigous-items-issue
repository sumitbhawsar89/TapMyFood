    return reply.send({ reply: 'I can help with menu questions only 🙏\nTo add items, browse the menu above!', cart_signal: null });
  if (/\b(pay|payment|bill|upi|cash|razorpay)\b/.test(lower))
    return reply.send({ reply: 'I can help with menu questions only 🙏\nFor billing, please ask our staff.', cart_signal: null });

  try {
    const menuItems = await db.queryAll(
      `SELECT mi.*, mc.name AS category_name
       FROM menu_items mi
       JOIN menu_categories mc ON mc.id = mi.category_id
       WHERE mi.restaurant_id = $1 AND mi.is_available = true
       ORDER BY mc.sort_order, mi.sort_order`,
      [session.restaurant_id]
    );
    const categories = await db.queryAll(
      `SELECT * FROM menu_categories WHERE restaurant_id = $1 AND is_active = true ORDER BY sort_order`,
      [session.restaurant_id]
    );

    // ── Veg/non-veg filter ──
    if (/\b(only veg|show veg|veg items|veg only|pure veg|veg menu)\b/.test(lower)) {
      const vegItems = menuItems.filter(i => i.is_veg === true || i.veg_flag === true);
      let text = '**🟢 Veg Items**\n\n';
      vegItems.slice(0, 15).forEach(i => {
        text += `• **${i.name}** — ₹${i.price}${_spiceLabel(i.spice_level) ? '  '+_spiceLabel(i.spice_level) : ''}\n`;
      });
      return reply.send({ reply: text + '\nAsk me about any item!', cart_signal: null });
    }
    if (/\b(non.?veg|nonveg|show non.?veg)\b/.test(lower)) {
      const nvItems = menuItems.filter(i => i.is_veg === false || i.veg_flag === false);
      let text = '**🔴 Non-Veg Items**\n\n';
      nvItems.slice(0, 15).forEach(i => {
        text += `• **${i.name}** — ₹${i.price}${_spiceLabel(i.spice_level) ? '  '+_spiceLabel(i.spice_level) : ''}\n`;
      });
      return reply.send({ reply: text + '\nAsk me about any item!', cart_signal: null });
    }

    // ── Category query ──
    const normQ = _normalise(lower);
    const catMatch = categories.find(c =>
      c.name.toLowerCase() === normQ ||
      c.name.toLowerCase().includes(normQ) ||
      normQ.includes(c.name.toLowerCase())
    );
    if (catMatch) {
      const catItems = menuItems.filter(i => i.category_id === catMatch.id).slice(0, 10);
      let text = `**${catMatch.name.toUpperCase()}**\n\n`;
      catItems.forEach(i => {
        const tags = [_vegLabel(i), _spiceLabel(i.spice_level)].filter(Boolean).join(' ');
        text += `• **${i.name}** — ₹${i.price}${tags ? '  '+tags : ''}\n`;
      });
      text += '\nAsk me about any item — spice, ingredients, allergens!';
      return reply.send({ reply: text, cart_signal: null });
    }

    // ── Item question ──
    const qtype = _detectQtype(lower);
    const item  = menuItems.find(i =>
      lower.includes(i.name.toLowerCase()) ||
      i.name.toLowerCase().includes(lower.replace(/\b(is|this|the|a|an|how|spicy|veg|what|in)\b/g,'').trim())
    ) || menuItems.find(i => {
      const words = lower.split(' ').filter(w => w.length > 3);
      return words.some(w => i.name.toLowerCase().includes(w));
    });

    if (item) {
      return reply.send({ reply: _buildAnswer(item, qtype), cart_signal: null });
    }

    // ── Fallback: show categories ──
    let text = `Hi! 👋 Here\'s our menu:\n\n`;
    categories.forEach((c, idx) => { text += `${idx+1}. ${c.name}\n`; });
    text += '\nAsk me about any dish — spice level, ingredients, veg/non-veg!';
    return reply.send({ reply: text, cart_signal: null });

  } catch (err) {
    console.error('Buddy v2 error:', err);
    return reply.send({ reply: 'Sorry, had a hiccup! Try again 😊', cart_signal: null });
  }
});
;

}

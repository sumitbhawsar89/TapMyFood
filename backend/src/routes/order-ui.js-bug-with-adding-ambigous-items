fastify.post('/bill/request/:sessionId', async (req, reply) => {
  const { sessionId } = req.params;

  const session = await db.queryOne(
    'SELECT id, bill_status, mode FROM sessions WHERE id = $1',
    [sessionId]
  );
  if (!session) return reply.status(404).send({ error: 'Session not found' });
  if (session.bill_status === 'paid') {
    return reply.status(409).send({ error: 'Bill already paid' });
  }

  // Check orders exist
  const orderCount = await db.queryOne(
    'SELECT COUNT(*) as cnt FROM orders WHERE session_id = $1',
    [sessionId]
  );
  if (parseInt(orderCount.cnt) === 0) {
    return reply.status(400).send({ error: 'No orders placed yet' });
  }

  await db.query(
    `UPDATE sessions SET bill_status = 'draft', updated_at = NOW() WHERE id = $1`,
    [sessionId]
  );

  console.log(`🧾 Bill requested: session ${sessionId}`);
  return reply.send({ success: true, bill_status: 'draft' });
});

// ── POST /api/order-ui/bill/pay/:sessionId ────────────────────────────
// Customer taps "Pay Now" — moves bill_status to payment_pending
// Also handles platform choice (direct vs zomato/swiggy)
fastify.post('/bill/pay/:sessionId', async (req, reply) => {
  const { sessionId } = req.params;
  const { payment_method, payment_type } = req.body || {};
  // payment_method: cash | upi | card | cod | counter_qr
  // payment_type:   direct | platform

  const session = await db.queryOne(
    `SELECT s.*, r.name AS restaurant_name, r.owner_phone
     FROM sessions s
     JOIN restaurants r ON r.id = s.restaurant_id
     WHERE s.id = $1`,
    [sessionId]
  );
  if (!session) return reply.status(404).send({ error: 'Session not found' });
  if (session.bill_status === 'paid') {
    return reply.status(409).send({ error: 'Already paid' });
  }

  const safeMethod = payment_method || 'cash';
  const safeType   = payment_type   || 'direct';

  // Move to payment_pending — session locks for new orders
  await db.query(
    `UPDATE sessions
     SET bill_status = 'payment_pending',
         updated_at  = NOW()
     WHERE id = $1`,
    [sessionId]
  );

  // Notify owner via WhatsApp
  if (session.owner_phone) {
    const msg = safeType === 'platform'
      ? `💳 *Payment Initiated*\nTable ${session.table_number} — ${(session.platform || '').toUpperCase()} payment\nCustomer is paying via app.\n\n[Verify & Confirm] in dashboard`
      : `💳 *Payment Initiated*\nTable ${session.table_number} — ${safeMethod.toUpperCase()}\nPlease collect payment and confirm in dashboard.`;
    await whatsapp.sendMessage(session.owner_phone, msg).catch(e =>
      console.warn('WhatsApp notify failed:', e.message)
    );
  }

  console.log(`💳 Pay initiated: ${sessionId} | method=${safeMethod} | type=${safeType}`);
  return reply.send({ success: true, bill_status: 'payment_pending' });
});

// ── POST /api/order-ui/bill/confirm/:sessionId ────────────────────────
// Owner confirms payment received — called from owner dashboard
// Locks session permanently
fastify.post('/bill/confirm/:sessionId', async (req, reply) => {
  const { sessionId } = req.params;
  const { payment_method, payment_type, amount_collected } = req.body || {};

  const session = await db.queryOne(
    `SELECT s.*, r.name AS restaurant_name
     FROM sessions s JOIN restaurants r ON r.id = s.restaurant_id
     WHERE s.id = $1`,
    [sessionId]
  );
  if (!session) return reply.status(404).send({ error: 'Session not found' });
  if (session.bill_status === 'paid') {
    return reply.status(409).send({ error: 'Already paid' });
  }

  // Lock session
  await db.query(
    `UPDATE sessions
     SET bill_status = 'paid',
         status      = 'paid',
         updated_at  = NOW()
     WHERE id = $1`,
    [sessionId]
  );

  // Mark bill(s) as paid for this session
  await db.query(
    `UPDATE bills
     SET status         = 'paid',
         payment_method = COALESCE($1, payment_method),
         payment_type   = $2,
         cash_collected = $3,
         paid_at        = NOW()
     WHERE session_id = $4`,
    [
      payment_method || 'cash',
      payment_type   || 'direct',
      (payment_method === 'cash' || payment_method === 'cod'),
      sessionId,
    ]
  );

  console.log(`✅ Payment confirmed: ${sessionId} | method=${payment_method} | type=${payment_type}`);

  // Notify customer via WhatsApp if phone available
  if (session.customer_phone && session.customer_phone !== 'qr_session') {
    const msg = `✅ *Payment Confirmed!*\n\nThank you for dining with us! 🙏\nUmmeed hai khana pasand aaya!\n\n_${session.restaurant_name}_`;
    await whatsapp.sendMessage(session.customer_phone, msg).catch(() => {});
  }

  return reply.send({ success: true, bill_status: 'paid' });
});

// ── POST /api/order-ui/session/close/:sessionId ───────────────────────
// Owner manually closes session (walkout / end of night)
fastify.post('/session/close/:sessionId', async (req, reply) => {
  const { sessionId } = req.params;
  const { reason }    = req.body || {};

  await db.query(
    `UPDATE sessions
     SET status     = 'closed',
         updated_at = NOW()
     WHERE id = $1`,
    [sessionId]
  );

  console.log(`🔒 Session closed: ${sessionId} | reason=${reason || 'manual'}`);
  return reply.send({ success: true });
});

// ══════════════════════════════════════════════════════════════════════
// UPGRADED AI CHAT — replaces existing /ai-chat/:sessionId
// Key changes:
//   1. Menu sent with UUIDs
//   2. @@CART JSON format (not @@ADD:Name:qty@@)
//   3. Upsell flag from DB
//   4. All 14 rules in system prompt
//   5. AI never writes to cart — returns signal only
// ══════════════════════════════════════════════════════════════════════
fastify.post('/ai-chat-v2/:sessionId', async (req, reply) => {
  const { sessionId } = req.params;
  const { message, history, language } = req.body || {};

  if (!message) return reply.status(400).send({ error: 'message required' });

  // ── Load session ──
  const session = await db.queryOne(
    `SELECT s.*, r.name AS restaurant_name, r.welcome_message
     FROM sessions s
     JOIN restaurants r ON r.id = s.restaurant_id
     WHERE s.id = $1`,
    [sessionId]
  );
  if (!session) return reply.status(404).send({ error: 'Session not found' });

  // Block chat if session is payment_pending or paid/closed
  if (session.bill_status === 'payment_pending') {
    return reply.send({
      reply: 'Payment process mein hai 😊 Naya order nahi ho sakta abhi. Dobara aana! 🙏',
      signal: null,
    });
  }
  if (['paid', 'closed', 'delivered'].includes(session.status)) {
    return reply.send({
      reply: 'Session expire ho gayi 😊 Ummeed hai khana pasand aaya! Dobara milte hain 🙏',
      signal: null,
    });
  }

  // ── Load menu with UUIDs ──
  const [menuItems, categories, modifiers] = await Promise.all([
    db.queryAll(
      `SELECT mi.id, mi.name, mi.price, mi.is_available,
              mc.name AS category_name, mc.id AS category_id
       FROM menu_items mi
       JOIN menu_categories mc ON mc.id = mi.category_id
       WHERE mi.restaurant_id = $1 AND mi.is_available = true
       ORDER BY mc.sort_order ASC NULLS LAST, mi.sort_order ASC NULLS LAST`,
      [session.restaurant_id]
    ),
    db.queryAll(
      `SELECT id, name FROM menu_categories
       WHERE restaurant_id = $1 AND is_active = true
       ORDER BY sort_order ASC`,
      [session.restaurant_id]
    ),
    db.queryAll(
      `SELECT id, name, price, applicable_item_ids
       FROM menu_modifiers
       WHERE restaurant_id = $1 AND is_active = true`,
      [session.restaurant_id]
    ).catch(() => []),
  ]);

  // ── Build UUID-based menu text ──
  const menuText = menuItems
    .map(i => `[${i.id}] ${i.name} | ₹${i.price} | ${i.category_name}`)
    .join('\n');

  // ── Live cart from DB ──
  const liveCart = await cartSvc.getCart(sessionId);
  const cartText = liveCart.items.length
    ? liveCart.items.map(i => `• ${i.name} x${i.quantity} (₹${i.subtotal})`).join('\n')
    : 'empty';

  // ── Latest order status ──
  const latestOrder = await db.queryOne(
    `SELECT o.id, k.status AS kot_status
     FROM orders o
     LEFT JOIN kots k ON k.order_id = o.id AND k.kot_type = 'kitchen'
     WHERE o.session_id = $1
     ORDER BY o.created_at DESC LIMIT 1`,
    [sessionId]
  ).catch(() => null);

  const kotStatus = latestOrder
    ? ({ new: 'Order received — kitchen preparing', cooking: 'Being prepared (15-20 mins)',
         ready: 'Ready!', done: 'Delivered' }[latestOrder.kot_status] || latestOrder.kot_status)
    : 'No order placed yet';

  // ── Latest order items for repeat ──
  let lastOrderItemsV2 = [];
  if (latestOrder) {
    lastOrderItemsV2 = await db.queryAll(
      `SELECT oi.menu_item_id, oi.name, oi.quantity, mi.id AS uuid
       FROM order_items oi JOIN menu_items mi ON mi.id = oi.menu_item_id
       WHERE oi.order_id = $1`,
      [latestOrder.id]
    ).catch(() => []);
  }
  const lastOrderTextV2 = lastOrderItemsV2.length
    ? lastOrderItemsV2.map(i => '[' + i.uuid + '] ' + i.name + ' x' + i.quantity).join(', ')
    : 'none';

  // ── Build system prompt ──
  const systemPrompt = 'You are Buddy, an ordering assistant for ' + session.restaurant_name + '.\n' +
    'Language: ' + (language || 'Hinglish') + '. Item names always in English as-is.\n' +
    'Session: ' + session.mode + (session.table_number ? ', Table ' + session.table_number : '') + '\n\n' +
    'MENU ([UUID] Name | Price | Category):\n' + menuText + '\n\n' +
    'CURRENT CART (already added — do NOT re-add):\n' + cartText + '\n\n' +
    'LAST ORDER ITEMS: ' + lastOrderTextV2 + '\n\n' +
    '════════════════════════════════════\n' +
    'SIGNAL FORMAT:\n' +
    '@@CART:[{"id":"EXACT-UUID","qty":1,"notes":""}]@@\n' +
    'Emit signal in SAME message as confirmation. No signal = item NOT added.\n\n' +
    'HOW TO RESPOND TO ITEM REQUESTS:\n\n' +
    'The system will inject [SYSTEM: ...] notes into customer messages.\n' +
    'If you see [SYSTEM: X items match ...] — show that numbered list to customer, ask to pick. Do NOT add yet.\n' +
    'If you see [SYSTEM: ... already in cart] — tell customer to use +/- buttons.\n' +
    'If no [SYSTEM] note — item is unique, confirm and emit @@CART signal immediately.\n\n' +
    'SELECTION vs QUANTITY:\n' +
    'After showing a numbered list, customer reply = SELECTION not quantity.\n' +
    '"2" after a list = option 2 at qty 1. "16" after a list = option 16 at qty 1.\n' +
    'NEVER carry qty from a previous message to a new item selection.\n' +
    'Even if customer said "2 burger" earlier, when they pick from list with "16", qty = 1.\n' +
    'Qty ONLY comes from the CURRENT message: "do wala" or "2 pieces" said RIGHT NOW.\n\n' +
    'SPECIAL CASES:\n' +
    '"bas"/"ho gaya"/"nhi" → "Perfect! 😊 Place Order button tap karo! 🛒" — no signal\n' +
    '"cart dikhao" → "Yeh raha! 😊" @@SHOW_CART@@\n' +
    '"wahi dobara"/"repeat" → emit @@CART with last order UUIDs\n' +
    (session.mode === 'dine_in' ? '"bill chahiye" → "Get Bill button tap karo 😊"\n' : '') +
    'Cart changes (remove/qty) → "Cart mein +/- buttons use karo 😊"\n\n' +
    'KEEP REPLIES SHORT — max 2 lines, warm friendly tone.\n' +
    '════════════════════════════════════'

  // ══════════════════════════════════════════════════════
  // STATE MACHINE — list → selection handled server-side
  // ══════════════════════════════════════════════════════
  const msgTrimmed = message.trim();
  const msgLower   = msgTrimmed.toLowerCase();
  let injectedMessage = message;

  // Clean expired pending lists (older than 10 minutes)
  const now = Date.now();
  for (const [k, v] of pendingListMap.entries()) {
    if (v.expiresAt < now) pendingListMap.delete(k);
  }

  // Check server-side pending list for this session
  const pending = pendingListMap.get(sessionId);
  if (pending) {
    const selNum = parseInt(msgTrimmed);
    if (!isNaN(selNum) && selNum >= 1 && selNum <= pending.ids.length) {
      const selectedId = pending.ids[selNum - 1];

      if (selectedId.startsWith('CAT:')) {
        // Customer picked a category — show items in that category
        const catItemIds = selectedId.replace('CAT:', '').split(';');
        const catItems   = catItemIds.map(id => menuItems.find(i => i.id === id)).filter(Boolean);
        const cartItemIds = new Set(liveCart.items.map(i => i.menu_item_id));
        const matchLines  = catItems.map((i, idx) =>
          (idx+1) + '. ' + i.name + ' - Rs' + i.price + (cartItemIds.has(i.id) ? ' (in cart)' : '')
        ).join(', ');
        // Store item-level list now
        pendingListMap.set(sessionId, { ids: catItemIds, expiresAt: Date.now() + 10*60*1000 });
        injectedMessage = '[SYSTEM: Customer picked category ' + selNum + '. Items: ' + matchLines +
          '. Show this numbered list, ask to pick a number.]';
      } else {
        // Item selection
        const selectedItem = menuItems.find(i => i.id === selectedId);
        if (selectedItem) {
          pendingListMap.delete(sessionId);
          const inCart = liveCart.items.some(i => i.menu_item_id === selectedItem.id);
          injectedMessage = '[SYSTEM: Customer selected "' + selectedItem.name + '".' +
            ' Reply: "' + selectedItem.name + '! 😊 Kuch aur loge?"' +
            ' then emit @@CART:[{"id":"' + selectedItem.id + '","qty":1,"notes":""}]@@' +
            ' Qty MUST be 1. Do not mention any other number.' +
            (inCart ? ' Item in cart — backend will increment.' : '') + ']';
        }
      }
    } else if (/^[a-z]/i.test(msgTrimmed)) {
      pendingListMap.delete(sessionId);
    }
  }

  if (injectedMessage === message) {
    // Keyword search — only if message is not a pure number
    const isKeyword = msgLower.length <= 30 &&
      !/[?!,।]/.test(msgLower) &&
      !/^\d+$/.test(msgLower);

    if (isKeyword) {
      const cartItemIds = new Set(liveCart.items.map(i => i.menu_item_id));

      // Step 1: exact phrase match (e.g. "russian burger" → only "Russian Burger")
      let matches = menuItems.filter(i => i.name.toLowerCase().includes(msgLower));

      // Step 2: if zero phrase matches, try fallback strategies
      if (matches.length === 0) {
        const words = msgLower.split(' ').filter(w => w.length > 2);

        if (words.length === 1) {
          // Single keyword e.g. "coffee", "burger", "cheese"
          matches = menuItems.filter(i => i.name.toLowerCase().includes(words[0]));
        } else {
          // Multi-word, no phrase match — try each word independently
          // Take the most specific word (longest) as primary filter
          // e.g. "cheeseburger" → try "cheese" and "burger" separately, merge results
          const wordMatches = new Map();
          for (const w of words) {
            menuItems.filter(i => i.name.toLowerCase().includes(w))
              .forEach(i => wordMatches.set(i.id, i));
          }
          matches = [...wordMatches.values()];
        }
      }

      if (matches.length > 1) {
        const uniqueCats = [...new Set(matches.map(i => i.category_name))];

        if (uniqueCats.length > 2 && matches.length > 6) {
          // Many categories — show category filter first
          const catList = uniqueCats.map((cat, idx) => {
            const catItems = matches.filter(i => i.category_name === cat);
            const prices   = catItems.map(i => i.price);
            return (idx+1) + '. ' + cat + ' (Rs' + Math.min(...prices) + '-Rs' + Math.max(...prices) + ')';
          }).join(', ');
          // Store category groups — when customer picks a category number, show its items
          const catGroups = uniqueCats.map(cat => matches.filter(i => i.category_name === cat).map(i => i.id));
          // Use special CAT marker — ids are arrays joined by ;
          pendingListMap.set(sessionId, { ids: catGroups.map(g => 'CAT:' + g.join(';')), expiresAt: Date.now() + 10*60*1000 });
          injectedMessage = '[SYSTEM: "' + msgTrimmed + '" matches items in ' + uniqueCats.length +
            ' categories. Show: ' + catList + '. Ask to pick a category number.]';
        } else {
          // Show item list directly
          const matchLines = matches.map((i, idx) => {
            return (idx+1) + '. ' + i.name + ' - Rs' + i.price + (cartItemIds.has(i.id) ? ' (in cart)' : '');
          }).join(', ');
          const ids = matches.map(i => i.id);
          pendingListMap.set(sessionId, { ids, expiresAt: Date.now() + 10*60*1000 });
          injectedMessage = '[SYSTEM: "' + msgTrimmed + '" matches: ' + matchLines +
            '. Show numbered list and ask to pick a number. Do NOT add any item yet.]';
        }

      } else if (matches.length === 1) {
        const m = matches[0];
        // Check for variants (e.g. "Cold Coffee" → "Cold Coffee with Brownie")
        const variants = menuItems.filter(i =>
          i.name.toLowerCase().startsWith(m.name.toLowerCase() + ' ') || i.id === m.id
        );
        if (variants.length > 1) {
          // Multiple variants — show list
          const matchLines = variants.map((i, idx) =>
            (idx+1) + '. ' + i.name + ' - Rs' + i.price + (cartItemIds.has(i.id) ? ' (in cart)' : '')
          ).join(', ');
          const ids = variants.map(i => i.id);
          pendingListMap.set(sessionId, { ids, expiresAt: Date.now() + 10*60*1000 });
          injectedMessage = '[SYSTEM: Variants of "' + msgTrimmed + '" exist: ' + matchLines +
            '. Show list, ask to pick a number. Do NOT add yet.]';
        } else {
          // Truly single unique match — force add directly, AI has no choice
          pendingListMap.delete(sessionId);
          const inCart = cartItemIds.has(m.id);
          injectedMessage = '[SYSTEM: Exact match found: "' + m.name + '" Rs' + m.price + ' UUID=' + m.id + '.' +
            ' Reply: "' + m.name + '! 😊 Kuch aur loge?"' +
            ' then emit @@CART:[{"id":"' + m.id + '","qty":1,"notes":""}]@@' +
            ' Do NOT show categories. Do NOT ask questions. Add it directly.' +
            (inCart ? ' Already in cart — backend will increment qty.' : '') + ']';
        }
      } else if (matches.length === 0) {
        // No match — let AI handle (might be a sentence or unknown item)
        pendingListMap.delete(sessionId);
      }
    }
  }

  // ── Debug log — shows exactly what backend decided ──
  if (injectedMessage !== message) {
    console.log('🔧 PRE-FILTER injected:', injectedMessage.substring(0, 120));
  } else {
    console.log('🔧 PRE-FILTER passthrough (AI decides):', message);
  }

  try {
    const Anthropic = require('@anthropic-ai/sdk');
    const client    = new Anthropic({ apiKey: process.env.ANTHROPIC_API_KEY });

    const response = await client.messages.create({
      model:      'claude-haiku-4-5-20251001',
      max_tokens: 500,
      system:     systemPrompt,
      messages:   [...(history || []).slice(-10), { role: 'user', content: injectedMessage }],
    });

    let replyText = response.content.find(b => b.type === 'text')?.text || 'Let me know how I can help!';
    console.log(`🤖 AI v2 raw: ${replyText.substring(0, 200)}`);

    // ── Parse @@CART signal ──
    const cartMatch = replyText.match(/@@CART:(\[[\s\S]*?\])@@/);
    let cartSignal  = null;

    if (cartMatch) {
      try {
        cartSignal = JSON.parse(cartMatch[1]);
        // Validate basic structure
        if (!Array.isArray(cartSignal)) cartSignal = null;
      } catch (e) {
        console.warn('⚠️ AI returned malformed @@CART JSON:', cartMatch[1]);
        cartSignal = null;
      }
    }

    // ── Parse @@SHOW_CART@@ signal ──
    let showCart = false;
    if (replyText.includes('@@SHOW_CART@@')) {
      showCart = true;
      const cartRows = await db.queryAll(
        'SELECT menu_item_id, name, price, quantity, notes FROM cart_items WHERE session_id = $1 AND quantity > 0',
        [sessionId]
      );
      if (cartRows.length > 0) {
        cartSignal = cartRows.map(i => ({ id: i.menu_item_id, qty: i.quantity, notes: i.notes || '' }));
      }
    }

    // ── Strip signals from visible reply ──
    const cleanReply = replyText
      .replace(/@@CART:\[[\s\S]*?\]@@/g, '')
      .replace(/@@ADD:[^@]*@@/g, '')
      .replace(/@@UPDATE:[^@]*@@/g, '')
      .replace(/@@REMOVE:[^@]*@@/g, '')
      .replace(/@@SHOW_CART@@/g, '')
      .replace(/@@PLACE_ORDER:[^@]*@@/g, '')
      .replace(/\[SYSTEM:[^\]]*\]/g, '')
      .trim();

    return reply.send({
      reply:       cleanReply,
      cart_signal: cartSignal,
      show_cart:   showCart,
    });

  } catch (err) {
    console.error('AI chat v2 error:', err);
    return reply.send({
      reply: 'Sorry, thodi dikkat aayi! Dobara try karo 😊',
      cart_signal: null,
    });
  }
});


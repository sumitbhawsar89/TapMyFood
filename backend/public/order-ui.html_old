<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Order</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink:    #1a1207;
    --cream:  #fdf6e9;
    --amber:  #f59e0b;
    --orange: #ea580c;
    --green:  #16a34a;
    --red:    #dc2626;
    --muted:  #9b8b72;
    --card:   #ffffff;
    --border: #ede8df;
    --radius: 16px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--ink); min-height: 100vh; max-width: 480px; margin: 0 auto; padding-bottom: 160px; }
  .header { background: var(--ink); color: white; padding: 20px 20px 16px; position: sticky; top: 0; z-index: 100; }
  .header-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .restaurant-name { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800; letter-spacing: -0.3px; }
  .mode-badge { font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 20px; background: var(--amber); color: var(--ink); text-transform: uppercase; letter-spacing: 0.5px; }
  .mode-badge.dine { background: #22c55e; }
  .mode-badge.takeaway { background: #a78bfa; color: white; }
  .search-wrap { position: relative; }
  .search-input { width: 100%; background: rgba(255,255,255,0.1); border: 1.5px solid rgba(255,255,255,0.15); border-radius: 10px; padding: 10px 16px 10px 38px; font-family: 'DM Sans', sans-serif; font-size: 14px; color: white; outline: none; transition: border-color 0.2s; }
  .search-input::placeholder { color: rgba(255,255,255,0.45); }
  .search-input:focus { border-color: var(--amber); }
  .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); opacity: 0.5; font-size: 15px; }
  .cat-tabs { display: flex; gap: 8px; padding: 14px 20px; overflow-x: auto; scrollbar-width: none; background: white; border-bottom: 1px solid var(--border); }
  .cat-tabs::-webkit-scrollbar { display: none; }
  .cat-tab { flex-shrink: 0; padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 500; background: var(--cream); border: 1.5px solid var(--border); cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .cat-tab.active { background: var(--ink); color: white; border-color: var(--ink); }
  .menu-section { padding: 0 16px; }
  .section-title { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; padding: 18px 0 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; }
  .item-card { background: var(--card); border-radius: var(--radius); border: 1.5px solid var(--border); padding: 14px; margin-bottom: 10px; display: flex; gap: 12px; align-items: flex-start; transition: border-color 0.2s; }
  .item-card.in-cart { border-color: var(--orange); }
  .item-info { flex: 1; min-width: 0; }
  .item-name { font-weight: 600; font-size: 15px; margin-bottom: 3px; }
  .item-desc { font-size: 12px; color: var(--muted); margin-bottom: 8px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .item-footer { display: flex; align-items: center; justify-content: space-between; }
  .item-price { font-weight: 700; font-size: 16px; color: var(--orange); }
  .veg-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 5px; vertical-align: middle; }
  .veg-dot.veg { background: var(--green); }
  .veg-dot.nonveg { background: var(--red); }
  .qty-control { display: flex; align-items: center; gap: 8px; }
  .qty-btn { width: 28px; height: 28px; border-radius: 50%; border: none; font-size: 18px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.15s; background: var(--orange); color: white; }
  .qty-btn:active { transform: scale(0.9); }
  .qty-num { font-weight: 700; font-size: 15px; min-width: 20px; text-align: center; }
  .add-btn { padding: 6px 16px; border-radius: 20px; border: 1.5px solid var(--orange); background: white; color: var(--orange); font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.15s; }
  .add-btn:active { background: var(--orange); color: white; }
  .item-img { width: 80px; height: 80px; border-radius: 12px; object-fit: cover; flex-shrink: 0; background: var(--cream); }
  .empty-state { text-align: center; padding: 60px 24px; color: var(--muted); }
  .empty-state .icon { font-size: 48px; margin-bottom: 16px; }
  .cart-pill { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); background: var(--ink); color: white; padding: 14px 28px; border-radius: 50px; font-weight: 600; font-size: 15px; cursor: pointer; box-shadow: 0 8px 32px rgba(0,0,0,0.25); display: none; align-items: center; gap: 12px; z-index: 90; transition: all 0.3s; white-space: nowrap; }
  .cart-pill.visible { display: flex; }
  .cart-pill-count { background: var(--orange); color: white; border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; }
  .drawer-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 200; opacity: 0; pointer-events: none; transition: opacity 0.25s; }
  .drawer-overlay.open { opacity: 1; pointer-events: all; }
  .cart-drawer { position: fixed; bottom: 0; left: 50%; transform: translateX(-50%) translateY(100%); width: 100%; max-width: 480px; background: white; border-radius: 24px 24px 0 0; z-index: 201; transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1); max-height: 85vh; overflow-y: auto; padding: 24px 20px 32px; }
  .cart-drawer.open { transform: translateX(-50%) translateY(0); }
  .drawer-handle { width: 40px; height: 4px; background: var(--border); border-radius: 2px; margin: 0 auto 20px; }
  .drawer-title { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800; margin-bottom: 16px; }
  .cart-item-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--border); }
  .cart-item-name { font-size: 14px; font-weight: 500; }
  .cart-item-price { font-size: 14px; color: var(--muted); }
  .cart-item-qty { display: flex; align-items: center; gap: 8px; }
  .cart-total-row { display: flex; justify-content: space-between; padding: 14px 0 4px; font-weight: 700; font-size: 16px; }
  .place-order-btn { width: 100%; padding: 16px; background: var(--orange); color: white; border: none; border-radius: 14px; font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; cursor: pointer; margin-top: 12px; transition: all 0.2s; }
  .place-order-btn:active { transform: scale(0.99); background: var(--orange); }
  .place-order-btn.loading { opacity: 0.7; pointer-events: none; }
  .place-order-btn:disabled { cursor: not-allowed; }
  .ai-fab { position: fixed; bottom: 24px; right: 20px; width: 54px; height: 54px; border-radius: 50%; background: var(--ink); color: white; border: none; font-size: 22px; cursor: pointer; box-shadow: 0 4px 20px rgba(0,0,0,0.25); z-index: 89; display: flex; align-items: center; justify-content: center; }
  .ai-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 300; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
  .ai-overlay.open { opacity: 1; pointer-events: all; }
  .ai-panel { position: fixed; bottom: 0; left: 50%; transform: translateX(-50%) translateY(100%); width: 100%; max-width: 480px; background: white; border-radius: 24px 24px 0 0; z-index: 301; transition: transform 0.3s; height: 75vh; display: flex; flex-direction: column; padding: 20px 16px 0; }
  .ai-panel.open { transform: translateX(-50%) translateY(0); }
  .ai-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .ai-title { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 16px; }
  .ai-close { background: none; border: none; font-size: 20px; cursor: pointer; color: var(--muted); }
  .ai-messages { flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 8px; padding-bottom: 8px; }
  .ai-msg { max-width: 80%; padding: 10px 14px; border-radius: 16px; font-size: 14px; line-height: 1.5; }
  .ai-msg.bot { background: var(--cream); border: 1px solid var(--border); align-self: flex-start; border-radius: 4px 16px 16px 16px; }
  .ai-msg.user { background: var(--ink); color: white; align-self: flex-end; border-radius: 16px 4px 16px 16px; }
  .ai-input-row { display: flex; gap: 8px; padding-top: 10px; border-top: 1px solid var(--border); }
  .ai-input { flex: 1; border: 1.5px solid var(--border); border-radius: 10px; padding: 10px 14px; font-family: 'DM Sans', sans-serif; font-size: 14px; outline: none; }
  .ai-input:focus { border-color: var(--orange); }
  .ai-send { background: var(--orange); color: white; border: none; border-radius: 10px; padding: 10px 16px; font-weight: 600; cursor: pointer; }
  .typing-dots { display: flex; gap: 4px; padding: 4px 0; }
  .typing-dots span { width: 6px; height: 6px; background: var(--muted); border-radius: 50%; animation: bounce 1.2s infinite; }
  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,60%,100% { transform: translateY(0); } 30% { transform: translateY(-6px); } }
  .toast { position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--ink); color: white; padding: 10px 20px; border-radius: 50px; font-size: 13px; font-weight: 500; opacity: 0; pointer-events: none; transition: all 0.3s; z-index: 999; white-space: nowrap; }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  .address-section { display: none; padding: 12px 0 8px; }
  .address-label { font-size: 12px; font-weight: 600; color: #666; margin-bottom: 8px; text-transform: uppercase; letter-spacing: .5px; }
  .past-addr-chip { padding: 8px 12px; background: #f5f5f5; border-radius: 8px; margin-bottom: 4px; font-size: 13px; cursor: pointer; border: 1.5px solid transparent; transition: all .15s; }
  .past-addr-chip.selected { border-color: var(--orange); background: #fff5ef; }
  .address-textarea { width: 100%; min-height: 72px; border: 1.5px solid var(--border); border-radius: 10px; padding: 10px 12px; font-size: 14px; font-family: inherit; resize: none; background: #faf8f5; box-sizing: border-box; outline: none; }
  .address-hint { font-size: 11px; color: #e53e3e; margin-top: 4px; display: none; }

  @keyframes pulse {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.06); box-shadow: 0 0 0 8px rgba(234,88,12,0.2); }
    100% { transform: scale(1); }
  }

  /* Order confirmation modal */
  .confirm-modal { position:fixed;inset:0;z-index:450;display:none; }
  .confirm-overlay { position:absolute;inset:0;background:rgba(0,0,0,0.55); }
  .confirm-panel { position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:white;border-radius:24px 24px 0 0;padding:24px 20px 32px;box-sizing:border-box;max-height:90vh;overflow-y:auto; }
  .confirm-title { font-family:'Syne',sans-serif;font-size:18px;font-weight:800;margin-bottom:4px; }
  .confirm-subtitle { font-size:13px;color:#9b8b72;margin-bottom:16px; }
  .confirm-items { border:1.5px solid #ede8df;border-radius:12px;overflow:hidden;margin-bottom:16px; }
  .confirm-item { display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border-bottom:1px solid #f5f0e8;font-size:14px; }
  .confirm-item:last-child { border-bottom:none; }
  .confirm-item-name { font-weight:600;flex:1; }
  .confirm-item-note { font-size:11px;color:#9b8b72;margin-top:2px; }
  .confirm-item-price { color:#ea580c;font-weight:700;margin-left:12px;white-space:nowrap; }
  .confirm-total { display:flex;justify-content:space-between;font-weight:800;font-size:16px;padding:12px 0;border-top:2px solid #1a1207;margin-top:4px; }
  .confirm-addr { font-size:12px;color:#9b8b72;background:#f9f6f0;border-radius:8px;padding:10px 12px;margin-bottom:16px; }
  .confirm-btns { display:flex;gap:10px; }
  .confirm-edit-btn { flex:1;padding:14px;border:1.5px solid #ede8df;border-radius:12px;background:white;font-size:14px;font-weight:600;cursor:pointer;color:#9b8b72; }
  .confirm-place-btn { flex:2;padding:14px;background:#ea580c;border:none;border-radius:12px;color:white;font-family:'Syne',sans-serif;font-size:15px;font-weight:800;cursor:pointer; }

  /* Notes modal */
  .notes-modal { position:fixed;inset:0;z-index:460;display:none; }
  .notes-overlay { position:absolute;inset:0;background:rgba(0,0,0,0.5); }
  .notes-panel { position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:white;border-radius:24px 24px 0 0;padding:24px 20px 32px;box-sizing:border-box; }
  .notes-title { font-family:'Syne',sans-serif;font-size:16px;font-weight:800;margin-bottom:4px; }
  .notes-item-name { font-size:13px;color:#9b8b72;margin-bottom:14px; }
  .notes-textarea { width:100%;border:1.5px solid #ede8df;border-radius:12px;padding:12px;font-family:'DM Sans',sans-serif;font-size:14px;resize:none;outline:none;box-sizing:border-box;height:100px; }
  .notes-textarea:focus { border-color:#ea580c; }
  .notes-hints { display:flex;flex-wrap:wrap;gap:8px;margin:10px 0 16px; }
  .notes-hint-chip { border:1.5px solid #ede8df;border-radius:20px;padding:6px 12px;font-size:12px;cursor:pointer;background:white;transition:all 0.15s; }
  .notes-hint-chip:active { border-color:#ea580c;color:#ea580c; }
  .note-btn { background:none;border:none;font-size:15px;cursor:pointer;padding:2px 4px;opacity:0.5;margin-left:4px; }
  .note-btn:active { opacity:1; }
  .notes-save-btn { width:100%;padding:14px;background:#1a1207;border:none;border-radius:12px;color:white;font-family:'Syne',sans-serif;font-size:15px;font-weight:800;cursor:pointer; }

  /* Language selector */
  .lang-btn { background: rgba(255,255,255,0.12); border: 1.5px solid rgba(255,255,255,0.2); border-radius: 20px; padding: 5px 10px; font-size: 13px; color: white; cursor: pointer; display: flex; align-items: center; gap: 5px; transition: all 0.2s; }
  .lang-btn:active { background: rgba(255,255,255,0.25); }
  .lang-drawer { position: fixed; inset: 0; z-index: 500; display: none; }
  .lang-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.5); }
  .lang-panel { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 100%; max-width: 480px; background: white; border-radius: 24px 24px 0 0; padding: 24px 20px 32px; box-sizing: border-box; }
  .lang-title { font-family: 'Syne', sans-serif; font-size: 17px; font-weight: 800; margin-bottom: 16px; text-align: center; }
  .lang-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .lang-option { padding: 14px 12px; border: 2px solid #ede8df; border-radius: 12px; cursor: pointer; display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 600; transition: all 0.15s; background: white; }
  .lang-option:active { transform: scale(0.97); }
  .lang-option.selected { border-color: #ea580c; background: #fff7f0; color: #ea580c; }
  .lang-option .flag { font-size: 22px; }
  .lang-option .label { display: flex; flex-direction: column; }
  .lang-option .native { font-size: 12px; color: #9b8b72; font-weight: 400; margin-top: 1px; }
  .lang-option.selected .native { color: #ea580c; opacity: 0.7; }
  .popular-chip {
    flex-shrink: 0;
    background: white;
    border: 1.5px solid #ede8df;
    border-radius: 12px;
    padding: 10px 12px;
    cursor: pointer;
    transition: all 0.15s;
    min-width: 120px;
    max-width: 150px;
  }
  .popular-chip:active { border-color: #ea580c; transform: scale(0.97); }
  .popular-chip-name { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .popular-chip-price { font-size: 12px; color: #ea580c; font-weight: 700; margin-top: 2px; }
  .popular-chip-add { font-size: 11px; color: #9b8b72; margin-top: 4px; }
</style>
<style>
/* ── Platform Selection Screen ── */
.platform-screen{position:fixed;inset:0;background:var(--cream);z-index:1000;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 24px;max-width:480px;margin:0 auto;left:50%;transform:translateX(-50%);width:100%}
.platform-logo{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;color:var(--ink);margin-bottom:6px;text-align:center}
.platform-subtitle{font-size:14px;color:var(--muted);margin-bottom:32px;text-align:center;line-height:1.5}
.platform-question{font-family:'Syne',sans-serif;font-size:17px;font-weight:700;margin-bottom:18px;text-align:center}
.platform-options{width:100%;display:flex;flex-direction:column;gap:12px;margin-bottom:24px}
.platform-option{width:100%;padding:15px 18px;border-radius:16px;border:2px solid var(--border);background:white;display:flex;align-items:center;gap:14px;cursor:pointer;transition:all 0.15s;text-align:left}
.platform-option:active{transform:scale(0.98)}
.platform-option.selected{border-color:var(--orange);background:#fff7f0}
.platform-option .p-icon{font-size:24px;flex-shrink:0}
.platform-option .p-label{font-weight:600;font-size:14px}
.platform-option .p-sub{font-size:12px;color:var(--muted);margin-top:2px}
.platform-option.selected .p-sub{color:var(--orange)}
.platform-start-btn{width:100%;padding:16px;background:var(--ink);color:white;border:none;border-radius:16px;font-family:'Syne',sans-serif;font-size:16px;font-weight:800;cursor:pointer;opacity:0.35;pointer-events:none;transition:all 0.2s}
.platform-start-btn.ready{opacity:1;pointer-events:all}
.platform-start-btn.ready:active{background:var(--orange)}
/* Platform edit badge in header */
.platform-edit-badge{font-size:11px;padding:3px 8px;border-radius:20px;background:rgba(255,255,255,0.15);color:white;cursor:pointer;display:inline-flex;align-items:center;gap:4px;border:1px solid rgba(255,255,255,0.2);margin-left:6px;vertical-align:middle}
/* AI Confirmation Card */
.ai-confirm-card{background:white;border:2px solid var(--orange);border-radius:16px;overflow:hidden;width:100%}
.ai-confirm-header{background:var(--orange);color:white;padding:9px 14px;font-size:12px;font-weight:600}
.ai-confirm-item{padding:12px 14px;border-bottom:1px solid var(--border)}
.ai-confirm-item:last-of-type{border-bottom:none}
.ai-confirm-row{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:8px}
.ai-confirm-name{font-weight:600;font-size:13px;flex:1}
.ai-confirm-qty-ctrl{display:flex;align-items:center;gap:6px}
.ai-cqbtn{width:24px;height:24px;border-radius:50%;border:none;background:var(--ink);color:white;font-size:15px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1}
.ai-cqbtn:active{transform:scale(0.88)}
.ai-cqnum{font-weight:700;font-size:13px;min-width:16px;text-align:center}
.ai-confirm-price{font-weight:700;color:var(--orange);font-size:13px;white-space:nowrap}
.ai-confirm-mods{margin-top:6px}
.ai-confirm-mod-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);margin-bottom:5px}
.ai-confirm-mod-row{display:flex;align-items:center;gap:8px;font-size:12px;margin-bottom:3px}
.ai-confirm-mod-row input{width:15px;height:15px;accent-color:var(--orange);cursor:pointer}
.ai-confirm-notes{margin-top:8px}
.ai-confirm-notes-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);margin-bottom:4px}
.ai-confirm-notes-inp{width:100%;border:1.5px solid var(--border);border-radius:8px;padding:7px 10px;font-size:12px;font-family:'DM Sans',sans-serif;outline:none;background:var(--cream)}
.ai-confirm-notes-inp:focus{border-color:var(--orange)}
.ai-confirm-footer{padding:10px 14px;border-top:2px solid var(--ink);display:flex;align-items:center;justify-content:space-between}
.ai-confirm-total{font-family:'Syne',sans-serif;font-weight:800;font-size:14px}
.ai-confirm-btns{display:flex;gap:8px}
.ai-confirm-change{padding:7px 12px;border:1.5px solid var(--border);border-radius:10px;background:white;font-size:12px;font-weight:600;cursor:pointer;color:var(--muted)}
.ai-confirm-add-btn{padding:7px 14px;border:none;border-radius:10px;background:var(--orange);color:white;font-weight:700;font-size:12px;cursor:pointer}
.ai-confirm-add-btn:disabled{background:var(--muted);cursor:not-allowed}
/* Bottom Bar */
.bottom-bar{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:white;border-top:1px solid var(--border);padding:12px 16px;display:flex;gap:10px;z-index:89;box-shadow:0 -4px 20px rgba(0,0,0,0.08)}
.bb-cart-btn{flex:1;padding:13px 10px;background:var(--ink);color:white;border:none;border-radius:14px;font-family:'Syne',sans-serif;font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px}
.bb-bill-btn{flex:1;padding:13px 10px;background:var(--orange);color:white;border:none;border-radius:14px;font-family:'Syne',sans-serif;font-size:13px;font-weight:700;cursor:pointer}
.bb-bill-btn:disabled{background:var(--muted);cursor:not-allowed}
.bb-cart-count{background:var(--orange);border-radius:50%;width:20px;height:20px;display:inline-flex;align-items:center;justify-content:center;font-size:10px;font-weight:700}
/* Bill Drawer */
.bill-drawer{position:fixed;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);width:100%;max-width:480px;background:white;border-radius:24px 24px 0 0;z-index:201;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);max-height:90vh;overflow-y:auto;padding:24px 20px 40px}
.bill-drawer.open{transform:translateX(-50%) translateY(0)}
.bill-item-row{display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px}
.bill-round-label{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--muted);padding:8px 0 3px}
.bill-tax-row{display:flex;justify-content:space-between;font-size:13px;color:var(--muted);padding:3px 0}
.bill-total-row{display:flex;justify-content:space-between;font-family:'Syne',sans-serif;font-weight:800;font-size:18px;padding:14px 0 4px;border-top:2px solid var(--ink);margin-top:8px}
.bill-pay-btn{width:100%;padding:16px;background:var(--orange);color:white;border:none;border-radius:14px;font-family:'Syne',sans-serif;font-size:16px;font-weight:800;cursor:pointer;margin-top:14px}
.bill-pay-btn:disabled{background:var(--muted);cursor:not-allowed}
/* Payment Sheet */
.pay-sheet{position:fixed;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);width:100%;max-width:480px;background:white;border-radius:24px 24px 0 0;z-index:210;padding:24px 20px 40px;transition:transform 0.3s}
.pay-sheet.open{transform:translateX(-50%) translateY(0)}
.pay-method-btn{width:100%;padding:14px 16px;border:2px solid var(--border);border-radius:14px;background:white;font-size:14px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:12px;margin-bottom:10px;transition:border-color 0.15s;text-align:left}
.pay-method-btn:active{border-color:var(--orange);background:#fff7f0}
/* Conversion Popup */
.conv-popup{position:fixed;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);width:100%;max-width:480px;background:white;border-radius:24px 24px 0 0;z-index:215;padding:24px 20px 40px;transition:transform 0.3s}
.conv-popup.open{transform:translateX(-50%) translateY(0)}
.conv-savings-box{background:#f0fdf4;border:1.5px solid #86efac;border-radius:12px;padding:14px 16px;margin:14px 0;display:flex;justify-content:space-between;align-items:center}
/* Thank You */
.thankyou-screen{position:fixed;inset:0;background:var(--cream);z-index:1000;display:none;flex-direction:column;align-items:center;justify-content:center;padding:32px 24px;text-align:center}
.thankyou-icon{font-size:64px;margin-bottom:20px}
.thankyou-title{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;margin-bottom:10px}
.thankyou-sub{font-size:15px;color:var(--muted);line-height:1.7}
</style>
<style>
/* Chatbot — now shown as bottom panel triggered by AI FAB */
</style>
</head>
<body>

<div class="header">
  <div class="header-top">
    <span class="restaurant-name" id="restName">Loading…</span>
    <div style="display:flex;align-items:center;gap:8px">
      <button class="lang-btn" onclick="openLangDrawer()" id="langBtn">🌐 EN</button>
      <span class="mode-badge" id="modeBadge">—</span>
    </div>
  </div>
  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input class="search-input" id="searchInput" placeholder="Search menu…" autocomplete="off">
  </div>
</div>

<div class="cat-tabs" id="catTabs"></div>
<div id="popularSection" style="display:none;padding:14px 16px 0">
  <div style="font-family:Syne,sans-serif;font-size:13px;font-weight:700;
              color:#9b8b72;text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">
    🔥 Popular
  </div>
  <div id="popularItems" style="display:flex;gap:10px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none"></div>
</div>
<div class="menu-section" id="menuContent">
  <div class="empty-state"><div class="icon">🍔</div><p>Loading menu…</p></div>
</div>

<div class="cart-pill" id="cartPill" onclick="openCart()">
  <div class="cart-pill-count" id="cartCount">0</div>
  <span id="cartPillText">View Cart</span>
  <span id="cartPillTotal"></span>
</div>

<div class="drawer-overlay" id="drawerOverlay" onclick="closeCart()"></div>
<div class="cart-drawer" id="cartDrawer">
  <div class="drawer-handle"></div>
  <div class="drawer-title">🛒 Your Cart</div>
  <div id="cartItems"></div>
  <div class="cart-total-row" id="cartTotalRow" style="display:none">
    <span>Total</span><span id="cartTotal">₹0</span>
  </div>

  <!-- Delivery address -->
  <div class="address-section" id="addressSection">
    <div class="address-label">📍 Delivery Address</div>
    <div id="pastAddresses"></div>
    <textarea class="address-textarea" id="deliveryAddress"
      placeholder="Enter your full delivery address…"
      oninput="onAddressInput()"
      onblur="if(this.value.trim())this.style.borderColor='#22c55e';else this.style.borderColor='var(--border)'"></textarea>
    <div class="address-hint" id="addressHint">⚠️ Please enter delivery address</div>
  </div>

  <button class="place-order-btn" id="placeOrderBtn" onclick="startUpsell()">Place Order →</button>
</div>

<!-- Order Confirmation Modal -->
<div class="confirm-modal" id="confirmModal">
  <div class="confirm-overlay" onclick="closeConfirm()"></div>
  <div class="confirm-panel">
    <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 20px"></div>
    <div class="confirm-title">✅ Confirm Order</div>
    <div class="confirm-subtitle" id="confirmSubtitle">Review your order before placing</div>
    <div class="confirm-items" id="confirmItems"></div>
    <div class="confirm-total"><span>Total</span><span id="confirmTotal">₹0</span></div>
    <div class="confirm-addr" id="confirmAddr" style="display:none"></div>
    <div class="confirm-btns" style="flex-direction:column;gap:10px">
      <button class="confirm-place-btn" id="confirmPlaceBtn" onclick="confirmAndPlace()">✅ Place Order →</button>
      <div style="display:flex;gap:10px">
        <button class="confirm-edit-btn" style="flex:1" onclick="closeConfirmOpenCart()">✏️ Edit Cart</button>
        <button class="confirm-edit-btn" style="flex:1" onclick="closeConfirm()">+ Add More</button>
      </div>
    </div>
  </div>
</div>

<!-- Notes Modal -->
<div class="notes-modal" id="notesModal">
  <div class="notes-overlay" onclick="closeNotes()"></div>
  <div class="notes-panel">
    <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 20px"></div>
    <div class="notes-title">📝 Special Instructions</div>
    <div class="notes-item-name" id="notesItemName"></div>
    <textarea class="notes-textarea" id="notesTextarea" placeholder="e.g. Extra spicy, no onions, less oil…"></textarea>
    <div class="notes-hints">
      <button class="notes-hint-chip" onclick="addNoteHint('Extra spicy')">🌶️ Extra spicy</button>
      <button class="notes-hint-chip" onclick="addNoteHint('No onions')">🧅 No onions</button>
      <button class="notes-hint-chip" onclick="addNoteHint('Less oil')">Less oil</button>
      <button class="notes-hint-chip" onclick="addNoteHint('No garlic')">No garlic</button>
      <button class="notes-hint-chip" onclick="addNoteHint('Well done')">Well done</button>
      <button class="notes-hint-chip" onclick="addNoteHint('Extra sauce')">Extra sauce</button>
    </div>
    <button class="notes-save-btn" onclick="saveNotes()">Save</button>
  </div>
</div>

<!-- Language Drawer -->
<div class="lang-drawer" id="langDrawer">
  <div class="lang-overlay" onclick="closeLangDrawer()"></div>
  <div class="lang-panel">
    <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 20px"></div>
    <div class="lang-title">🌐 Choose Language</div>
    <div class="lang-grid" id="langGrid">
      <!-- populated by JS -->
    </div>
  </div>
</div>

<!-- Upsell Modal -->
<div id="upsellOverlay" style="
  position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:400;
  opacity:0;pointer-events:none;transition:opacity 0.25s"></div>
<div id="upsellModal" style="
  position:fixed;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);
  width:100%;max-width:480px;background:white;border-radius:24px 24px 0 0;
  z-index:401;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
  padding:24px 20px 32px;box-sizing:border-box">
  <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 20px"></div>
  <div style="font-family:'Syne',sans-serif;font-size:17px;font-weight:800;margin-bottom:4px">🔥 Wait — you might like this!</div>
  <div id="upsellMsg" style="font-size:14px;color:#9b8b72;margin-bottom:16px;line-height:1.5">Finding the perfect add-on…</div>

  <!-- Suggested item card -->
  <div id="upsellItem" style="display:none;background:#fdf6e9;border:1.5px solid #f59e0b;border-radius:14px;padding:16px;margin-bottom:16px">
    <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
      <div style="flex:1">
        <div id="upsellItemName" style="font-weight:700;font-size:16px;margin-bottom:3px"></div>
        <div id="upsellItemPrice" style="color:#ea580c;font-weight:700;font-size:14px"></div>
      </div>
      <button onclick="addUpsellItem()" style="
        background:#ea580c;color:white;border:none;border-radius:20px;
        padding:10px 20px;font-weight:700;font-size:14px;cursor:pointer;
        white-space:nowrap;flex-shrink:0">
        ＋ Add
      </button>
    </div>
  </div>

  <!-- Loading state -->
  <div id="upsellLoading" style="text-align:center;padding:16px;color:#9b8b72;font-size:13px">
    <div style="margin-bottom:6px">🤔</div>Checking what pairs well…
  </div>

  <!-- Action buttons -->
  <div style="display:flex;gap:10px;margin-top:8px">
    <button onclick="skipUpsell()" style="
      flex:1;padding:14px;border:1.5px solid #ede8df;border-radius:12px;

  <!-- Action buttons -->
  <div style="display:flex;gap:10px;margin-top:8px">
    <button onclick="skipUpsell()" style="
      flex:1;padding:14px;border:1.5px solid #ede8df;border-radius:12px;
      background:white;font-size:14px;font-weight:600;cursor:pointer;color:#9b8b72">
      Skip
    </button>
    <button onclick="confirmAfterUpsell()" style="
      flex:2;padding:14px;background:#1a1207;border:none;border-radius:12px;
      color:white;font-family:'Syne',sans-serif;font-size:15px;font-weight:800;cursor:pointer">
      Place Order →
    </button>
  </div>
</div>

<!-- Platform Selection Screen -->
<div class="platform-screen" id="platformScreen" style="display:none">
  <div class="platform-logo" id="platformRestName">TapMyFood</div>
  <div class="platform-subtitle" id="platformSubtitle">Aapka swagat hai!</div>
  <div class="platform-question">Aap kahan se aaye hain?</div>
  <div class="platform-options">
    <button class="platform-option" onclick="selectPlatform('direct',this)">
      <span class="p-icon">🚶</span>
      <div><div class="p-label">Direct (Walk-in)</div><div class="p-sub">Seedha aaye hain</div></div>
    </button>
    <button class="platform-option" onclick="selectPlatform('zomato',this)">
      <span class="p-icon">🔴</span>
      <div><div class="p-label">Zomato Dine-in</div><div class="p-sub">Zomato app se booking</div></div>
    </button>
    <button class="platform-option" onclick="selectPlatform('swiggy',this)">
      <span class="p-icon">🟠</span>
      <div><div class="p-label">Swiggy Dine-in</div><div class="p-sub">Swiggy app se booking</div></div>
    </button>
  </div>
  <button class="platform-start-btn" id="platformStartBtn" onclick="startSession()">Let's Order! →</button>
</div>

<!-- Bottom Bar (dine-in only) -->
<div class="bottom-bar" id="bottomBar" style="display:none">
  <button class="bb-cart-btn" onclick="openCart()">
    🛒 View Cart
    <span class="bb-cart-count" id="bbCartCount">0</span>
  </button>
  <button class="bb-bill-btn" id="getBillBtn" onclick="requestBill()" disabled>🧾 Get Bill</button>
</div>

<!-- Bill Drawer -->
<div class="drawer-overlay" id="billOverlay" onclick="closeBillDrawer()"></div>
<div class="bill-drawer" id="billDrawer">
  <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 20px"></div>
  <div style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;margin-bottom:3px">🧾 Your Bill</div>
  <div style="font-size:12px;color:var(--muted);margin-bottom:16px" id="billLiveNote">Live — updates with new orders</div>
  <div id="billItemsContainer"></div>
  <div style="margin-top:10px">
    <div class="bill-tax-row"><span>Subtotal</span><span id="billSubtotal">₹0</span></div>
    <div class="bill-tax-row"><span>GST (CGST + SGST)</span><span id="billGST">₹0</span></div>
    <div class="bill-tax-row" id="billDiscountRow" style="display:none;color:#16a34a"><span id="billDiscountLabel">Discount</span><span id="billDiscountAmt"></span></div>
    <div class="bill-tax-row"><span>Platform fee</span><span id="billPlatformFee">₹3</span></div>
  </div>
  <div class="bill-total-row"><span>Total</span><span id="billGrandTotal">₹0</span></div>
  <button class="bill-pay-btn" id="billPayBtn" onclick="openPaymentSheet()">💳 Pay Now</button>
  <button onclick="closeBillDrawer()" style="width:100%;padding:12px;background:none;border:none;color:var(--muted);font-size:14px;cursor:pointer;margin-top:6px">← Back to Menu</button>
</div>

<!-- Payment Method Sheet -->
<div class="drawer-overlay" id="payOverlay" onclick="closePaymentSheet()"></div>
<div class="pay-sheet" id="paySheet">
  <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 20px"></div>
  <div style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;margin-bottom:4px">💳 Kaise pay karein?</div>
  <div style="font-size:13px;color:var(--muted);margin-bottom:20px">Payment method choose karein</div>
  <button class="pay-method-btn" onclick="confirmPayment('cash','direct')"><span style="font-size:22px">💵</span><div><div>Cash</div><div style="font-size:12px;color:var(--muted)">Counter pe cash dein</div></div></button>
  <button class="pay-method-btn" onclick="confirmPayment('upi','direct')"><span style="font-size:22px">📱</span><div><div>UPI</div><div style="font-size:12px;color:var(--muted)">GPay, PhonePe, Paytm</div></div></button>
  <button class="pay-method-btn" onclick="confirmPayment('card','direct')"><span style="font-size:22px">💳</span><div><div>Card</div><div style="font-size:12px;color:var(--muted)">Debit ya Credit card</div></div></button>
  <button onclick="closePaymentSheet()" style="width:100%;padding:12px;background:none;border:none;color:var(--muted);font-size:14px;cursor:pointer;margin-top:6px">← Wapas</button>
</div>

<!-- Zomato/Swiggy Conversion Popup -->
<div class="drawer-overlay" id="convOverlay" onclick="skipConversion()"></div>
<div class="conv-popup" id="convPopup">
  <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 20px"></div>
  <div style="font-size:28px;margin-bottom:8px;text-align:center">🎉</div>
  <div style="font-family:'Syne',sans-serif;font-size:17px;font-weight:800;margin-bottom:4px">Direct pay karein aur bachayein!</div>
  <div style="font-size:13px;color:var(--muted)">Restaurant seedha discount de raha hai</div>
  <div class="conv-savings-box">
    <div><div style="font-size:12px;color:var(--muted)">Direct payment</div><div style="font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:#16a34a" id="convDirectAmt">₹0</div></div>
    <div style="text-align:right"><div style="font-size:12px;color:var(--muted)">Aapki bachat</div><div style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:#16a34a" id="convSaving">₹0</div></div>
  </div>
  <div style="font-size:12px;color:var(--muted);text-align:center;margin-bottom:18px" id="convOrigAmt"></div>
  <button onclick="openDirectPaySheet()" style="width:100%;padding:15px;background:#16a34a;border:none;border-radius:14px;color:white;font-family:'Syne',sans-serif;font-size:15px;font-weight:800;cursor:pointer;margin-bottom:10px">💚 Direct Pay — Save <span id="convSavingBtn">₹0</span></button>
  <button onclick="confirmPayment('platform','platform')" style="width:100%;padding:14px;border:1.5px solid var(--border);border-radius:14px;background:white;font-size:14px;font-weight:600;cursor:pointer;color:var(--muted);margin-bottom:8px" id="convPlatformBtn">Pay via Platform</button>
  <button onclick="skipConversion()" style="width:100%;padding:10px;background:none;border:none;color:var(--muted);font-size:13px;cursor:pointer">← Wapas</button>
</div>

<!-- Thank You Screen -->
<div class="thankyou-screen" id="thankyouScreen">
  <div class="thankyou-icon">🙏</div>
  <div class="thankyou-title">Shukriya!</div>
  <div class="thankyou-sub">Ummeed hai khana pasand aaya!<br><br><strong id="thankyouRestName"></strong><br><span id="thankyouExtra" style="font-size:13px"></span></div>
</div>

<button class="ai-fab" id="aiFab" onclick="toggleAI()">🤖</button>

<div class="ai-overlay" id="aiOverlay" onclick="closeAI()"></div>
<div class="ai-panel" id="aiPanel">
  <div class="ai-header">
    <span class="ai-title">Buddy 🍔</span>
    <button class="ai-close" onclick="closeAI()">✕</button>
  </div>
  <div class="ai-messages" id="aiMessages"></div>
  <div class="ai-input-row" style="padding:10px 0;flex-shrink:0;">
    <input class="ai-input" id="aiInput" placeholder="Ask me anything…" autocomplete="off"
      onkeydown="if(event.key==='Enter')sendAIMsg()">
    <button class="ai-send" id="chatSendBtn" onclick="sendAIMsg()">Send</button>
  </div>
  <div id="chatPlaceOrderBar" style="display:none;padding:10px 12px;border-top:2px solid var(--orange);background:#fff8f3;flex-shrink:0;">
    <button onclick="showChatOrderSummary()"
      style="width:100%;padding:14px;background:var(--orange);color:white;border:none;border-radius:12px;font-size:16px;font-weight:800;cursor:pointer;letter-spacing:0.3px;">
      🛒 Place Order →
    </button>
    <p style="text-align:center;font-size:11px;color:#888;margin:6px 0 0;">Cart ready! Review karke order karo</p>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const SESSION_ID = (location.pathname.split('/order/')[1] || '').split('?')[0];
const API_BASE   = '';

// ── State ──
let restaurant    = null;
let allModifiers  = [];
let pendingAddItem= null;
let categories    = [];
let allItems      = [];
let cart          = {};
let aiHistory     = [];
let sessionMode   = 'dine_in';
let sessionPlatform = 'direct';
let platformLocked  = false;
let billStatus      = 'none';
let currentBillData = null;

// ══════════════════════════════════════════════
// PLATFORM SELECTION
// ══════════════════════════════════════════════
let _selectedPlatform = null;

function selectPlatform(platform, el) {
  _selectedPlatform = platform;
  document.querySelectorAll('.platform-option').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('platformStartBtn').classList.add('ready');
  document.getElementById('platformStartBtn').textContent = "Let's Order! →";
}

async function startSession() {
  if (!_selectedPlatform) return;
  const btn = document.getElementById('platformStartBtn');
  btn.textContent = 'Starting… ⏳';
  btn.classList.remove('ready');

  sessionPlatform = _selectedPlatform;

  // Update platform on existing session (if SESSION_ID already exists)
  if (SESSION_ID) {
    try {
      await fetch(API_BASE + '/api/order-ui/session/platform', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ session_id: SESSION_ID, platform: _selectedPlatform })
      });
    } catch(e) { /* non-fatal */ }
    hidePlatformScreen();
    return;
  }

  // New QR flow — create session
  const urlParams = new URLSearchParams(location.search);
  const restaurantId = urlParams.get('r');
  const tableNumber  = urlParams.get('t');
  if (restaurantId) {
    try {
      const res = await fetch(API_BASE + '/api/order-ui/session/start', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ restaurant_id: restaurantId, table_number: tableNumber || '', platform: _selectedPlatform, mode: 'dine_in' })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed');
      window.location.href = '/order/' + data.session_id + '?platform=' + _selectedPlatform;
    } catch(e) {
      btn.textContent = "Let's Order! →";
      btn.classList.add('ready');
      document.getElementById('platformSubtitle').textContent = 'Session start nahi hua 😔 Dobara try karein';
      document.getElementById('platformSubtitle').style.color = 'red';
    }
    return;
  }
  hidePlatformScreen();
}

function hidePlatformScreen() {
  const screen = document.getElementById('platformScreen');
  screen.style.opacity = '0';
  screen.style.transition = 'opacity 0.3s';
  setTimeout(() => { screen.style.display = 'none'; }, 300);
  const aiInput = document.getElementById('aiInput');
  if (aiInput) { aiInput.disabled = false; aiInput.placeholder = 'Kya khayenge aaj? 😊'; }
  const sendBtn = document.getElementById('chatSendBtn');
  if (sendBtn) sendBtn.disabled = false;
}

function showPlatformScreen() {
  if (platformLocked) { showToast('Platform ab change nahi ho sakta 😊'); return; }
  const screen = document.getElementById('platformScreen');
  screen.style.display = 'flex';
  screen.style.opacity = '1';
  screen.style.transition = '';
  _selectedPlatform = null;
  document.querySelectorAll('.platform-option').forEach(b => b.classList.remove('selected'));
  const startBtn = document.getElementById('platformStartBtn');
  startBtn.classList.remove('ready');
  startBtn.textContent = "Let's Order! →";
}

// ══════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════
async function init() {
  if (!SESSION_ID) {
    document.getElementById('menuContent').innerHTML =
      '<div class="empty-state"><div class="icon">🔗</div><p>Invalid link. Please scan the QR code again.</p></div>';
    document.getElementById('platformScreen').style.display = 'none';
    return;
  }

  try {
    const [sessionRes, menuRes] = await Promise.all([
      fetch(API_BASE + '/api/order-ui/session/' + SESSION_ID),
      fetch(API_BASE + '/api/order-ui/menu/' + SESSION_ID)
    ]);

    if (!sessionRes.ok) throw new Error('Session not found');
    const sessionData = await sessionRes.json();

    // Paid/closed — show thank you
    if (['closed','paid','delivered'].includes(sessionData.status) || sessionData.bill_status === 'paid') {
      showThankyouScreen(sessionData.restaurant_name);
      document.getElementById('platformScreen').style.display = 'none';
      return;
    }

    const menuData = await menuRes.json();
    restaurant   = menuData.restaurant;
    categories   = menuData.categories;
    allItems     = menuData.items;
    allModifiers = menuData.modifiers || [];

    sessionMode     = sessionData.mode || 'delivery'; // never default to dine_in — avoids false platform screen
    sessionPlatform = sessionData.platform || 'direct';
    platformLocked  = sessionData.platform_locked || false;
    billStatus      = sessionData.bill_status || 'none';

    const isDineIn = ['dine_in','zomato_dine_in','swiggy_dine_in'].includes(sessionMode);

    // Platform screen setup
    document.getElementById('platformRestName').textContent = restaurant.name;
    document.getElementById('platformSubtitle').textContent = restaurant.welcome_message || 'Swagat hai! Kya khayenge aaj?';

    const urlPlatform = new URLSearchParams(location.search).get('platform');
    // Show platform screen for ALL fresh dine-in sessions
    // Only skip if: not dine-in, OR url has platform param (post-redirect), OR platform_locked (returning customer)
    const platformAlreadySet = urlPlatform || platformLocked;
    if (!isDineIn || platformAlreadySet) {
      document.getElementById('platformScreen').style.display = 'none';
      if (urlPlatform) sessionPlatform = urlPlatform;
    }
    // else: isDineIn + not locked = show platform screen every time

    document.getElementById('restName').textContent = restaurant.name;
    document.title = 'Order — ' + restaurant.name;

    // Mode badge
    const modeEl = document.getElementById('modeBadge');
    if (isDineIn) {
      modeEl.textContent = 'Table ' + (sessionData.table_number || '—');
      modeEl.className = 'mode-badge dine';
    } else if (sessionMode === 'takeaway') {
      modeEl.textContent = 'Takeaway'; modeEl.className = 'mode-badge takeaway';
    } else {
      modeEl.textContent = 'Delivery'; modeEl.className = 'mode-badge';
      document.getElementById('addressSection').style.display = 'block';
      document.getElementById('placeOrderBtn').disabled = true;
      document.getElementById('placeOrderBtn').style.opacity = '0.5';
      loadPastAddresses();
    }

    // Platform edit badge (dine-in, not locked)
    if (isDineIn && !platformLocked) {
      const icon = sessionPlatform === 'zomato' ? '🔴' : sessionPlatform === 'swiggy' ? '🟠' : '🚶';
      const badge = document.createElement('span');
      badge.className = 'platform-edit-badge';
      badge.innerHTML = icon + ' ✏️';
      badge.onclick = showPlatformScreen;
      modeEl.insertAdjacentElement('afterend', badge);
    }

    // Bottom bar for dine-in
    if (isDineIn) {
      document.getElementById('bottomBar').style.display = 'flex';
      document.body.style.paddingBottom = '100px';
      const cartPill = document.getElementById('cartPill');
      if (cartPill) cartPill.style.display = 'none';
    }

    // Disable chat until platform selected
    const platformScreenVisible = document.getElementById('platformScreen').style.display !== 'none';
    if (isDineIn && platformScreenVisible) {
      const aiInput = document.getElementById('aiInput');
      if (aiInput) { aiInput.disabled = true; aiInput.placeholder = 'Pehle upar se option select karein ☝️'; }
      const sendBtn = document.getElementById('chatSendBtn');
      if (sendBtn) sendBtn.disabled = true;
    }

    // Already ordered (takeaway/delivery)
    if (sessionData.status === 'ordered' && !isDineIn) {
      const cartRes2 = await fetch(API_BASE + '/api/order-ui/cart/' + SESSION_ID);
      const cartData2 = await cartRes2.json();
      if (cartData2.items) {
        cartData2.items.forEach(i => { cart[i.menu_item_id] = { qty: i.quantity, notes: i.notes||'', name: i.name, price: i.price }; });
      }
      buildCategoryTabs(); renderMenu(); renderPopular(); updateCartUI();
      lockUI('');
      return;
    }

    const cartRes = await fetch(API_BASE + '/api/order-ui/cart/' + SESSION_ID);
    const cartData = await cartRes.json();
    if (cartData.items) {
      cartData.items.forEach(i => { cart[i.menu_item_id] = { qty: i.quantity, notes: i.notes||'', name: i.name, price: i.price }; });
    }

    buildCategoryTabs();
    renderMenu();
    renderPopular();
    updateCartUI();

    addAIMessage('bot', restaurant.welcome_message ||
      'Namaste! 😊 ' + restaurant.name + ' mein aapka swagat hai! Kya khayenge aaj?');

    document.getElementById('searchInput').addEventListener('input', function(e) {
      renderMenu(e.target.value.toLowerCase().trim());
    });

    // Poll session status every 30s for dine-in
    if (isDineIn) setInterval(checkSessionStatus, 30000);

  } catch(err) {
    console.error('INIT ERROR:', err);
    document.getElementById('platformScreen').style.display = 'none';
    document.getElementById('loadingScreen') && (document.getElementById('loadingScreen').style.display = 'none');
    document.getElementById('menuContent').innerHTML =
      '<div class="empty-state"><div class="icon">😕</div><p>Error: ' + (err.message || err) + '</p><p style="font-size:11px;color:#999">Please refresh or contact support.</p></div>';
  }
}

// ── Chat Order Summary — shown when Place Order tapped in chat ──
function chatConfirmOrder() {
  closeAI();
  setTimeout(function() {
    var b = document.getElementById('placeOrderBtn');
    if (b) b.scrollIntoView({ behavior: 'smooth' });
  }, 300);
}

function showChatOrderSummary() {
  var items = Object.entries(cart).filter(([,i]) => (i.qty||0) > 0);
  if (!items.length) { showToast('Cart empty hai!'); return; }

  var total = items.reduce((s,[,i]) => s + (i.price||0)*i.qty, 0);
  var rows = items.map(([,i]) =>
    '<div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid #f5ede3;font-size:14px;">' +
    '<span>' + i.name + ' <span style="color:#888">×' + i.qty + '</span></span>' +
    '<span style="font-weight:600">₹' + ((i.price||0)*i.qty) + '</span></div>'
  ).join('');

  var html =
    '<div style="background:white;border:2px solid var(--orange);border-radius:16px;overflow:hidden;width:100%">' +
    '<div style="background:var(--orange);color:white;padding:12px 16px;font-weight:800;font-size:15px;">🛒 Aapka Order</div>' +
    '<div style="padding:12px 16px">' + rows +
    '<div style="display:flex;justify-content:space-between;padding:10px 0 4px;font-weight:800;font-size:16px;">' +
    '<span>Total</span><span style="color:var(--orange)">₹' + total + '</span></div></div>' +
    '<div style="display:flex;gap:8px;padding:12px 16px;border-top:1px solid #f5ede3;">' +
    '<button onclick="closeAI();setTimeout(openCart,350)" style="flex:1;padding:12px;background:white;border:2px solid var(--orange);color:var(--orange);border-radius:10px;font-weight:700;font-size:14px;cursor:pointer;">✏️ Edit Cart</button>' +
    '<button onclick="chatConfirmOrder()" style="flex:2;padding:12px;background:var(--orange);color:white;border:none;border-radius:10px;font-weight:800;font-size:14px;cursor:pointer;">✅ Confirm &amp; Place Order</button>' +
    '</div></div>';

  var msgDiv = document.createElement('div');
  msgDiv.className = 'ai-msg bot';
  msgDiv.style.cssText = 'max-width:98%;padding:0;background:transparent;border:none';
  msgDiv.innerHTML = html;
  var msgs = document.getElementById('aiMessages');
  msgs.appendChild(msgDiv);
  msgs.scrollTop = msgs.scrollHeight;
}

// ══════════════════════════════════════════════
// CATEGORY TABS
// ══════════════════════════════════════════════
function buildCategoryTabs() {
  const tabs = document.getElementById('catTabs');
  tabs.innerHTML = categories.map(function(cat, i) {
    return '<div class="cat-tab' + (i===0?' active':'') + '" data-cat="' + cat.id + '" onclick="selectCat(\'' + cat.id + '\',this)">' + cat.name + '</div>';
  }).join('');
  activeCat = categories[0] ? categories[0].id : null;
}
var activeCat = null;
function selectCat(catId, el) {
  document.querySelectorAll('.cat-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  activeCat = catId;
  renderMenu();
}

// ══════════════════════════════════════════════
// RENDER MENU
// ══════════════════════════════════════════════
function renderMenu(search) {
  const container = document.getElementById('menuContent');
  let items = allItems;
  if (search) {
    items = items.filter(i => i.name.toLowerCase().includes(search) || (i.description||'').toLowerCase().includes(search));
  } else if (activeCat) {
    items = items.filter(i => i.category_id === activeCat);
  }
  if (!items.length) { container.innerHTML = '<div class="empty-state"><div class="icon">🔍</div><p>No items found</p></div>'; return; }
  container.innerHTML = items.map(function(item) {
    var inCart = cart[item.id];
    var vegDot = item.is_veg !== null ? '<span class="veg-dot ' + (item.is_veg?'veg':'nonveg') + '"></span>' : '';
    var imgHtml = item.image_url ? '<img class="item-img" src="' + item.image_url + '" alt="' + item.name + '" onerror="this.style.display=\'none\'">' : '';
    var qtyHtml = inCart
      ? '<div class="qty-control">' +
        '<button class="qty-btn minus" onclick="changeQty(\'' + item.id + '\',\'' + item.name.replace(/'/g,"\\'") + '\',' + item.price + ',-1)">−</button>' +
        '<span class="qty-num" id="qty_' + item.id + '">' + inCart.qty + '</span>' +
        '<button class="qty-btn plus" onclick="changeQty(\'' + item.id + '\',\'' + item.name.replace(/'/g,"\\'") + '\',' + item.price + ',1)">+</button>' +
        '<button class="note-btn" onclick="openNotes(\'' + item.id + '\')" title="Special instructions">📝</button>' +
        '</div>'
      : '<button class="add-btn" id="addbtn_' + item.id + '" onclick="addItem(\'' + item.id + '\',\'' + item.name.replace(/'/g,"\\'") + '\',' + item.price + ')">Add</button>';
    return '<div class="item-card' + (inCart?' in-cart':'') + '" id="card_' + item.id + '">' +
      '<div class="item-info">' +
      '<div class="item-name">' + vegDot + item.name + '</div>' +
      (item.description ? '<div class="item-desc">' + item.description + '</div>' : '') +
      '<div class="item-footer"><span class="item-price">₹' + item.price + '</span>' + qtyHtml + '</div></div>' +
      imgHtml + '</div>';
  }).join('');
}

// ══════════════════════════════════════════════
// CART OPERATIONS
// ══════════════════════════════════════════════
function addItem(itemId, name, price) {
  var menuItem = allItems.find(i => i.id === itemId);
  var catId = menuItem ? menuItem.category_id : '';
  var applicable = allModifiers.filter(function(m) {
    var catMatch  = m.applicable_categories && m.applicable_categories.some(c => c === catId);
    var itemMatch = m.applicable_item_ids && m.applicable_item_ids.length > 0 && m.applicable_item_ids.includes(itemId);
    return catMatch || itemMatch;
  });
  if (applicable.length > 0) openModifierModal(itemId, name, price, applicable);
  else addItemDirect(itemId, name, price, []);
}

function addItemDirect(itemId, name, price, modifiers) {
  var modsTotal = modifiers.reduce((s,m) => s + (m.price||0), 0);
  var unitPrice = price + modsTotal;
  var newQty = cart[itemId] ? cart[itemId].qty + 1 : 1;
  cart[itemId] = { qty: newQty, notes: cart[itemId] ? cart[itemId].notes : '', name: name, price: unitPrice, modifiers: modifiers };
  renderMenu(); updateCartUI();
  syncCartItem(itemId, newQty, modifiers);
  var modText = modifiers.length ? ' + ' + modifiers.map(m => m.name).join(', ') : '';
  showToast('✅ ' + name + modText + ' added!');
}

function openModifierModal(itemId, name, price, mods) {
  pendingAddItem = { itemId, name, price };
  document.getElementById('modItemName').textContent = name;
  document.getElementById('modItemPrice').textContent = '₹' + price;
  document.getElementById('modTotal').textContent = price;
  var html = '';
  mods.forEach(function(mod) {
    html += '<div style="display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid #f0ebe3">' +
      '<div style="display:flex;align-items:center;gap:10px">' +
      '<input type="checkbox" id="mod_' + mod.id + '" style="width:20px;height:20px;accent-color:#ea580c;cursor:pointer" ' +
      'onchange="updateModTotal(' + price + ')" data-name="' + mod.name + '" data-price="' + mod.price + '">' +
      '<label for="mod_' + mod.id + '" style="font-size:14px;font-weight:600;cursor:pointer">' + mod.name + '</label>' +
      '</div><span style="color:#ea580c;font-weight:700;font-size:13px">+₹' + mod.price + '</span></div>';
  });
  document.getElementById('modOptions').innerHTML = html;
  document.getElementById('modifierModal').style.display = 'block';
}
function updateModTotal(base) {
  var total = base;
  document.querySelectorAll('[id^="mod_"]:checked').forEach(cb => { total += parseInt(cb.dataset.price||0); });
  document.getElementById('modTotal').textContent = total;
}
function confirmModifiers() {
  if (!pendingAddItem) return;
  var item = pendingAddItem;
  var selected = [];
  document.querySelectorAll('[id^="mod_"]:checked').forEach(cb => {
    selected.push({ id: cb.id.replace('mod_',''), name: cb.dataset.name, price: parseInt(cb.dataset.price||0) });
  });
  closeModifierModal();
  addItemDirect(item.itemId, item.name, item.price, selected);
}
function skipModifiers() { if (!pendingAddItem) return; var i = pendingAddItem; closeModifierModal(); addItemDirect(i.itemId, i.name, i.price, []); }
function closeModifierModal() { document.getElementById('modifierModal').style.display = 'none'; pendingAddItem = null; }

function changeQty(itemId, name, price, delta) {
  var cur = cart[itemId] ? cart[itemId].qty : 0;
  var newQty = cur + delta;
  if (newQty <= 0) delete cart[itemId];
  else cart[itemId] = { qty: newQty, notes: cart[itemId] ? cart[itemId].notes : '', name: name, price: price };
  var qEl = document.getElementById('qty_' + itemId);
  if (qEl) qEl.textContent = newQty > 0 ? newQty : 0;
  var card = document.getElementById('card_' + itemId);
  if (card) { if (newQty <= 0) card.classList.remove('in-cart'); else card.classList.add('in-cart'); }
  updateCartUI();
  syncCartItem(itemId, newQty < 0 ? 0 : newQty);
}

function updateCartUI() {
  // Show/hide Place Order bar in chat
  var cartBar = document.getElementById('chatPlaceOrderBar');
  if (cartBar) {
    var hasItems = Object.values(cart).some(i => (i.qty||0) > 0);
    cartBar.style.display = hasItems ? 'block' : 'none';
  }
  var items = Object.entries(cart).filter(([,i]) => i.qty > 0);
  var count = items.reduce((s,[,i]) => s + i.qty, 0);
  var total = items.reduce((s,[,i]) => s + (i.price||0) * i.qty, 0);

  // Bottom bar count (dine-in)
  var bbCount = document.getElementById('bbCartCount');
  if (bbCount) bbCount.textContent = count;

  // Old cart pill (takeaway/delivery)
  var pill = document.getElementById('cartPill');
  if (pill && ['dine_in','zomato_dine_in','swiggy_dine_in'].indexOf(sessionMode) === -1) {
    document.getElementById('cartCount').textContent = count;
    document.getElementById('cartPillText').textContent = count === 1 ? '1 item' : count + ' items';
    document.getElementById('cartPillTotal').textContent = count > 0 ? ' — ₹' + total : '';
    if (count > 0) pill.classList.add('visible'); else pill.classList.remove('visible');
  }

  // Enable Get Bill button once items exist
  updateBillButtonState();

  // Cart drawer
  renderCartDrawer();
}

function scheduleSave() {}
async function saveCart() {}

// ── Chat lock: disable input when confirmation card is pending ──
function lockChatInput(msg) {
  var inp = document.getElementById('aiInput');
  var btn = document.getElementById('chatSendBtn');
  if (inp) { inp.disabled = true; inp.placeholder = msg || 'Pehle upar wala item confirm karo 👆'; }
  if (btn) btn.disabled = true;
}
function unlockChatInput() {
  var inp = document.getElementById('aiInput');
  var btn = document.getElementById('chatSendBtn');
  if (inp) { inp.disabled = false; inp.placeholder = 'Ask me anything…'; }
  if (btn) btn.disabled = false;
  // Only unlock if no pending confirmation cards remain
}
function hasPendingCard() {
  return Object.keys(window._cqStates || {}).some(cid => {
    var vm = (window._cqViewMode || {})[cid];
    return !vm; // not a view-mode card
  });
}

async function syncCartItem(itemId, qty, modifiers) {
  if (!SESSION_ID) return;
  var item = cart[itemId];
  try {
    var res = await fetch(API_BASE + '/api/order-ui/cart-item/' + SESSION_ID, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ menu_item_id: itemId, quantity: qty||0, name: item?item.name:'', price: item?item.price:0, notes: item?item.notes:null, modifiers: modifiers||(item?item.modifiers:[]) })
    });
    if (res.status === 409) lockCartAfterOrder();
  } catch(e) { console.error('syncCartItem failed', e); }
}

function lockCartAfterOrder() {
  document.querySelectorAll('.qty-btn, .add-btn, .place-order-btn').forEach(b => { b.disabled=true; b.style.opacity='0.4'; b.style.cursor='not-allowed'; });
  var btn = document.getElementById('placeOrderBtn');
  if (btn) { btn.textContent='✅ Order Placed'; btn.style.background='#22c55e'; btn.disabled=true; }
  showToast('✅ Order placed — cart is locked');
}

// ══════════════════════════════════════════════
// ADDRESS
// ══════════════════════════════════════════════
function onAddressInput() {
  var val = document.getElementById('deliveryAddress').value.trim();
  var btn = document.getElementById('placeOrderBtn');
  if (val.length > 5) { btn.disabled=false; btn.style.opacity='1'; document.getElementById('addressHint').style.display='none'; document.getElementById('deliveryAddress').style.borderColor='#22c55e'; }
  else { btn.disabled=true; btn.style.opacity='0.5'; }
}
function selectPastAddress(addr) {
  document.getElementById('deliveryAddress').value = addr;
  document.querySelectorAll('.past-addr-chip').forEach(el => el.classList.remove('selected'));
  event.target.classList.add('selected');
  onAddressInput();
}
async function loadPastAddresses() {
  try {
    var res  = await fetch(API_BASE + '/api/order-ui/past-addresses/' + SESSION_ID);
    var data = await res.json();
    if (!data.addresses || !data.addresses.length) return;
    var container = document.getElementById('pastAddresses');
    container.innerHTML = '<div style="font-size:11px;color:#888;margin-bottom:4px">Recent addresses:</div>' +
      data.addresses.map(a => '<div class="past-addr-chip" onclick="selectPastAddress(\'' + a.replace(/'/g,"\\'") + '\')">📍 ' + a + '</div>').join('') +
      '<div style="font-size:11px;color:#888;margin-top:6px;margin-bottom:2px">Or enter new address:</div>';
  } catch(e) {}
}

// ══════════════════════════════════════════════
// LOCK UI
// ══════════════════════════════════════════════
function lockUI(billNumber) {
  document.querySelectorAll('.qty-btn, .add-btn').forEach(b => { b.disabled=true; b.style.opacity='0.4'; b.style.pointerEvents='none'; });
  var btn = document.getElementById('placeOrderBtn');
  if (btn) { btn.disabled=true; btn.style.background='#22c55e'; btn.style.opacity='1'; btn.textContent = billNumber ? '✅ Order Placed #' + billNumber : '✅ Order Placed'; }
  var chatInput = document.getElementById('aiInput');
  var sendBtn   = document.getElementById('chatSendBtn');
  if (chatInput) { chatInput.disabled=true; chatInput.placeholder='Order placed — session closed'; }
  if (sendBtn) { sendBtn.disabled=true; sendBtn.style.opacity='0.4'; }
}

// ══════════════════════════════════════════════
// PLACE ORDER (takeaway/delivery only)
// ══════════════════════════════════════════════
async function placeOrder(skipAddressCheck) {
  if (Object.keys(cart).length === 0) { showToast('Add items first!'); return; }
  var btn = document.getElementById('placeOrderBtn');
  btn.classList.add('loading'); btn.textContent = 'Placing order…';
  try {
    var addrEl = document.getElementById('deliveryAddress');
    var address = addrEl ? addrEl.value.trim() : '';
    var isDelivery = document.getElementById('addressSection').style.display !== 'none';
    if (isDelivery && address.length < 6 && !skipAddressCheck) {
      document.getElementById('addressHint').style.display = 'block';
      if (addrEl) { addrEl.focus(); addrEl.style.borderColor='#e53e3e'; }
      btn.textContent = 'Place Order →'; btn.classList.remove('loading'); return;
    }
    if (isDelivery && address) {
      await fetch(API_BASE + '/api/order-ui/address/' + SESSION_ID, {
        method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ address })
      });
    }
    var res  = await fetch(API_BASE + '/api/order-ui/place-order/' + SESSION_ID, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({}) });
    var data = await res.json();
    if (res.status === 410) { showToast('⚠️ Session expired — scan QR to reorder'); btn.textContent='Place Order →'; btn.classList.remove('loading'); return; }
    if (data.success) {
      closeCart();
      document.getElementById('cartPill').classList.remove('visible');
      showToast('✅ Order placed! Bill #' + data.bill_number);
      if (sessionMode !== 'dine_in') {
        cart = {}; updateCartUI(); renderMenu(); lockUI(data.bill_number);
        addAIMessage('bot', '🎉 Order placed! Bill #' + data.bill_number + ' — ₹' + data.total);
      } else {
        cart = {}; updateCartUI(); renderMenu();
        btn.textContent = 'Place Order →'; btn.classList.remove('loading');
        addAIMessage('bot', '🎉 Order sent to kitchen! Kuch aur chahiye?');
      }
    } else throw new Error(data.error || 'Failed');
  } catch(e) { showToast('Failed to place order. Try again.'); btn.textContent='Place Order →'; btn.classList.remove('loading'); }
}

// ══════════════════════════════════════════════
// CART DRAWER
// ══════════════════════════════════════════════
function openCart() {
  document.getElementById('cartDrawer').classList.add('open');
  document.getElementById('drawerOverlay').classList.add('open');
  renderCartDrawer();
}
function closeCart() {
  document.getElementById('cartDrawer').classList.remove('open');
  document.getElementById('drawerOverlay').classList.remove('open');
}
function renderCartDrawer() {
  var items = Object.entries(cart).filter(([,i]) => i.qty > 0);
  var total = items.reduce((s,[,i]) => s + (i.price||0) * i.qty, 0);
  var container = document.getElementById('cartItems');
  if (!container) return;
  if (!items.length) {
    container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted)">Cart is empty</div>';
    var tRow = document.getElementById('cartTotalRow');
    if (tRow) tRow.style.display = 'none';
    return;
  }
  container.innerHTML = items.map(([id, item]) =>
    '<div class="cart-item-row">' +
    '<div><div class="cart-item-name">' + item.name + '</div><div class="cart-item-price">₹' + item.price + ' each</div></div>' +
    '<div class="cart-item-qty">' +
    '<button class="qty-btn minus" onclick="changeQty(\'' + id + '\',\'' + item.name.replace(/'/g,"\\'") + '\',' + item.price + ',-1);renderCartDrawer()">−</button>' +
    '<span>' + item.qty + '</span>' +
    '<button class="qty-btn plus" onclick="changeQty(\'' + id + '\',\'' + item.name.replace(/'/g,"\\'") + '\',' + item.price + ',1);renderCartDrawer()">+</button>' +
    '</div></div>'
  ).join('');
  var totalEl = document.getElementById('cartTotal');
  var tRow = document.getElementById('cartTotalRow');
  if (totalEl) totalEl.textContent = '₹' + total;
  if (tRow) tRow.style.display = 'flex';
}

// ══════════════════════════════════════════════
// BILL FLOW (dine-in)
// ══════════════════════════════════════════════
function updateBillButtonState() {
  var btn = document.getElementById('getBillBtn');
  if (!btn) return;
  if (billStatus === 'paid') { btn.disabled=true; btn.textContent='✅ Paid'; return; }
  if (billStatus === 'payment_pending') { btn.disabled=true; btn.textContent='⏳ Pending'; return; }
  var hasItems = Object.keys(cart).length > 0;
  btn.disabled = !hasItems;
}

async function requestBill() {
  try {
    await fetch(API_BASE + '/api/order-ui/bill/request/' + SESSION_ID, {
      method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({})
    });
    billStatus = 'draft';
  } catch(e) {}
  openBillDrawer();
}

async function openBillDrawer() {
  try {
    var res = await fetch(API_BASE + '/api/order-ui/bill/' + SESSION_ID);
    currentBillData = await res.json();
  } catch(e) { showToast('Bill load nahi hua — dobara try karein'); return; }
  renderBillDrawer(currentBillData);
  var overlay = document.getElementById('billOverlay');
  overlay.style.display = 'block';
  setTimeout(() => { overlay.style.opacity='1'; overlay.style.pointerEvents='all'; }, 10);
  document.getElementById('billDrawer').classList.add('open');
}

function closeBillDrawer() {
  var overlay = document.getElementById('billOverlay');
  overlay.style.opacity = '0'; overlay.style.pointerEvents = 'none';
  setTimeout(() => { overlay.style.display='none'; }, 260);
  document.getElementById('billDrawer').classList.remove('open');
}

function renderBillDrawer(bill) {
  var container = document.getElementById('billItemsContainer');
  if (!bill || bill.empty || !bill.items || !bill.items.length) {
    container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted)">Koi order nahi mila</div>';
    document.getElementById('billPayBtn').disabled = true;
    return;
  }
  var html = '';
  var lastTime = null;
  bill.items.forEach(function(item, idx) {
    var t = item.ordered_at ? new Date(item.ordered_at).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) : '';
    if (t !== lastTime) { html += '<div class="bill-round-label">Order — ' + (t||'—') + '</div>'; lastTime = t; }
    html += '<div class="bill-item-row"><span>' + item.name + ' <span style="color:var(--muted)">×' + item.quantity + '</span></span><span style="font-weight:600">₹' + item.subtotal + '</span></div>';
  });
  container.innerHTML = html;
  document.getElementById('billSubtotal').textContent = '₹' + (bill.subtotal||0);
  document.getElementById('billGST').textContent = '₹' + (bill.total_tax||0);
  document.getElementById('billPlatformFee').textContent = '₹' + (bill.platform_fee||3);
  document.getElementById('billGrandTotal').textContent = '₹' + (bill.grand_total||0);
  if (bill.discount_amount > 0) {
    document.getElementById('billDiscountRow').style.display = 'flex';
    document.getElementById('billDiscountLabel').textContent = 'Discount (' + bill.discount_pct + '%)';
    document.getElementById('billDiscountAmt').textContent = '−₹' + bill.discount_amount;
  }
  var payBtn = document.getElementById('billPayBtn');
  if (billStatus === 'payment_pending') { payBtn.disabled=true; payBtn.textContent='⏳ Confirmation pending'; }
  else if (billStatus === 'paid') { payBtn.disabled=true; payBtn.textContent='✅ Paid'; }
  else { payBtn.disabled=false; payBtn.textContent='💳 Pay Now'; }
}

function openPaymentSheet() {
  closeBillDrawer();
  // Show conversion popup for Zomato/Swiggy with discount
  if (['zomato','swiggy'].includes(sessionPlatform) && currentBillData && currentBillData.discount_pct > 0) {
    showConversionPopup(); return;
  }
  showPaySheet();
}

function showPaySheet() {
  var overlay = document.getElementById('payOverlay');
  overlay.style.display='block'; setTimeout(() => { overlay.style.opacity='1'; overlay.style.pointerEvents='all'; }, 10);
  document.getElementById('paySheet').classList.add('open');
}
function closePaymentSheet() {
  var overlay = document.getElementById('payOverlay');
  overlay.style.opacity='0'; overlay.style.pointerEvents='none';
  setTimeout(() => { overlay.style.display='none'; }, 260);
  document.getElementById('paySheet').classList.remove('open');
}

function showConversionPopup() {
  if (!currentBillData) return;
  var grand    = currentBillData.grand_total || 0;
  var discount = currentBillData.discount_amount || 0;
  var direct   = grand - discount;
  var pName    = sessionPlatform.charAt(0).toUpperCase() + sessionPlatform.slice(1);
  document.getElementById('convDirectAmt').textContent = '₹' + direct;
  document.getElementById('convSaving').textContent    = '₹' + discount;
  document.getElementById('convSavingBtn').textContent = '₹' + discount;
  document.getElementById('convOrigAmt').textContent   = 'Bill total: ₹' + grand;
  document.getElementById('convPlatformBtn').textContent = 'Pay via ' + pName + ' — ₹' + grand;
  var overlay = document.getElementById('convOverlay');
  overlay.style.display='block'; setTimeout(() => { overlay.style.opacity='1'; overlay.style.pointerEvents='all'; }, 10);
  document.getElementById('convPopup').classList.add('open');
}
function skipConversion() {
  var overlay = document.getElementById('convOverlay');
  overlay.style.opacity='0'; overlay.style.pointerEvents='none';
  setTimeout(() => { overlay.style.display='none'; }, 260);
  document.getElementById('convPopup').classList.remove('open');
}
function openDirectPaySheet() {
  skipConversion(); setTimeout(showPaySheet, 200);
}

async function confirmPayment(method, type) {
  closePaymentSheet(); skipConversion();
  showToast('Payment request bheja ja raha hai… ⏳');
  try {
    var res = await fetch(API_BASE + '/api/order-ui/bill/pay/' + SESSION_ID, {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ payment_method: method, payment_type: type })
    });
    var data = await res.json();
    if (!res.ok) throw new Error(data.error);
    billStatus = 'payment_pending';
    updateBillButtonState();
    if (type === 'platform') {
      var pName = sessionPlatform.charAt(0).toUpperCase() + sessionPlatform.slice(1);
      addAIMessage('bot', pName + ' app se payment karein 😊\n\nTotal: ₹' + (currentBillData?.grand_total||0) + '\n\nPayment ke baad staff ko batayein — woh confirm kar denge! 🙏');
      openAI();
    } else {
      showToast('✅ Owner ko notify kar diya! Woh confirm karenge.');
    }
  } catch(e) { showToast('Payment request failed — dobara try karein'); }
}

async function checkSessionStatus() {
  try {
    var res  = await fetch(API_BASE + '/api/order-ui/session/' + SESSION_ID);
    var data = await res.json();
    if (data.bill_status === 'paid' || ['paid','closed'].includes(data.status)) {
      showThankyouScreen(data.restaurant_name);
    }
    billStatus = data.bill_status || 'none';
    updateBillButtonState();
  } catch(e) {}
}

function showThankyouScreen(restName) {
  document.getElementById('thankyouRestName').textContent = restName || (restaurant && restaurant.name) || '';
  document.getElementById('thankyouScreen').style.display = 'flex';
  document.getElementById('bottomBar').style.display = 'none';
  document.getElementById('platformScreen').style.display = 'none';
}

// ══════════════════════════════════════════════
// AI CHAT — upgraded v2 with UUID signals
// ══════════════════════════════════════════════
function toggleAI() { var p = document.getElementById('aiPanel'); if (p.classList.contains('open')) closeAI(); else openAI(); }
function openAI()  { document.getElementById('aiPanel').classList.add('open'); document.getElementById('aiOverlay').classList.add('open'); document.getElementById('aiInput').focus(); }
function closeAI() { document.getElementById('aiPanel').classList.remove('open'); document.getElementById('aiOverlay').classList.remove('open'); }

function addAIMessage(role, text) {
  var msgs = document.getElementById('aiMessages');
  var div  = document.createElement('div');
  div.className = 'ai-msg ' + role;
  div.textContent = text;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
  if (role !== 'bot' || !text.startsWith('Namaste')) {
    aiHistory.push({ role: role==='bot'?'assistant':'user', content: text });
  }
}
function showTyping() {
  var msgs = document.getElementById('aiMessages');
  var div  = document.createElement('div');
  div.className = 'ai-msg bot typing'; div.id = 'typingIndicator';
  div.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
  msgs.appendChild(div); msgs.scrollTop = msgs.scrollHeight;
}
function hideTyping() { var el = document.getElementById('typingIndicator'); if (el) el.remove(); }

async function sendAIMsg() {
  if (window._upsellOpen) return;
  var input = document.getElementById('aiInput');
  if (input.disabled) { showToast('Pehle platform select karein ☝️'); return; }
  var text = input.value.trim();
  if (!text) return;

  // Bill redirect check before sending to AI
  if (/bill|pay|check please/i.test(text)) {
    input.value = '';
    addAIMessage('user', text);
    addAIMessage('bot', 'Bill ke liye neeche 🧾 Get Bill button tap karo 😊');
    return;
  }

  // Delivery address flow
  if (window._aiWantsToOrder) {
    window._aiWantsToOrder = false;
    hideTyping();
    var addrEl = document.getElementById('deliveryAddress');
    if (addrEl) addrEl.value = text;
    onAddressInput();
    await fetch(API_BASE + '/api/order-ui/address/' + SESSION_ID, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ address: text }) });
    addAIMessage('bot', 'Got it! Placing your order now… ⏳');
    await placeOrder(true); return;
  }

  input.value = '';
  addAIMessage('user', text);
  showTyping();

  try {
    var res = await fetch(API_BASE + '/api/order-ui/ai-chat-v2/' + SESSION_ID, {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ message: text, history: aiHistory.slice(-10), language: getLangInstruction() })
    });
    var data = await res.json();
    hideTyping();

    if (data.reply) addAIMessage('bot', data.reply);
    aiHistory.push({ role: 'user', content: text });
    if (data.reply) aiHistory.push({ role: 'assistant', content: data.reply.replace(/@@CART:\[.*?\]@@/gs,'').replace(/@@SHOW_CART@@/g,'').trim() });

    if (data.cart_signal && data.cart_signal.length > 0) {
      await showAIConfirmCard(data.cart_signal, data.show_cart || false);
    }

  } catch(e) { hideTyping(); addAIMessage('bot', 'Sorry, kuch problem aayi. Dobara try karein 😊'); }
}

// ══════════════════════════════════════════════
// AI CONFIRMATION CARD
// ══════════════════════════════════════════════
async function showAIConfirmCard(cartSignal, viewMode) {
  var parseRes = await fetch(API_BASE + '/api/order-ui/ai-parse/' + SESSION_ID, {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ cart_signal: cartSignal })
  });
  var parseData = await parseRes.json();
  var verified = parseData.verified || [];
  if (verified.length === 0) { addAIMessage('bot', 'Kuch items available nahi hain abhi. Kuch aur try karein? 😊'); return; }
  if (parseData.rejected && parseData.rejected.length > 0) {
    addAIMessage('bot', '⚠️ Kuch items abhi available nahi — baaki add kar raha hoon.');
  }

  var cardId = 'card_' + Date.now();
  var cardState = verified.map(item => ({ ...item, price: item.price, cardQty: item.qty, selMods: [], editNotes: item.notes||'' }));

  function calcTotal() {
    return cardState.reduce((sum, item) => {
      var modSum = item.selMods.reduce((ms, mid) => { var m = item.applicable_modifiers.find(x => x.id===mid); return ms+(m?m.price:0); }, 0);
      return sum + (item.price + modSum) * item.cardQty;
    }, 0);
  }

  function buildCard() {
    var html = '<div class="ai-confirm-card" id="' + cardId + '"><div class="ai-confirm-header">' + (viewMode ? '🛒 Aapka current cart' : '✅ Confirm karein — cart mein add hoga') + '</div>';
    cardState.forEach(function(item, idx) {
      if (item.cardQty === 0) return;
      var modSum = item.selMods.reduce((ms,mid) => { var m = item.applicable_modifiers.find(x=>x.id===mid); return ms+(m?m.price:0); }, 0);
      var lineTotal = (item.price + modSum) * item.cardQty;
      html += '<div class="ai-confirm-item"><div class="ai-confirm-row">' +
        '<span class="ai-confirm-name">' + item.name + '</span>' +
        '<div class="ai-confirm-qty-ctrl">' +
        '<button class="ai-cqbtn" onclick="cqChange(\'' + cardId + '\',' + idx + ',-1)">−</button>' +
        '<span class="ai-cqnum" id="cq_' + cardId + '_' + idx + '">' + item.cardQty + '</span>' +
        '<button class="ai-cqbtn" onclick="cqChange(\'' + cardId + '\',' + idx + ',1)">+</button>' +
        '</div>' +
        '<span class="ai-confirm-price" id="cp_' + cardId + '_' + idx + '">₹' + lineTotal + '</span>' +
        '</div>';
      if (item.applicable_modifiers && item.applicable_modifiers.length > 0) {
        html += '<div class="ai-confirm-mods"><div class="ai-confirm-mod-title">Extras (optional)</div>';
        item.applicable_modifiers.forEach(function(mod) {
          var chk = item.selMods.includes(mod.id) ? 'checked' : '';
          html += '<div class="ai-confirm-mod-row"><input type="checkbox" ' + chk + ' onchange="cqMod(\'' + cardId + '\',' + idx + ',\'' + mod.id + '\',this.checked)"><label style="flex:1;cursor:pointer">' + mod.name + '</label><span style="color:var(--orange);font-weight:600">+₹' + mod.price + '</span></div>';
        });
        html += '</div>';
      }
      html += '<div class="ai-confirm-notes"><div class="ai-confirm-notes-label">📝 Instructions</div><input class="ai-confirm-notes-inp" type="text" value="' + (item.notes||'').replace(/"/g,'&quot;') + '" placeholder="extra spicy, no onion…" oninput="cqNotes(\'' + cardId + '\',' + idx + ',this.value)"></div></div>';
    });
    var total = calcTotal(); var allZero = cardState.every(i => i.cardQty===0);
    var footerBtns = viewMode
      ? '<button class="ai-confirm-change" onclick="cqDismiss(\'' + cardId + '\')">✕ Close</button><button class="ai-confirm-add-btn" onclick="openCart()">🛒 Edit Cart</button>'
      : '<button class="ai-confirm-change" onclick="cqDismiss(\'' + cardId + '\')">❌ Wrong item</button><button class="ai-confirm-add-btn" id="ca_' + cardId + '" onclick="cqAddToCart(\'' + cardId + '\')" ' + (allZero?'disabled':'') + '>✅ Add to Cart</button>';
    var headerText = viewMode ? '🛒 Aapka current cart' : '✅ Confirm karein — cart mein add hoga';
    html += '<div class="ai-confirm-footer"><span class="ai-confirm-total" id="ct_' + cardId + '">Total: ₹' + total + '</span><div class="ai-confirm-btns">' + footerBtns + '</div></div></div>';
    return html;
  }

  window.cqChange = function(cid, idx, d) {
    var s = window._cqStates[cid]; if (!s) return;
    s[idx].cardQty = Math.max(0, s[idx].cardQty + d);
    document.getElementById('cq_' + cid + '_' + idx).textContent = s[idx].cardQty;
    cqRefresh(cid);
  };
  window.cqMod = function(cid, idx, mid, checked) {
    var s = window._cqStates[cid]; if (!s) return;
    if (checked && !s[idx].selMods.includes(mid)) s[idx].selMods.push(mid);
    else s[idx].selMods = s[idx].selMods.filter(m => m !== mid);
    cqRefresh(cid);
  };
  window.cqNotes = function(cid, idx, val) { var s = window._cqStates[cid]; if (s) s[idx].editNotes = val; };
  window.cqRefresh = function(cid) {
    var s = window._cqStates[cid]; if (!s) return;
    var grand = 0; var allZero = true;
    s.forEach(function(item, idx) {
      if (item.cardQty === 0) return;
      allZero = false;
      var ms = item.selMods.reduce((ms,mid)=>{ var m=item.applicable_modifiers.find(x=>x.id===mid); return ms+(m?m.price:0); },0);
      var lt = (item.price+ms)*item.cardQty;
      var el = document.getElementById('cp_' + cid + '_' + idx); if (el) el.textContent = '₹'+lt;
      grand += lt;
    });
    var tel = document.getElementById('ct_' + cid); if (tel) tel.textContent = 'Total: ₹'+grand;
    var aBtn = document.getElementById('ca_' + cid); if (aBtn) aBtn.disabled = allZero;
  };
  window.cqDismiss = function(cid) {
    // Get rejected item names before deleting state
    var s = window._cqStates[cid] || [];
    var rejectedNames = s.map(i => i.name).join(', ');
    var el = document.getElementById(cid); if (el) el.closest('.ai-msg').remove();
    delete window._cqStates[cid];
    delete (window._cqViewMode||{})[cid];
    if (!hasPendingCard()) {
      unlockChatInput();
      // Push rejection into chat history so AI knows this item was NOT added
      if (rejectedNames) {
        aiHistory.push({ role: 'assistant', content: 'SYSTEM: Customer rejected ' + rejectedNames + '. This item was NOT added to cart. Cart is unchanged.' });
      }
      addAIMessage('bot', 'Koi baat nahi! Kaunsa item chahiye? 😊');
    }
  };
  window.cqAddToCart = async function(cid) {
    var s = window._cqStates[cid]; if (!s) return;
    var btn = document.getElementById('ca_' + cid); if (btn) { btn.disabled=true; btn.textContent='Adding…'; }
    var added = []; var failed = false;
    for (var item of s) {
      if (item.cardQty === 0) continue;
      var mods = item.selMods.map(mid => { var m = item.applicable_modifiers.find(x=>x.id===mid); return m?{id:m.id,name:m.name,price:m.price}:null; }).filter(Boolean);
      try {
        var modsTotal = mods.reduce((s,m)=>s+(m.price||0),0);
        var r = await fetch(API_BASE + '/api/order-ui/cart-item/' + SESSION_ID, {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ menu_item_id: item.menu_item_id, quantity: item.cardQty, name: item.name, price: item.price + modsTotal, notes: item.editNotes||'', modifiers: mods })
        });
        if (r.ok) {
          var modsT = mods.reduce((s,m)=>s+(m.price||0),0);
          cart[item.menu_item_id] = { qty: item.cardQty, name: item.name, price: item.price + modsT, notes: item.editNotes||'' };
          added.push(item.name + ' ×' + item.cardQty);
        } else failed = true;
      } catch(e) { failed = true; }
    }
    // Refresh from DB
    try {
      var cr = await fetch(API_BASE + '/api/order-ui/cart/' + SESSION_ID);
      var cd = await cr.json();
      if (cd.items) { cart = {}; cd.items.forEach(i => { cart[i.menu_item_id] = { qty:i.quantity, notes:i.notes||'', name:i.name, price:i.price }; }); }
    } catch(e) {}
    updateCartUI(); renderMenu();
    var el = document.getElementById(cid); if (el) el.closest('.ai-msg').remove();
    if (added.length) {
      showToast('✅ ' + added.join(', ') + ' added!');
      platformLocked = true;
      var bb = document.getElementById('getBillBtn'); if(bb) bb.disabled = false;
      // Push confirmation into chat history so AI knows exact cart state
      aiHistory.push({ role: 'assistant', content: 'SYSTEM: Successfully added to cart: ' + added.join(', ') + '.' });
    }
    if (failed) addAIMessage('bot', '⚠️ Kuch items add nahi ho paaye. Dobara try karein.');
    delete window._cqStates[cid];
    delete (window._cqViewMode||{})[cid];
    if (!hasPendingCard()) unlockChatInput();
  };

  window._cqStates = window._cqStates || {};
  window._cqStates[cardId] = cardState;
  window._cqViewMode = window._cqViewMode || {};
  window._cqViewMode[cardId] = viewMode;

  var msgDiv = document.createElement('div');
  msgDiv.className = 'ai-msg bot';
  msgDiv.style.cssText = 'max-width:98%;padding:0;background:transparent;border:none';
  msgDiv.innerHTML = buildCard();
  var msgs = document.getElementById('aiMessages');
  msgs.appendChild(msgDiv);
  msgs.scrollTop = msgs.scrollHeight;
  // Lock chat input until card is acted on
  if (!viewMode) lockChatInput('Pehle upar wala item confirm karo 👆');
}

// ══════════════════════════════════════════════
// UPSELL (unchanged — keep existing logic)
// ══════════════════════════════════════════════
var _upsellItem = null;
var _skipAddressCheck = false;

async function startUpsell(skipAddr) {
  _skipAddressCheck = skipAddr || false;
  var addrEl     = document.getElementById('deliveryAddress');
  var address    = addrEl ? addrEl.value.trim() : '';
  var isDelivery = document.getElementById('addressSection').style.display !== 'none';
  if (isDelivery && address.length < 6 && !skipAddr) {
    document.getElementById('addressHint').style.display = 'block';
    if (addrEl) { addrEl.focus(); addrEl.style.borderColor = '#e53e3e'; }
    return;
  }
  if (Object.keys(cart).length === 0) { showToast('Add items first!'); return; }
  var cartNames = Object.values(cart).map(i => i.name);
  var allNames  = allItems.map(i => i.name + ' (₹' + i.price + ')').join(', ');
  document.getElementById('upsellOverlay').style.opacity = '1';
  document.getElementById('upsellOverlay').style.pointerEvents = 'all';
  document.getElementById('upsellModal').style.transform = 'translateX(-50%) translateY(0)';
  document.getElementById('upsellMsg').textContent = 'Finding the perfect add-on…';
  document.getElementById('upsellItem').style.display = 'none';
  document.getElementById('upsellLoading').style.display = 'block';
  window._upsellOpen = true;
  try {
    var res = await fetch(API_BASE + '/api/order-ui/upsell/' + SESSION_ID, {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ cart_items: cartNames, menu_items: allNames })
    });
    var data = await res.json();
    document.getElementById('upsellLoading').style.display = 'none';
    if (data.item) {
      _upsellItem = data.item;
      document.getElementById('upsellMsg').textContent = data.message || 'You might love this!';
      document.getElementById('upsellItemName').textContent = data.item.name;
      document.getElementById('upsellItemPrice').textContent = '₹' + data.item.price;
      document.getElementById('upsellItem').style.display = 'block';
    } else {
      document.getElementById('upsellMsg').textContent = "Looks like you're all set! 🎉";
    }
  } catch(e) {
    document.getElementById('upsellLoading').style.display = 'none';
    document.getElementById('upsellMsg').textContent = "Looks like you're all set! 🎉";
  }
}

function closeUpsell() {
  document.getElementById('upsellOverlay').style.opacity = '0';
  document.getElementById('upsellOverlay').style.pointerEvents = 'none';
  document.getElementById('upsellModal').style.transform = 'translateX(-50%) translateY(100%)';
  window._upsellOpen = false;
  _upsellItem = null;
}

function addUpsellItem() {
  if (!_upsellItem) { closeUpsell(); confirmAfterUpsell(); return; }
  addItemDirect(_upsellItem.id, _upsellItem.name, _upsellItem.price, []);
  closeUpsell();
  confirmAfterUpsell();
}

function skipUpsell() { closeUpsell(); confirmAfterUpsell(); }

async function confirmAfterUpsell() {
  closeCart();
  if (sessionMode === 'dine_in' || sessionMode === 'zomato_dine_in' || sessionMode === 'swiggy_dine_in') {
    await placeOrder(true);
  } else {
    showConfirmModal();
  }
}

// ══════════════════════════════════════════════
// CONFIRM MODAL (takeaway/delivery)
// ══════════════════════════════════════════════
function showConfirmModal() {
  var items = Object.entries(cart).filter(([,i]) => i.qty > 0);
  var total = items.reduce((s,[,i]) => s + (i.price||0)*i.qty, 0);
  document.getElementById('confirmItems').innerHTML = items.map(([id,item]) =>
    '<div class="confirm-item"><div><div class="confirm-item-name">' + item.name + '</div>' +
    (item.notes ? '<div class="confirm-item-note">📝 ' + item.notes + '</div>' : '') +
    '</div><span class="confirm-item-price">₹' + (item.price*item.qty) + '</span></div>'
  ).join('');
  document.getElementById('confirmTotal').textContent = '₹' + total;
  var addrEl = document.getElementById('deliveryAddress');
  var addr = addrEl ? addrEl.value.trim() : '';
  if (addr) { document.getElementById('confirmAddr').style.display='block'; document.getElementById('confirmAddr').textContent = '📍 ' + addr; }
  document.getElementById('confirmModal').style.display = 'block';
}
function closeConfirm() { document.getElementById('confirmModal').style.display = 'none'; }
function closeConfirmOpenCart() { closeConfirm(); openCart(); }
async function confirmAndPlace() {
  var btn = document.getElementById('confirmPlaceBtn');
  btn.disabled=true; btn.textContent='Placing…';
  await placeOrder(true);
  closeConfirm();
}

// ══════════════════════════════════════════════
// NOTES
// ══════════════════════════════════════════════
var _notesItemId = null;
function openNotes(itemId) {
  _notesItemId = itemId;
  document.getElementById('notesItemName').textContent = cart[itemId] ? cart[itemId].name : '';
  document.getElementById('notesTextarea').value = cart[itemId] ? (cart[itemId].notes || '') : '';
  document.getElementById('notesModal').style.display = 'block';
}
function closeNotes() { document.getElementById('notesModal').style.display='none'; _notesItemId=null; }
function addNoteHint(hint) {
  var ta = document.getElementById('notesTextarea');
  ta.value = ta.value ? ta.value + ', ' + hint : hint;
}
function saveNotes() {
  if (_notesItemId && cart[_notesItemId]) {
    cart[_notesItemId].notes = document.getElementById('notesTextarea').value.trim();
    syncCartItem(_notesItemId, cart[_notesItemId].qty);
  }
  closeNotes();
}

// ══════════════════════════════════════════════
// POPULAR ITEMS
// ══════════════════════════════════════════════
function renderPopular() {
  var popular = allItems.filter(i => i.is_popular);
  if (!popular.length) {
    var seen = {};
    popular = allItems.filter(i => { if (!seen[i.category_id]) { seen[i.category_id]=true; return true; } return false; }).slice(0,4);
  }
  if (!popular.length) return;
  document.getElementById('popularSection').style.display = 'block';
  document.getElementById('popularItems').innerHTML = popular.map(function(item) {
    return '<div class="popular-chip" onclick="quickAddPopular(\'' + item.id + '\',\'' + item.name.replace(/'/g,"\\'") + '\',' + item.price + ')">' +
      '<div class="popular-chip-name">' + item.name + '</div>' +
      '<div class="popular-chip-price">₹' + item.price + '</div>' +
      '<div class="popular-chip-add">+ Add</div></div>';
  }).join('');
}
function quickAddPopular(id, name, price) {
  if (cart[id]) cart[id].qty += 1;
  else cart[id] = { qty:1, notes:'', name:name, price:price };
  renderMenu(); updateCartUI();
  syncCartItem(id, cart[id].qty);
  showToast('✅ ' + name + ' added!');
}

// ══════════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════════
function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// ══════════════════════════════════════════════
// LANGUAGE
// ══════════════════════════════════════════════
var selectedLang = 'hi';
var LANGS = [
  {code:'hi',name:'Hindi',flag:'🇮🇳',native:'हिंदी'},{code:'en',name:'English',flag:'🇬🇧',native:'English'},
  {code:'mr',name:'Marathi',flag:'🇮🇳',native:'मराठी'},{code:'gu',name:'Gujarati',flag:'🇮🇳',native:'ગુજરાતી'},
  {code:'pa',name:'Punjabi',flag:'🇮🇳',native:'ਪੰਜਾਬੀ'},{code:'bn',name:'Bengali',flag:'🇮🇳',native:'বাংলা'},
  {code:'ta',name:'Tamil',flag:'🇮🇳',native:'தமிழ்'},{code:'te',name:'Telugu',flag:'🇮🇳',native:'తెలుగు'},
  {code:'ar',name:'Arabic',flag:'🇸🇦',native:'العربية'},{code:'zh',name:'Chinese',flag:'🇨🇳',native:'中文'}
];
function openLangDrawer() {
  document.getElementById('langGrid').innerHTML = LANGS.map(l =>
    '<div class="lang-option' + (l.code===selectedLang?' selected':'') + '" onclick="setLang(\'' + l.code + '\')">' +
    '<span class="flag">' + l.flag + '</span><div class="label"><span>' + l.name + '</span><span class="native">' + l.native + '</span></div></div>'
  ).join('');
  document.getElementById('langDrawer').style.display = 'block';
}
function closeLangDrawer() { document.getElementById('langDrawer').style.display = 'none'; }
function setLang(code) {
  selectedLang = code;
  var lang = LANGS.find(l => l.code===code);
  document.getElementById('langBtn').textContent = lang.flag + ' ' + lang.code.toUpperCase();
  closeLangDrawer();
  var msgs = document.getElementById('aiMessages');
  if (msgs) { msgs.innerHTML=''; addAIMessage('bot', restaurant ? (restaurant.welcome_message||'Namaste! 😊') : 'Namaste! 😊'); }
  showToast(lang.flag + ' Language changed to ' + lang.name);
}
function getLangInstruction() {
  var map = { en:'English', hi:'Hindi/Hinglish', mr:'Marathi', gu:'Gujarati', pa:'Punjabi', bn:'Bengali', ta:'Tamil', te:'Telugu', ar:'Arabic', zh:'Chinese' };
  return map[selectedLang] || 'Hinglish';
}

// ══════════════════════════════════════════════
// START
// ══════════════════════════════════════════════
init();
</script>

<!-- Modifier Modal -->
<div id="modifierModal" style="display:none;position:fixed;inset:0;z-index:500">
  <div onclick="closeModifierModal()" style="position:absolute;inset:0;background:rgba(0,0,0,0.5)"></div>
  <div style="position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:white;border-radius:24px 24px 0 0;padding:24px 20px 32px;box-sizing:border-box">
    <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 16px"></div>
    <div id="modItemName" style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;margin-bottom:4px"></div>
    <div id="modItemPrice" style="font-size:14px;color:#9b8b72;margin-bottom:16px"></div>
    <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#9b8b72;margin-bottom:4px">Add extras (optional)</div>
    <div id="modOptions"></div>
    <button onclick="confirmModifiers()" style="width:100%;padding:14px;background:#1a1207;border:none;border-radius:12px;color:white;font-family:'Syne',sans-serif;font-size:15px;font-weight:800;cursor:pointer;margin-top:16px">
      Add to Cart &#8377;<span id="modTotal">0</span>
    </button>
    <button onclick="skipModifiers()" style="width:100%;padding:10px;background:none;border:none;color:#9b8b72;font-size:13px;cursor:pointer;margin-top:6px">
      Add without extras
    </button>
  </div>
</div>
</body>
</html>
  

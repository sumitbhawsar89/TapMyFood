    lines.push('<div class="info-section-title">' + t('about') + '</div>');
    lines.push('<div class="info-val" style="font-size:13px;line-height:1.5;margin-bottom:8px">' + item.description + '</div>');
  }
  if (item.spice_level && item.spice_level !== 'none') {
    var spiceMap = { mild: '\ud83d\ude0a Mild', medium: '\ud83c\udf36 Medium', spicy: '\ud83c\udf36\ud83c\udf36 Spicy', hot: '\ud83c\udf36\ud83c\udf36 Spicy' };
    lines.push('<div class="info-row"><span class="info-label">' + t('spice') + '</span><span class="info-val">' + (spiceMap[item.spice_level] || item.spice_level) + '</span></div>');

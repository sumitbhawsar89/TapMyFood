// CART OPERATIONS (unchanged from original)
// ══════════════════════════════════════════════
function addItem(itemId, name, price) {
  var menuItem = allItems.find(function(i) { return i.id === itemId; });
  var catId = menuItem ? menuItem.category_id : '';
  var applicable = allModifiers.filter(function(m) {
    var catMatch  = m.applicable_categories && m.applicable_categories.some(function(c) { return c === catId; });
    var itemMatch = m.applicable_item_ids && m.applicable_item_ids.length > 0 && m.applicable_item_ids.includes(itemId);
    return catMatch || itemMatch;
  });
  if (applicable.length > 0) {
    openModifierModal(itemId, name, price, applicable);
  } else {
    addItemDirect(itemId, name, price, []);
  }
}
function addItemDirect(itemId, name, price, modifiers) {
  var modsTotal = modifiers.reduce(function(s,m) { return s+(m.price||0); }, 0);
  var unitPrice = price + modsTotal;
  var newQty    = cart[itemId] ? cart[itemId].qty + 1 : 1;
  var menuItem  = allItems.find(function(i) { return i.id === itemId; });
  var engName   = menuItem ? (menuItem.orig_name || menuItem.name) : name;
  cart[itemId]  = { qty: newQty, notes: cart[itemId] ? cart[itemId].notes : '', name: engName, display_name: name, price: unitPrice, modifiers: modifiers };
  renderMenu();
  updateCartUI();
  syncCartItem(itemId, newQty, modifiers);
  var modText = modifiers.length ? ' + ' + modifiers.map(function(m) { return m.name; }).join(', ') : '';
  showToast('✅ ' + name + modText + ' added!');
}
function openModifierModal(itemId, name, price, mods) {
  pendingAddItem = { itemId, name, price };
  document.getElementById('modItemName').textContent = name;
  document.getElementById('modItemPrice').textContent = '₹' + price;
  document.getElementById('modTotal').textContent = price;
  var el = document.getElementById('modExtrasLabel'); if (el) el.textContent = t('add_extras');
  var cb = document.getElementById('modConfirmBtn'); if (cb) cb.innerHTML = t('add_to_cart') + ' ₹<span id="modTotal">' + price + '</span>';
  var sb = document.getElementById('modSkipBtn'); if (sb) sb.textContent = t('add_without');
  var html = '';
  mods.forEach(function(mod) {
    html += '<div style="display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid #f0ebe3">' +
      '<div style="display:flex;align-items:center;gap:10px">' +
      '<input type="checkbox" id="mod_' + mod.id + '" style="width:20px;height:20px;accent-color:#ea580c;cursor:pointer" ' +
      'onchange="updateModTotal(' + price + ')" data-name="' + mod.name + '" data-price="' + mod.price + '">' +
      '<label for="mod_' + mod.id + '" style="font-size:14px;font-weight:600;cursor:pointer">' + mod.name + '</label>' +
      '</div><span style="color:#ea580c;font-weight:700;font-size:13px">+₹' + mod.price + '</span></div>';
  });
  document.getElementById('modOptions').innerHTML = html;
  document.getElementById('modifierModal').style.display = 'block';
}
function updateModTotal(base) {
  var total = base;
  document.querySelectorAll('[id^="mod_"]:checked').forEach(function(cb) { total += parseInt(cb.dataset.price||0); });
  document.getElementById('modTotal').textContent = total;
}
function confirmModifiers() {
  if (!pendingAddItem) return;
  var item = pendingAddItem;
  var selected = [];
  document.querySelectorAll('[id^="mod_"]:checked').forEach(function(cb) {
    selected.push({ id: cb.id.replace('mod_',''), name: cb.dataset.name, price: parseInt(cb.dataset.price||0) });
  });
  closeModifierModal();
  addItemDirect(item.itemId, item.name, item.price, selected);
}
function skipModifiers() {
  if (!pendingAddItem) return;
  var item = pendingAddItem;
  closeModifierModal();
  addItemDirect(item.itemId, item.name, item.price, []);
}
function closeModifierModal() {
  document.getElementById('modifierModal').style.display = 'none';
  pendingAddItem = null;
}
function changeQty(itemId, name, price, delta) {
  var cur    = cart[itemId] ? cart[itemId].qty : 0;
  var newQty = cur + delta;
  if (newQty <= 0) { delete cart[itemId]; }
  else { cart[itemId] = { qty: newQty, notes: cart[itemId] ? cart[itemId].notes : '', name, price }; }
  var qEl = document.getElementById('qty_' + itemId);
  if (qEl) qEl.textContent = newQty > 0 ? newQty : 0;
  var card = document.getElementById('card_' + itemId);
  if (card) { if (newQty <= 0) card.classList.remove('in-cart'); else card.classList.add('in-cart'); }
  updateCartUI();
  syncCartItem(itemId, newQty < 0 ? 0 : newQty);
}
function updateCartUI() {
  var items = Object.entries(cart);
  var count = items.reduce(function(s,e) { return s+e[1].qty; }, 0);
  var total = items.reduce(function(s,e) { return s+e[1].price*e[1].qty; }, 0);
  var pill  = document.getElementById('cartPill');
  document.getElementById('cartCount').textContent = count;
  document.getElementById('cartPillText').textContent = count === 1 ? '1 ' + t('item') : count + ' ' + t('items');
  document.getElementById('cartPillTotal').textContent = count > 0 ? ' — ₹' + total : '';
  if (count > 0) pill.classList.add('visible'); else pill.classList.remove('visible');
}
async function syncCartItem(itemId, qty, modifiers) {
  if (!SESSION_ID) return;
  var item = cart[itemId];
  try {
    var res = await fetch(API_BASE + '/api/order-ui/cart-item/' + SESSION_ID, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        menu_item_id: itemId,
        quantity: qty || 0,
        name:  item ? (item.name || item.display_name || '') : '',
        price: item ? item.price : 0,
        notes: item ? item.notes : null,
        modifiers: modifiers || (item ? item.modifiers : [])
      })
    });
    if (!res.ok && res.status !== 409) {
      var errData = await res.json().catch(function(){return {};});
      console.error('syncCartItem error', res.status, errData);
    }
    if (res.status === 409) lockCartAfterOrder();
  } catch(e) { console.error('syncCartItem failed', e); }
}
function lockCartAfterOrder() {
  document.querySelectorAll('.qty-btn, .add-btn, .place-order-btn').forEach(function(btn) {
    btn.disabled = true; btn.style.opacity = '0.4'; btn.style.cursor = 'not-allowed';
  });
  var btn = document.getElementById('placeOrderBtn');
  if (btn) { btn.textContent = '✅ Order Placed'; btn.style.background = '#22c55e'; btn.disabled = true; }
  showToast(t('order_locked'));
}

// RENDER MENU
// ══════════════════════════════════════════════
function getFilteredItems(search) {
  var addonCatIds = categories.filter(isAddonCategory).map(function(c) { return c.id; });
  var items = allItems.filter(function(i) { return addonCatIds.indexOf(i.category_id) === -1; });
  // Search: match translated name OR original English name
  if (search) {
    return items.filter(function(i) {
      var name = (i.name || '').toLowerCase();
      var orig = (i.orig_name || i.name || '').toLowerCase();
      var desc = (i.description || '').toLowerCase();
      return name.includes(search) || orig.includes(search) || desc.includes(search);
    });
  }
  // Category filter
  if (activeCat) {
    items = items.filter(function(i) { return i.category_id === activeCat; });
  }
  // Chip filter
  switch(activeFilter) {
    case 'veg':
      items = items.filter(function(i) { return i.is_veg === true; });
      break;
    case 'nonveg':
      items = items.filter(function(i) { return i.is_veg === false; });
      break;
    case 'mild':
      items = items.filter(function(i) { return i.spice_level === 'mild'; });
      break;
    case 'spicy':
      items = items.filter(function(i) { return i.spice_level === 'spicy' || i.spice_level === 'hot'; });
      break;
    case 'popular':
      items = items.filter(function(i) {
        return i.tags && i.tags.some(function(t) { return t.tag_code === 'popular'; });
      });
      break;
  }
  return items;
}
function spiceBadge(level) {
  if (!level || level === 'none') return '';
  if (level === 'mild')   return '<span class="item-badge spice">\ud83d\ude0a Mild</span>';
  if (level === 'medium') return '<span class="item-badge spice">\ud83c\udf36 Medium</span>';
  if (level === 'spicy' || level === 'hot') return '<span class="item-badge spice">\ud83c\udf36\ud83c\udf36 Spicy</span>';
  return '';
}
function labelBadges(tags) {
  if (!tags || !tags.length) return '';
  return tags.filter(function(t) { return t.type === 'LABEL'; }).map(function(t) {
    if (t.tag_code === 'popular')    return '<span class="item-badge popular">⭐ Popular</span>';
    if (t.tag_code === 'chef_special') return '<span class="item-badge chef">\ud83d\udc68‍\ud83c\udf73 Chef Special</span>';
    return '';
  }).join('');
}
function addBtnHtml(id, name, price) {
  var safeName = name.replace(/'/g, "\\'");
  return '<button class="add-btn" id="addbtn_' + id + '" onclick="addItem(\'' + id + '\',\'' + safeName + '\',' + price + ')">' + t('add') + '</button>';
}
function renderMenu(search) {

// INIT
// ══════════════════════════════════════════════
async function init() {
  if (!SESSION_ID) {
    document.getElementById('menuContent').innerHTML =
      '<div class="empty-state"><div class="icon">\ud83d\udd17</div><p>Invalid link. Please scan the QR code again.</p></div>';
    return;
  }
  try {
    const [sessionRes, menuRes] = await Promise.all([
      fetch(API_BASE + '/api/order-ui/session/' + SESSION_ID),
      fetch(API_BASE + '/api/order-ui/menu/' + SESSION_ID + '?lang=' + (localStorage.getItem('buddy_lang') || 'en'))
    ]);
    if (!sessionRes.ok) throw new Error('Session not found');
    const sessionData = await sessionRes.json();
    if (['closed','paid','delivered'].includes(sessionData.status)) {
      document.getElementById('menuContent').innerHTML =
        '<div class="empty-state" style="padding:60px 24px">' +
        '<div class="icon">\ud83d\udd17</div>' +
        '<h3 style="font-family:Syne,sans-serif;font-size:18px;margin-bottom:8px">Link Expired</h3>' +
        '<p>This order session has ended.</p>' +
        '<p>Please <strong>scan the QR code again</strong> to start a new order.</p>' +
        '</div>';
      document.getElementById('catTabs').style.display = 'none';
      document.getElementById('restName').textContent = sessionData.restaurant_name || 'Restaurant';
      return;
    }
    const menuData = await menuRes.json();
    restaurant = menuData.restaurant;
    categories = menuData.categories;
    allItems = (menuData.items || []).map(function(item) {
      item.orig_name = item.name; return item;
    });
    document.getElementById('restName').textContent = restaurant.name;
    document.title = 'Order — ' + restaurant.name;
    sessionMode = sessionData.mode || 'delivery';
    const modeEl = document.getElementById('modeBadge');
    sessionTable = sessionData.table_number || '—';
    sessionDeliveryAddress = sessionData.delivery_address || '';
    if (sessionMode === 'dine_in') {
      modeEl.textContent = t('mode_table') + ' ' + sessionTable;
      modeEl.className = 'mode-badge dine';
    } else if (sessionMode === 'takeaway') {
      modeEl.textContent = t('mode_takeaway');
      modeEl.className = 'mode-badge takeaway';
    } else {
      modeEl.textContent = t('mode_delivery');
      modeEl.className = 'mode-badge';
    }
    // Lock ALL modes when already ordered — prevent re-ordering on same session link
    if (sessionData.status === 'ordered') {
      const cartRes2  = await fetch(API_BASE + '/api/order-ui/cart/' + SESSION_ID);
      const cartData2 = await cartRes2.json();
      if (cartData2.items) {
        cartData2.items.forEach(function(item) {
          cart[item.menu_item_id] = { qty: item.quantity, notes: item.notes || '', name: item.name, price: item.price };
        });
      }
      allModifiers = menuData.modifiers || [];
      buildFilterChips();
      buildCategoryTabs();
      renderMenu();
      renderPopular();
      updateCartUI();
      lockUI('');
      return;
    }
    const cartRes = await fetch(API_BASE + '/api/order-ui/cart/' + SESSION_ID);
    const cartData = await cartRes.json();
    if (cartData.items) {
      cartData.items.forEach(function(item) {
        cart[item.menu_item_id] = { qty: item.quantity, notes: item.notes || '', name: item.name, price: item.price };
      });
    }
    allModifiers = menuData.modifiers || [];
    buildFilterChips();
    buildCategoryTabs();
    renderMenu();
    renderPopular();
    updateCartUI();
    updateUIStrings();
  document.getElementById('searchInput').addEventListener('input', function(e) {
      activeFilter = 'all';
      document.querySelectorAll('.filter-chip').forEach(function(c) { c.classList.remove('active'); });
      document.querySelector('.filter-chip[data-filter="all"]').classList.add('active');
      renderMenu(e.target.value.toLowerCase().trim());
    });
  } catch (err) {
    console.error(err);
    document.getElementById('menuContent').innerHTML =
      '<div class="empty-state"><div class="icon">\ud83d\ude15</div><p>' + t('menu_load_error') + '</p></div>';
  }
}

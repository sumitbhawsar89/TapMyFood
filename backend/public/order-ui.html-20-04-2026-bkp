async function placeOrderFromCheckout() {
  if (Object.keys(cart).length === 0) { showToast(t('add_items_first')); return; }
  if (sessionMode === 'delivery') {
    var addr = document.getElementById('checkoutAddrInput').value.trim();
    if (addr.length < 6) {
      document.getElementById('checkoutAddrHint').style.display = 'block';
      document.getElementById('checkoutAddrInput').focus();
      document.getElementById('checkoutAddrInput').style.borderColor = '#e53e3e'; return;
    }
    sessionDeliveryAddress = addr;
    await fetch(API_BASE + '/api/order-ui/address/' + SESSION_ID, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ address: addr })
    }).catch(function() {});
  }
  var btn = document.getElementById('checkoutPlaceBtn');
  var origText = btn.textContent;
  btn.textContent = t('placing_order'); btn.disabled = true;
  var payMode = sessionMode === 'dine_in' ? 'cod' : checkoutPaymentMode;
  try {
    var res  = await fetch(API_BASE + '/api/order-ui/place-order/' + SESSION_ID, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ payment_mode: payMode })
    });
    var data = await res.json();
    if (res.status === 410) { showToast(t('session_expired')); btn.textContent = origText; btn.disabled = false; return; }
    if (data.success) {
      closeCheckout();
      document.getElementById('cartPill').classList.remove('visible');
      if (payMode === 'online' && data.payment_url) {
        showToast('✅ ' + t('order_placed') + data.bill_number);
        cart = {}; updateCartUI(); renderMenu(); lockUI(data.bill_number);
        setTimeout(function() { window.location.href = data.payment_url; }, 1500); return;
      }
      if (payMode === 'online' && data.payment_status === 'payment_pending') {
        showToast('✅ Order placed! Complete payment to confirm.');
        cart = {}; updateCartUI(); renderMenu(); lockUI(data.bill_number); return;
      }
      showToast('✅ ' + t('order_placed') + data.bill_number);
      if (sessionMode !== 'dine_in') {
        cart = {}; updateCartUI(); renderMenu(); lockUI(data.bill_number);
      } else {
        cart = {}; updateCartUI(); renderMenu();
        btn.textContent = 'Send to Kitchen →'; btn.disabled = false;
      }
    } else { throw new Error(data.error || 'Failed'); }
  } catch(e) {
    showToast(t('order_failed'));
    btn.textContent = origText; btn.disabled = false;
  }
}

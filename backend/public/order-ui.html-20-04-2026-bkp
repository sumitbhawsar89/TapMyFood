  var nt = document.getElementById('notesTitle'); if (nt) nt.textContent = t('special_instructions');
  var ns = document.getElementById('notesSaveBtn'); if (ns) ns.textContent = t('save');
  var h1 = document.getElementById('hint_spicy'); if (h1) h1.textContent = t('note_extra_spicy');
  var h2 = document.getElementById('hint_onions'); if (h2) h2.textContent = t('note_no_onions');
  var h3 = document.getElementById('hint_oil'); if (h3) h3.textContent = t('note_less_oil');
  var h4 = document.getElementById('hint_garlic'); if (h4) h4.textContent = t('note_no_garlic');
  var h5 = document.getElementById('hint_welldone'); if (h5) h5.textContent = t('note_well_done');
  var h6 = document.getElementById('hint_sauce'); if (h6) h6.textContent = t('note_extra_sauce');
  var ldt = document.getElementById('langDrawerTitle'); if (ldt) ldt.textContent = t('choose_language');
  var lt = document.getElementById('loadingText'); if (lt) lt.textContent = t('loading');
  buildFilterChips();
}
function selectLang(code) {
  selectedLang = code;
  localStorage.setItem('buddy_lang', code);
  var lang = getLang();
  document.getElementById('langBtn').textContent = lang.flag + ' ' + lang.code.toUpperCase();
  closeLangDrawer();
  fetch(API_BASE + '/api/order-ui/menu/' + SESSION_ID + '?lang=' + code)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var prevOrig = {};
      allItems.forEach(function(i) { prevOrig[i.id] = i.orig_name || i.name; });
      allItems = (data.items || []).map(function(item) {
        item.orig_name = prevOrig[item.id] || item.name; return item;
      });
      categories  = data.categories || [];
      allModifiers = data.modifiers  || [];
      Object.keys(cart).forEach(function(id) {
        var ni = allItems.find(function(i) { return i.id === id; });
        if (ni) cart[id].display_name = ni.name;
      });
      updateUIStrings();
      buildCategoryTabs();
      renderMenu();
      renderPopular();
      updateCartUI();
      loadPastAddresses(); // refresh address labels in new language
      showToast(lang.flag + ' ' + t('lang_changed') + ' ' + lang.name);
    })
    .catch(function(e) { console.error('Menu reload failed', e); });
}
// ══════════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════════
function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(function() { t.classList.remove('show'); }, 2500);
}
// ══════════════════════════════════════════════
// START
// ══════════════════════════════════════════════
init();
</script>

function closeAnyOpenInfoPanel() {
  if (!openInfoId) return;
  var panel = document.getElementById('info_' + openInfoId);
  var btn   = document.getElementById('infobtn_' + openInfoId);
  if (panel) panel.classList.remove('open');
  if (btn)   btn.classList.remove('open');
  openInfoId = null;
}
async function toggleInfoPanel(itemId) {
  // If same panel is open — close it
  if (openInfoId === itemId) {
    closeAnyOpenInfoPanel();
    return;
  }
  // Close any previously open panel
  closeAnyOpenInfoPanel();
  // Open new panel
  openInfoId = itemId;
  var panel = document.getElementById('info_' + itemId);
  var btn   = document.getElementById('infobtn_' + itemId);
  if (!panel || !btn) return;
  btn.classList.add('open');
  panel.classList.add('open');
  // Check if we already have rich data for this item
  var item = allItems.find(function(i) { return i.id === itemId; });
  // Try to fetch from info endpoint first (has tags, allergens, etc.)
  try {
    var res  = await fetch(API_BASE + '/api/order-ui/menu/items/' + itemId + '/info?lang=' + (selectedLang || 'en'));
    if (res.ok) {
      var data = await res.json();
      var content = document.getElementById('infocontent_' + itemId);
      if (content) content.innerHTML = buildInfoPanelHTML(data);
      return;
    }
  } catch(e) { /* fall through to basic display */ }
  // Fallback to basic item data if endpoint fails
  var content = document.getElementById('infocontent_' + itemId);
  if (content && item) content.innerHTML = renderInfoPanelContent(item);
}
function renderInfoPanelContent(item) {
  // Basic fallback using data already in allItems
  var lines = [];

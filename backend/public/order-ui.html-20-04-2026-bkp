function buildFilterChips() {
  // Show filter chips only if we have enough items to make filtering useful
  if (allItems.length < 4) return;
  // Check what data exists to show relevant chips
  const hasVeg    = allItems.some(function(i) { return i.is_veg === true; });
  const hasNonveg = allItems.some(function(i) { return i.is_veg === false; });
  const hasMild   = allItems.some(function(i) { return i.spice_level === 'mild'; });
  const hasSpicy  = allItems.some(function(i) { return i.spice_level === 'spicy' || i.spice_level === 'hot'; });
  const hasPopular = allItems.some(function(i) {
    return i.tags && i.tags.some(function(t) { return t.tag_code === 'popular'; });
  });
  var chips = document.getElementById('filterChips');
  var html = '<div class="filter-chip active" data-filter="all" onclick="applyFilter(\'all\',this)">' + t('filter_all') + '</div>';
  if (hasVeg)     html += '<div class="filter-chip" data-filter="veg" onclick="applyFilter(\'veg\',this)">' + t('filter_veg') + '</div>';
  if (hasNonveg)  html += '<div class="filter-chip" data-filter="nonveg" onclick="applyFilter(\'nonveg\',this)">' + t('filter_nonveg') + '</div>';
  if (hasMild)    html += '<div class="filter-chip" data-filter="mild" onclick="applyFilter(\'mild\',this)">' + t('filter_mild') + '</div>';
  if (hasSpicy)   html += '<div class="filter-chip" data-filter="spicy" onclick="applyFilter(\'spicy\',this)">' + t('filter_spicy') + '</div>';
  if (hasPopular) html += '<div class="filter-chip" data-filter="popular" onclick="applyFilter(\'popular\',this)">' + t('filter_popular') + '</div>';
  chips.innerHTML = html;

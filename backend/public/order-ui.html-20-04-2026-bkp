  if (!items.length) {
    var filterMsg = activeFilter !== 'all'
      ? '<p style="margin-top:8px;font-size:13px">' + t('try_filter') + '</p>'
      : '';
    container.innerHTML = '<div class="empty-state"><div class="icon">\ud83d\udd0d</div><p>' + t('no_items') + '</p>' + filterMsg + '</div>';
    return;
  }
  container.innerHTML = items.map(function(item) {
    var inCart  = cart[item.id];
    var vegDot  = item.is_veg !== null && item.is_veg !== undefined
      ? '<span class="veg-dot ' + (item.is_veg ? 'veg' : 'nonveg') + '"></span>'
      : '';
    var imgHtml = item.image_url
      ? '<img class="item-img" src="' + item.image_url + '" alt="' + item.name + '" onerror="this.style.display=\'none\'">'
      : '';
    var spice  = spiceBadge(item.spice_level);
    var labels = labelBadges(item.tags || []);
    var badges = spice + labels;
    var qtyHtml = inCart
      ? '<div class="qty-control">' +
        '<button class="qty-btn minus" onclick="changeQty(\'' + item.id + '\',\'' + item.name.replace(/'/g, "\\'") + '\',' + item.price + ',-1)">−</button>' +
        '<span class="qty-num" id="qty_' + item.id + '">' + inCart.qty + '</span>' +
        '<button class="qty-btn plus" onclick="changeQty(\'' + item.id + '\',\'' + item.name.replace(/'/g, "\\'") + '\',' + item.price + ',1)">+</button>' +
        '<button class="note-btn" onclick="openNotes(\'' + item.id + '\')" title="Special instructions">\ud83d\udcdd</button>' +
        '</div>'
      : '<button class="add-btn" id="addbtn_' + item.id + '" onclick="addItem(\'' + item.id + '\',\'' + item.name.replace(/'/g, "\\'") + '\',' + item.price + ')">Add</button>';
    var infoPanelId = 'info_' + item.id;
    var isOpen = openInfoId === item.id;
    return '<div class="item-card' + (inCart ? ' in-cart' : '') + '" id="card_' + item.id + '">' +
      '<div class="item-card-top">' +
      '<div class="item-info">' +
      '<div class="item-name">' + vegDot + item.name + '</div>' +
      (badges ? '<div class="item-badges">' + badges + '</div>' : '') +
      (item.description ? '<div class="item-desc">' + item.description + '</div>' : '') +
      '<div class="item-footer">' +

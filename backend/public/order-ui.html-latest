<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Order</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --ink:    #1a1207;
    --cream:  #fdf6e9;
    --amber:  #f59e0b;
    --orange: #ea580c;
    --green:  #16a34a;
    --red:    #dc2626;
    --muted:  #9b8b72;
    --card:   #ffffff;
    --border: #ede8df;
    --radius: 16px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--ink); min-height: 100vh; max-width: 480px; margin: 0 auto; padding-bottom: 160px; }
  .header { background: var(--ink); color: white; padding: 20px 20px 16px; position: sticky; top: 0; z-index: 100; }
  .header-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .restaurant-name { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800; letter-spacing: -0.3px; }
  .mode-badge { font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 20px; background: var(--amber); color: var(--ink); text-transform: uppercase; letter-spacing: 0.5px; }
  .mode-badge.dine { background: #22c55e; }
  .mode-badge.takeaway { background: #a78bfa; color: white; }
  .search-wrap { position: relative; }
  .search-input { width: 100%; background: rgba(255,255,255,0.1); border: 1.5px solid rgba(255,255,255,0.15); border-radius: 10px; padding: 10px 16px 10px 38px; font-family: 'DM Sans', sans-serif; font-size: 14px; color: white; outline: none; transition: border-color 0.2s; }
  .search-input::placeholder { color: rgba(255,255,255,0.45); }
  .search-input:focus { border-color: var(--amber); }
  .search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); opacity: 0.5; font-size: 15px; }

  /* ── FILTER CHIPS ── */
  .filter-chips-wrap { display: flex; gap: 8px; padding: 10px 16px; overflow-x: auto; scrollbar-width: none; background: white; border-bottom: 1px solid var(--border); }
  .filter-chips-wrap::-webkit-scrollbar { display: none; }
  .filter-chip { flex-shrink: 0; padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; background: var(--cream); border: 1.5px solid var(--border); cursor: pointer; transition: all 0.15s; white-space: nowrap; display: flex; align-items: center; gap: 4px; }
  .filter-chip.active { background: var(--ink); color: white; border-color: var(--ink); }
  .filter-chip:active { transform: scale(0.95); }

  .cat-tabs { display: flex; gap: 8px; padding: 14px 20px; overflow-x: auto; scrollbar-width: none; background: white; border-bottom: 1px solid var(--border); }
  .cat-tabs::-webkit-scrollbar { display: none; }
  .cat-tab { flex-shrink: 0; padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 500; background: var(--cream); border: 1.5px solid var(--border); cursor: pointer; transition: all 0.15s; white-space: nowrap; }
  .cat-tab.active { background: var(--ink); color: white; border-color: var(--ink); }
  .menu-section { padding: 0 16px; }
  .section-title { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; padding: 18px 0 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; }

  /* ── ITEM CARD ── */
  .item-card { background: var(--card); border-radius: var(--radius); border: 1.5px solid var(--border); padding: 14px; margin-bottom: 10px; transition: border-color 0.2s; }
  .item-card.in-cart { border-color: var(--orange); }
  .item-card-top { display: flex; gap: 12px; align-items: flex-start; }
  .item-info { flex: 1; min-width: 0; }
  .item-name { font-weight: 600; font-size: 15px; margin-bottom: 3px; }
  .item-badges { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 6px; align-items: center; }
  .item-badge { font-size: 11px; font-weight: 600; padding: 2px 7px; border-radius: 10px; }
  .item-badge.spice { background: #fff3cd; color: #856404; }
  .item-badge.popular { background: #fff8e1; color: #e65100; }
  .item-badge.chef { background: #f3e5f5; color: #6a1b9a; }
  .item-desc { font-size: 12px; color: var(--muted); margin-bottom: 8px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .item-footer { display: flex; align-items: center; justify-content: space-between; }
  .item-price { font-weight: 700; font-size: 16px; color: var(--orange); }
  .veg-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 5px; vertical-align: middle; flex-shrink: 0; }
  .veg-dot.veg { background: var(--green); }
  .veg-dot.nonveg { background: var(--red); }
  .qty-control { display: flex; align-items: center; gap: 8px; }
  .qty-btn { width: 28px; height: 28px; border-radius: 50%; border: none; font-size: 18px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.15s; background: var(--orange); color: white; }
  .qty-btn:active { transform: scale(0.9); }
  .qty-num { font-weight: 700; font-size: 15px; min-width: 20px; text-align: center; }
  .add-btn { padding: 6px 16px; border-radius: 20px; border: 1.5px solid var(--orange); background: white; color: var(--orange); font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.15s; }
  .add-btn:active { background: var(--orange); color: white; }
  .item-img { width: 80px; height: 80px; border-radius: 12px; object-fit: cover; flex-shrink: 0; background: var(--cream); }

  /* ── INFO BUTTON ── */
  .info-btn { background: none; border: 1.5px solid var(--border); border-radius: 50%; width: 28px; height: 28px; font-size: 14px; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.15s; color: var(--muted); margin-left: 6px; }
  .info-btn:active { background: var(--cream); }
  .info-btn.open { background: var(--ink); color: white; border-color: var(--ink); }

  /* ── INFO PANEL (inline slide-down) ── */
  .info-panel { overflow: hidden; max-height: 0; transition: max-height 0.3s ease; }
  .info-panel.open { max-height: 800px; }
  .info-panel-inner { border-top: 1px solid var(--border); margin-top: 12px; padding-top: 12px; }
  .info-row { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 8px; font-size: 13px; }
  .info-label { font-weight: 600; color: var(--ink); min-width: 80px; flex-shrink: 0; }
  .info-val { color: #444; line-height: 1.5; }
  .info-safe-tone { font-size: 11px; color: var(--muted); font-style: italic; margin-top: 4px; }
  .info-tag-row { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 8px; }
  .info-tag { font-size: 11px; padding: 3px 8px; border-radius: 10px; font-weight: 600; }
  .info-tag.diet { background: #e8f5e9; color: #2e7d32; }
  .info-tag.spice { background: #fff3e0; color: #e65100; }
  .info-tag.label { background: #f3e5f5; color: #6a1b9a; }
  .info-tag.flavor { background: #e3f2fd; color: #1565c0; }
  .info-tag.experience { background: #e0f7fa; color: #006064; }
  .info-tag.restriction { background: #fce4ec; color: #880e4f; }
  .info-tag.allergen { background: #fff8e1; color: #f57f17; }
  .info-tag.drink { background: #ede7f6; color: #4527a0; }
  .info-section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--muted); margin-bottom: 5px; margin-top: 8px; }
  .info-warn { font-size: 11px; color: #c0392b; background: #fff5f5; border-radius: 6px; padding: 4px 8px; margin-top: 4px; }
  .info-bestseller { display: flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 700; color: var(--orange); margin-bottom: 8px; }

  .empty-state { text-align: center; padding: 60px 24px; color: var(--muted); }
  .empty-state .icon { font-size: 48px; margin-bottom: 16px; }
  .cart-pill { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); background: var(--ink); color: white; padding: 14px 28px; border-radius: 50px; font-weight: 600; font-size: 15px; cursor: pointer; box-shadow: 0 8px 32px rgba(0,0,0,0.25); display: none; align-items: center; gap: 12px; z-index: 90; transition: all 0.3s; white-space: nowrap; }
  .cart-pill.visible { display: flex; }
  .cart-pill-count { background: var(--orange); color: white; border-radius: 50%; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; }
  .drawer-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 200; opacity: 0; pointer-events: none; transition: opacity 0.25s; }
  .drawer-overlay.open { opacity: 1; pointer-events: all; }
  .cart-drawer { position: fixed; bottom: 0; left: 50%; transform: translateX(-50%) translateY(100%); width: 100%; max-width: 480px; background: white; border-radius: 24px 24px 0 0; z-index: 201; transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1); max-height: 85vh; overflow-y: auto; padding: 24px 20px 32px; }
  .cart-drawer.open { transform: translateX(-50%) translateY(0); }
  .drawer-handle { width: 40px; height: 4px; background: var(--border); border-radius: 2px; margin: 0 auto 20px; }
  .drawer-title { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800; margin-bottom: 16px; }
  .cart-item-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--border); }
  .cart-item-name { font-size: 14px; font-weight: 500; }
  .cart-item-price { font-size: 14px; color: var(--muted); }
  .cart-item-qty { display: flex; align-items: center; gap: 8px; }
  .cart-total-row { display: flex; justify-content: space-between; padding: 14px 0 4px; font-weight: 700; font-size: 16px; }
  .place-order-btn { width: 100%; padding: 16px; background: var(--orange); color: white; border: none; border-radius: 14px; font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700; cursor: pointer; margin-top: 12px; transition: all 0.2s; }
  .place-order-btn:active { transform: scale(0.99); }
  .place-order-btn.loading { opacity: 0.7; pointer-events: none; }
  .place-order-btn:disabled { cursor: not-allowed; }

  /* All other existing modals — kept as-is */
  .confirm-modal { position:fixed;inset:0;z-index:450;display:none; }
  .confirm-overlay { position:absolute;inset:0;background:rgba(0,0,0,0.55); }
  .confirm-panel { position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:white;border-radius:24px 24px 0 0;padding:24px 20px 32px;box-sizing:border-box;max-height:90vh;overflow-y:auto; }
  .confirm-title { font-family:'Syne',sans-serif;font-size:18px;font-weight:800;margin-bottom:4px; }
  .confirm-subtitle { font-size:13px;color:#9b8b72;margin-bottom:16px; }
  .confirm-items { border:1.5px solid #ede8df;border-radius:12px;overflow:hidden;margin-bottom:16px; }
  .confirm-item { display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border-bottom:1px solid #f5f0e8;font-size:14px; }
  .confirm-item:last-child { border-bottom:none; }
  .confirm-item-name { font-weight:600;flex:1; }
  .confirm-item-note { font-size:11px;color:#9b8b72;margin-top:2px; }
  .confirm-item-price { color:#ea580c;font-weight:700;margin-left:12px;white-space:nowrap; }
  .confirm-total { display:flex;justify-content:space-between;font-weight:800;font-size:16px;padding:12px 0;border-top:2px solid #1a1207;margin-top:4px; }
  .confirm-addr { font-size:12px;color:#9b8b72;background:#f9f6f0;border-radius:8px;padding:10px 12px;margin-bottom:16px; }
  .confirm-btns { display:flex;gap:10px; }
  .confirm-edit-btn { flex:1;padding:14px;border:1.5px solid #ede8df;border-radius:12px;background:white;font-size:14px;font-weight:600;cursor:pointer;color:#9b8b72; }
  .confirm-place-btn { flex:2;padding:14px;background:#ea580c;border:none;border-radius:12px;color:white;font-family:'Syne',sans-serif;font-size:15px;font-weight:800;cursor:pointer; }
  .notes-modal { position:fixed;inset:0;z-index:460;display:none; }
  .notes-overlay { position:absolute;inset:0;background:rgba(0,0,0,0.5); }
  .notes-panel { position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:white;border-radius:24px 24px 0 0;padding:24px 20px 32px;box-sizing:border-box; }
  .notes-title { font-family:'Syne',sans-serif;font-size:16px;font-weight:800;margin-bottom:4px; }
  .notes-item-name { font-size:13px;color:#9b8b72;margin-bottom:14px; }
  .notes-textarea { width:100%;border:1.5px solid #ede8df;border-radius:12px;padding:12px;font-family:'DM Sans',sans-serif;font-size:14px;resize:none;outline:none;box-sizing:border-box;height:100px; }
  .notes-textarea:focus { border-color:#ea580c; }
  .notes-hints { display:flex;flex-wrap:wrap;gap:8px;margin:10px 0 16px; }
  .notes-hint-chip { border:1.5px solid #ede8df;border-radius:20px;padding:6px 12px;font-size:12px;cursor:pointer;background:white;transition:all 0.15s; }
  .notes-hint-chip:active { border-color:#ea580c;color:#ea580c; }
  .note-btn { background:none;border:none;font-size:15px;cursor:pointer;padding:2px 4px;opacity:0.5;margin-left:4px; }
  .note-btn:active { opacity:1; }
  .notes-save-btn { width:100%;padding:14px;background:#1a1207;border:none;border-radius:12px;color:white;font-family:'Syne',sans-serif;font-size:15px;font-weight:800;cursor:pointer; }
  .lang-btn { background: rgba(255,255,255,0.12); border: 1.5px solid rgba(255,255,255,0.2); border-radius: 20px; padding: 5px 10px; font-size: 13px; color: white; cursor: pointer; display: flex; align-items: center; gap: 5px; transition: all 0.2s; }
  .lang-btn:active { background: rgba(255,255,255,0.25); }
  .lang-drawer { position: fixed; inset: 0; z-index: 500; display: none; }
  .lang-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.5); }
  .lang-panel { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 100%; max-width: 480px; background: white; border-radius: 24px 24px 0 0; padding: 24px 20px 32px; box-sizing: border-box; }
  .lang-title { font-family: 'Syne', sans-serif; font-size: 17px; font-weight: 800; margin-bottom: 16px; text-align: center; }
  .lang-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .lang-option { padding: 14px 12px; border: 2px solid #ede8df; border-radius: 12px; cursor: pointer; display: flex; align-items: center; gap: 10px; font-size: 14px; font-weight: 600; transition: all 0.15s; background: white; }
  .lang-option:active { transform: scale(0.97); }
  .lang-option.selected { border-color: #ea580c; background: #fff7f0; color: #ea580c; }
  .lang-option .flag { font-size: 22px; }
  .lang-option .label { display: flex; flex-direction: column; }
  .lang-option .native { font-size: 12px; color: #9b8b72; font-weight: 400; margin-top: 1px; }
  .lang-option.selected .native { color: #ea580c; opacity: 0.7; }
  .popular-chip { flex-shrink: 0; background: white; border: 1.5px solid #ede8df; border-radius: 12px; padding: 10px 12px; cursor: pointer; transition: all 0.15s; min-width: 120px; max-width: 150px; }
  .popular-chip:active { border-color: #ea580c; transform: scale(0.97); }
  .popular-chip-name { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .popular-chip-price { font-size: 12px; color: #ea580c; font-weight: 700; margin-top: 2px; }
  .popular-chip-add { font-size: 11px; color: #9b8b72; margin-top: 4px; }
  .address-section { display: none; padding: 12px 0 8px; }
  .address-label { font-size: 12px; font-weight: 600; color: #666; margin-bottom: 8px; text-transform: uppercase; letter-spacing: .5px; }
  .past-addr-chip { padding: 8px 12px; background: #f5f5f5; border-radius: 8px; margin-bottom: 4px; font-size: 13px; cursor: pointer; border: 1.5px solid transparent; transition: all .15s; }
  .past-addr-chip.selected { border-color: var(--orange); background: #fff5ef; }
  .address-textarea { width: 100%; min-height: 72px; border: 1.5px solid var(--border); border-radius: 10px; padding: 10px 12px; font-size: 14px; font-family: inherit; resize: none; background: #faf8f5; box-sizing: border-box; outline: none; }
  .address-hint { font-size: 11px; color: #e53e3e; margin-top: 4px; display: none; }
  .toast { position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--ink); color: white; padding: 10px 20px; border-radius: 50px; font-size: 13px; font-weight: 500; opacity: 0; pointer-events: none; transition: all 0.3s; z-index: 999; white-space: nowrap; }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  @keyframes bounce { 0%,60%,100% { transform: translateY(0); } 30% { transform: translateY(-6px); } }
  /* Chatbot hidden */
  #aiPanel,#aiOverlay,.ai-fab,.ai-toggle{display:none!important}
</style>
</head>
<body>

<div class="header">
  <div class="header-top">
    <span class="restaurant-name" id="restName">Loading…</span>
    <div style="display:flex;align-items:center;gap:8px">
      <button class="lang-btn" onclick="openLangDrawer()" id="langBtn">🌐 EN</button>
      <span class="mode-badge" id="modeBadge">—</span>
    </div>
  </div>
  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input class="search-input" id="searchInput" placeholder="Search menu…" autocomplete="off">
  </div>
</div>

<!-- Filter Chips -->
<div class="filter-chips-wrap" id="filterChips" style="display:none">
  <div class="filter-chip" data-filter="all" onclick="applyFilter('all',this)">All</div>
  <div class="filter-chip" data-filter="veg" onclick="applyFilter('veg',this)">🟢 Veg Only</div>
  <div class="filter-chip" data-filter="nonveg" onclick="applyFilter('nonveg',this)">🔴 Non-Veg</div>
  <div class="filter-chip" data-filter="mild" onclick="applyFilter('mild',this)">😊 Mild</div>
  <div class="filter-chip" data-filter="spicy" onclick="applyFilter('spicy',this)">🌶 Spicy</div>
  <div class="filter-chip" data-filter="popular" onclick="applyFilter('popular',this)">⭐ Popular</div>
</div>

<div class="cat-tabs" id="catTabs"></div>
<div id="popularSection" style="display:none;padding:14px 16px 0">
  <div style="font-family:Syne,sans-serif;font-size:13px;font-weight:700;color:#9b8b72;text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">🔥 Popular</div>
  <div id="popularItems" style="display:flex;gap:10px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none"></div>
</div>
<div class="menu-section" id="menuContent">
  <div class="empty-state"><div class="icon">🍔</div><p>Loading menu…</p></div>
</div>

<div class="cart-pill" id="cartPill" onclick="openCart()">
  <div class="cart-pill-count" id="cartCount">0</div>
  <span id="cartPillText">View Cart</span>
  <span id="cartPillTotal"></span>
</div>

<div class="drawer-overlay" id="drawerOverlay" onclick="closeCart()"></div>
<div class="cart-drawer" id="cartDrawer">
  <div class="drawer-handle"></div>
  <div class="drawer-title">🛒 Your Cart</div>
  <div id="cartItems"></div>
  <div class="cart-total-row" id="cartTotalRow" style="display:none">
    <span>Total</span><span id="cartTotal">₹0</span>
  </div>
  <div class="address-section" id="addressSection">
    <div class="address-label">📍 Delivery Address</div>
    <div id="pastAddresses"></div>
    <textarea class="address-textarea" id="deliveryAddress" placeholder="Enter your full delivery address…" oninput="onAddressInput()" onblur="if(this.value.trim())this.style.borderColor='#22c55e';else this.style.borderColor='var(--border)'"></textarea>
    <div class="address-hint" id="addressHint">⚠️ Please enter delivery address</div>
  </div>
  <button class="place-order-btn" id="placeOrderBtn" onclick="startUpsell()">Place Order →</button>
</div>

<!-- Order Confirmation Modal -->
<div class="confirm-modal" id="confirmModal">
  <div class="confirm-overlay" onclick="closeConfirm()"></div>
  <div class="confirm-panel">
    <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 20px"></div>
    <div class="confirm-title">✅ Confirm Order</div>
    <div class="confirm-subtitle" id="confirmSubtitle">Review your order before placing</div>
    <div class="confirm-items" id="confirmItems"></div>
    <div class="confirm-total"><span>Total</span><span id="confirmTotal">₹0</span></div>
    <div class="confirm-addr" id="confirmAddr" style="display:none"></div>
    <div class="confirm-btns" style="flex-direction:column;gap:10px">
      <button class="confirm-place-btn" id="confirmPlaceBtn" onclick="confirmAndPlace()">✅ Place Order →</button>
      <div style="display:flex;gap:10px">
        <button class="confirm-edit-btn" style="flex:1" onclick="closeConfirmOpenCart()">✏️ Edit Cart</button>
        <button class="confirm-edit-btn" style="flex:1" onclick="closeConfirm()">+ Add More</button>
      </div>
    </div>
  </div>
</div>

<!-- Notes Modal -->
<div class="notes-modal" id="notesModal">
  <div class="notes-overlay" onclick="closeNotes()"></div>
  <div class="notes-panel">
    <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 20px"></div>
    <div class="notes-title">📝 Special Instructions</div>
    <div class="notes-item-name" id="notesItemName"></div>
    <textarea class="notes-textarea" id="notesTextarea" placeholder="e.g. Extra spicy, no onions, less oil…"></textarea>
    <div class="notes-hints">
      <button class="notes-hint-chip" onclick="addNoteHint('Extra spicy')">🌶️ Extra spicy</button>
      <button class="notes-hint-chip" onclick="addNoteHint('No onions')">🧅 No onions</button>
      <button class="notes-hint-chip" onclick="addNoteHint('Less oil')">Less oil</button>
      <button class="notes-hint-chip" onclick="addNoteHint('No garlic')">No garlic</button>
      <button class="notes-hint-chip" onclick="addNoteHint('Well done')">Well done</button>
      <button class="notes-hint-chip" onclick="addNoteHint('Extra sauce')">Extra sauce</button>
    </div>
    <button class="notes-save-btn" onclick="saveNotes()">Save</button>
  </div>
</div>

<!-- Language Drawer -->
<div class="lang-drawer" id="langDrawer">
  <div class="lang-overlay" onclick="closeLangDrawer()"></div>
  <div class="lang-panel">
    <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 20px"></div>
    <div class="lang-title">🌐 Choose Language</div>
    <div class="lang-grid" id="langGrid"></div>
  </div>
</div>

<!-- Upsell Modal -->
<div id="upsellOverlay" style="position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:400;opacity:0;pointer-events:none;transition:opacity 0.25s"></div>
<div id="upsellModal" style="position:fixed;bottom:0;left:50%;transform:translateX(-50%) translateY(100%);width:100%;max-width:480px;background:white;border-radius:24px 24px 0 0;z-index:401;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);padding:24px 20px 32px;box-sizing:border-box">
  <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 20px"></div>
  <div style="font-family:'Syne',sans-serif;font-size:17px;font-weight:800;margin-bottom:4px">🔥 Wait — you might like this!</div>
  <div id="upsellMsg" style="font-size:14px;color:#9b8b72;margin-bottom:16px;line-height:1.5">Finding the perfect add-on…</div>
  <div id="upsellItem" style="display:none;background:#fdf6e9;border:1.5px solid #f59e0b;border-radius:14px;padding:16px;margin-bottom:16px">
    <div style="display:flex;justify-content:space-between;align-items:center;gap:12px">
      <div style="flex:1">
        <div id="upsellItemName" style="font-weight:700;font-size:16px;margin-bottom:3px"></div>
        <div id="upsellItemPrice" style="color:#ea580c;font-weight:700;font-size:14px"></div>
      </div>
      <button onclick="addUpsellItem()" style="background:#ea580c;color:white;border:none;border-radius:20px;padding:10px 20px;font-weight:700;font-size:14px;cursor:pointer;white-space:nowrap;flex-shrink:0">＋ Add</button>
    </div>
  </div>
  <div id="upsellLoading" style="text-align:center;padding:16px;color:#9b8b72;font-size:13px"><div style="margin-bottom:6px">🤔</div>Checking what pairs well…</div>
  <div style="display:flex;gap:10px;margin-top:8px">
    <button onclick="skipUpsell()" style="flex:1;padding:14px;border:1.5px solid #ede8df;border-radius:12px;background:white;font-size:14px;font-weight:600;cursor:pointer;color:#9b8b72">Skip</button>
    <button onclick="confirmAfterUpsell()" style="flex:2;padding:14px;background:#1a1207;border:none;border-radius:12px;color:white;font-family:'Syne',sans-serif;font-size:15px;font-weight:800;cursor:pointer">Place Order →</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const SESSION_ID = (location.pathname.split('/order/')[1] || '').split('?')[0];
const API_BASE   = '';

let restaurant   = null;
let allModifiers = [];
let pendingAddItem = null;
let categories   = [];
let allItems     = [];
let cart         = {};
let sessionMode  = 'delivery';
let activeFilter = 'all';  // current filter chip
let openInfoId   = null;   // currently open info panel item id

// ══════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════
async function init() {
  if (!SESSION_ID) {
    document.getElementById('menuContent').innerHTML =
      '<div class="empty-state"><div class="icon">🔗</div><p>Invalid link. Please scan the QR code again.</p></div>';
    return;
  }
  try {
    const [sessionRes, menuRes] = await Promise.all([
      fetch(API_BASE + '/api/order-ui/session/' + SESSION_ID),
      fetch(API_BASE + '/api/order-ui/menu/' + SESSION_ID + '?lang=' + (localStorage.getItem('buddy_lang') || 'en'))
    ]);
    if (!sessionRes.ok) throw new Error('Session not found');
    const sessionData = await sessionRes.json();

    if (['closed','paid','delivered'].includes(sessionData.status)) {
      document.getElementById('menuContent').innerHTML =
        '<div class="empty-state" style="padding:60px 24px">' +
        '<div class="icon">🔗</div>' +
        '<h3 style="font-family:Syne,sans-serif;font-size:18px;margin-bottom:8px">Link Expired</h3>' +
        '<p>This order session has ended.</p>' +
        '<p>Please <strong>scan the QR code again</strong> to start a new order.</p>' +
        '</div>';
      document.getElementById('catTabs').style.display = 'none';
      document.getElementById('restName').textContent = sessionData.restaurant_name || 'Restaurant';
      return;
    }

    const menuData = await menuRes.json();
    restaurant = menuData.restaurant;
    categories = menuData.categories;
    allItems   = menuData.items;

    document.getElementById('restName').textContent = restaurant.name;
    document.title = 'Order — ' + restaurant.name;

    sessionMode = sessionData.mode || 'delivery';
    const modeEl = document.getElementById('modeBadge');
    if (sessionMode === 'dine_in') {
      modeEl.textContent = 'Table ' + (sessionData.table_number || '—');
      modeEl.className = 'mode-badge dine';
    } else if (sessionMode === 'takeaway') {
      modeEl.textContent = 'Takeaway';
      modeEl.className = 'mode-badge takeaway';
    } else {
      modeEl.textContent = 'Delivery';
      modeEl.className = 'mode-badge';
      document.getElementById('addressSection').style.display = 'block';
      document.getElementById('placeOrderBtn').disabled = true;
      document.getElementById('placeOrderBtn').style.opacity = '0.5';
      loadPastAddresses();
    }

    if (sessionData.status === 'ordered' && sessionMode !== 'dine_in') {
      const cartRes2  = await fetch(API_BASE + '/api/order-ui/cart/' + SESSION_ID);
      const cartData2 = await cartRes2.json();
      if (cartData2.items) {
        cartData2.items.forEach(function(item) {
          cart[item.menu_item_id] = { qty: item.quantity, notes: item.notes || '', name: item.name, price: item.price };
        });
      }
      allModifiers = menuData.modifiers || [];
      buildFilterChips();
      buildCategoryTabs();
      renderMenu();
      renderPopular();
      updateCartUI();
      lockUI('');
      return;
    }

    const cartRes = await fetch(API_BASE + '/api/order-ui/cart/' + SESSION_ID);
    const cartData = await cartRes.json();
    if (cartData.items) {
      cartData.items.forEach(function(item) {
        cart[item.menu_item_id] = { qty: item.quantity, notes: item.notes || '', name: item.name, price: item.price };
      });
    }

    allModifiers = menuData.modifiers || [];
    buildFilterChips();
    buildCategoryTabs();
    renderMenu();
    renderPopular();
    updateCartUI();

    document.getElementById('searchInput').addEventListener('input', function(e) {
      activeFilter = 'all';
      document.querySelectorAll('.filter-chip').forEach(function(c) { c.classList.remove('active'); });
      document.querySelector('.filter-chip[data-filter="all"]').classList.add('active');
      renderMenu(e.target.value.toLowerCase().trim());
    });

  } catch (err) {
    console.error(err);
    document.getElementById('menuContent').innerHTML =
      '<div class="empty-state"><div class="icon">😕</div><p>Could not load menu. Please try again.</p></div>';
  }
}

// ══════════════════════════════════════════════
// FILTER CHIPS
// ══════════════════════════════════════════════
function buildFilterChips() {
  // Show filter chips only if we have enough items to make filtering useful
  if (allItems.length < 4) return;

  // Check what data exists to show relevant chips
  const hasVeg    = allItems.some(function(i) { return i.is_veg === true; });
  const hasNonveg = allItems.some(function(i) { return i.is_veg === false; });
  const hasMild   = allItems.some(function(i) { return i.spice_level === 'mild'; });
  const hasSpicy  = allItems.some(function(i) { return i.spice_level === 'spicy' || i.spice_level === 'hot'; });
  const hasPopular = allItems.some(function(i) {
    return i.tags && i.tags.some(function(t) { return t.tag_code === 'popular'; });
  });

  var chips = document.getElementById('filterChips');
  var html = '<div class="filter-chip active" data-filter="all" onclick="applyFilter(\'all\',this)">All</div>';
  if (hasVeg)     html += '<div class="filter-chip" data-filter="veg" onclick="applyFilter(\'veg\',this)">🟢 Veg Only</div>';
  if (hasNonveg)  html += '<div class="filter-chip" data-filter="nonveg" onclick="applyFilter(\'nonveg\',this)">🔴 Non-Veg</div>';
  if (hasMild)    html += '<div class="filter-chip" data-filter="mild" onclick="applyFilter(\'mild\',this)">😊 Mild</div>';
  if (hasSpicy)   html += '<div class="filter-chip" data-filter="spicy" onclick="applyFilter(\'spicy\',this)">🌶 Spicy</div>';
  if (hasPopular) html += '<div class="filter-chip" data-filter="popular" onclick="applyFilter(\'popular\',this)">⭐ Popular</div>';

  chips.innerHTML = html;
  chips.style.display = 'flex';
}

function applyFilter(filter, el) {
  activeFilter = filter;
  document.querySelectorAll('.filter-chip').forEach(function(c) { c.classList.remove('active'); });
  el.classList.add('active');
  document.getElementById('searchInput').value = '';
  closeAnyOpenInfoPanel();
  renderMenu();
}

// ══════════════════════════════════════════════
// CATEGORY TABS
// ══════════════════════════════════════════════
function isAddonCategory(cat) {
  var n = (cat.name || '').toLowerCase();
  return n.includes('add-on') || n.includes('addon') || n.includes('add on') || n.includes('extras');
}

function buildCategoryTabs() {
  const tabs = document.getElementById('catTabs');
  var visibleCats = categories.filter(function(cat) { return !isAddonCategory(cat); });
  tabs.innerHTML = visibleCats.map(function(cat, i) {
    return '<div class="cat-tab' + (i === 0 ? ' active' : '') + '" data-cat="' + cat.id + '" onclick="selectCat(\'' + cat.id + '\',this)">' + cat.name + '</div>';
  }).join('');
  activeCat = visibleCats[0] ? visibleCats[0].id : null;
}

var activeCat = null;
function selectCat(catId, el) {
  document.querySelectorAll('.cat-tab').forEach(function(t) { t.classList.remove('active'); });
  el.classList.add('active');
  activeCat = catId;
  activeFilter = 'all';
  document.querySelectorAll('.filter-chip').forEach(function(c) { c.classList.remove('active'); });
  var allChip = document.querySelector('.filter-chip[data-filter="all"]');
  if (allChip) allChip.classList.add('active');
  closeAnyOpenInfoPanel();
  renderMenu();
}

// ══════════════════════════════════════════════
// RENDER MENU
// ══════════════════════════════════════════════
function getFilteredItems(search) {
  // Get add-on category IDs to exclude from main menu
  var addonCatIds = categories.filter(isAddonCategory).map(function(c) { return c.id; });

  var items = allItems.filter(function(i) {
    return addonCatIds.indexOf(i.category_id) === -1;
  });

  // Search takes priority
  if (search) {
    return items.filter(function(i) {
      return i.name.toLowerCase().includes(search) || (i.description || '').toLowerCase().includes(search);
    });
  }

  // Category filter
  if (activeCat) {
    items = items.filter(function(i) { return i.category_id === activeCat; });
  }

  // Chip filter
  switch(activeFilter) {
    case 'veg':
      items = items.filter(function(i) { return i.is_veg === true; });
      break;
    case 'nonveg':
      items = items.filter(function(i) { return i.is_veg === false; });
      break;
    case 'mild':
      items = items.filter(function(i) { return i.spice_level === 'mild'; });
      break;
    case 'spicy':
      items = items.filter(function(i) { return i.spice_level === 'spicy' || i.spice_level === 'hot'; });
      break;
    case 'popular':
      items = items.filter(function(i) {
        return i.tags && i.tags.some(function(t) { return t.tag_code === 'popular'; });
      });
      break;
  }
  return items;
}

function spiceBadge(level) {
  if (!level || level === 'none') return '';
  if (level === 'mild')   return '<span class="item-badge spice">😊 Mild</span>';
  if (level === 'medium') return '<span class="item-badge spice">🌶 Medium</span>';
  if (level === 'spicy' || level === 'hot') return '<span class="item-badge spice">🌶🌶 Spicy</span>';
  return '';
}

function labelBadges(tags) {
  if (!tags || !tags.length) return '';
  return tags.filter(function(t) { return t.type === 'LABEL'; }).map(function(t) {
    if (t.tag_code === 'popular')    return '<span class="item-badge popular">⭐ Popular</span>';
    if (t.tag_code === 'chef_special') return '<span class="item-badge chef">👨‍🍳 Chef Special</span>';
    return '';
  }).join('');
}

function renderMenu(search) {
  const container = document.getElementById('menuContent');
  const items = getFilteredItems(search);

  if (!items.length) {
    var filterMsg = activeFilter !== 'all'
      ? '<p style="margin-top:8px;font-size:13px">Try a different filter</p>'
      : '';
    container.innerHTML = '<div class="empty-state"><div class="icon">🔍</div><p>No items found</p>' + filterMsg + '</div>';
    return;
  }

  container.innerHTML = items.map(function(item) {
    var inCart  = cart[item.id];
    var vegDot  = item.is_veg !== null && item.is_veg !== undefined
      ? '<span class="veg-dot ' + (item.is_veg ? 'veg' : 'nonveg') + '"></span>'
      : '';
    var imgHtml = item.image_url
      ? '<img class="item-img" src="' + item.image_url + '" alt="' + item.name + '" onerror="this.style.display=\'none\'">'
      : '';
    var spice  = spiceBadge(item.spice_level);
    var labels = labelBadges(item.tags || []);
    var badges = spice + labels;

    var qtyHtml = inCart
      ? '<div class="qty-control">' +
        '<button class="qty-btn minus" onclick="changeQty(\'' + item.id + '\',\'' + item.name.replace(/'/g, "\\'") + '\',' + item.price + ',-1)">−</button>' +
        '<span class="qty-num" id="qty_' + item.id + '">' + inCart.qty + '</span>' +
        '<button class="qty-btn plus" onclick="changeQty(\'' + item.id + '\',\'' + item.name.replace(/'/g, "\\'") + '\',' + item.price + ',1)">+</button>' +
        '<button class="note-btn" onclick="openNotes(\'' + item.id + '\')" title="Special instructions">📝</button>' +
        '</div>'
      : '<button class="add-btn" id="addbtn_' + item.id + '" onclick="addItem(\'' + item.id + '\',\'' + item.name.replace(/'/g, "\\'") + '\',' + item.price + ')">Add</button>';

    var infoPanelId = 'info_' + item.id;
    var isOpen = openInfoId === item.id;

    return '<div class="item-card' + (inCart ? ' in-cart' : '') + '" id="card_' + item.id + '">' +
      '<div class="item-card-top">' +
      '<div class="item-info">' +
      '<div class="item-name">' + vegDot + item.name + '</div>' +
      (badges ? '<div class="item-badges">' + badges + '</div>' : '') +
      /* description shown in info panel only — not duplicated on card */ +
      '<div class="item-footer">' +
      '<span class="item-price">₹' + item.price + '</span>' +
      '<div style="display:flex;align-items:center">' +
      qtyHtml +
      '<button class="info-btn' + (isOpen ? ' open' : '') + '" id="infobtn_' + item.id + '" onclick="toggleInfoPanel(\'' + item.id + '\')" title="Item info">ℹ️</button>' +
      '</div>' +
      '</div></div>' +
      imgHtml +
      '</div>' +
      '<div class="info-panel' + (isOpen ? ' open' : '') + '" id="' + infoPanelId + '">' +
      '<div class="info-panel-inner" id="infocontent_' + item.id + '">' +
      (isOpen ? renderInfoPanelContent(item) : '<div style="text-align:center;padding:12px;color:#9b8b72;font-size:13px">Loading…</div>') +
      '</div></div>' +
      '</div>';
  }).join('');
}

// ══════════════════════════════════════════════
// INFO PANEL
// ══════════════════════════════════════════════
function closeAnyOpenInfoPanel() {
  if (!openInfoId) return;
  var panel = document.getElementById('info_' + openInfoId);
  var btn   = document.getElementById('infobtn_' + openInfoId);
  if (panel) panel.classList.remove('open');
  if (btn)   btn.classList.remove('open');
  openInfoId = null;
}

async function toggleInfoPanel(itemId) {
  // If same panel is open — close it
  if (openInfoId === itemId) {
    closeAnyOpenInfoPanel();
    return;
  }

  // Close any previously open panel
  closeAnyOpenInfoPanel();

  // Open new panel
  openInfoId = itemId;
  var panel = document.getElementById('info_' + itemId);
  var btn   = document.getElementById('infobtn_' + itemId);
  if (!panel || !btn) return;

  btn.classList.add('open');
  panel.classList.add('open');

  // Check if we already have rich data for this item
  var item = allItems.find(function(i) { return i.id === itemId; });

  // Try to fetch from info endpoint first (has tags, allergens, etc.)
  try {
    var res  = await fetch(API_BASE + '/api/order-ui/menu/items/' + itemId + '/info?lang=' + (selectedLang || 'en'));
    if (res.ok) {
      var data = await res.json();
      var content = document.getElementById('infocontent_' + itemId);
      if (content) content.innerHTML = buildInfoPanelHTML(data);
      return;
    }
  } catch(e) { /* fall through to basic display */ }

  // Fallback to basic item data if endpoint fails
  var content = document.getElementById('infocontent_' + itemId);
  if (content && item) content.innerHTML = renderInfoPanelContent(item);
}

function renderInfoPanelContent(item) {
  // Basic fallback using data already in allItems
  var lines = [];
  if (item.description) {
    lines.push('<div class="info-section-title">About</div>');
    lines.push('<div class="info-val" style="font-size:13px;line-height:1.5;margin-bottom:8px">' + item.description + '</div>');
  }
  if (item.spice_level && item.spice_level !== 'none') {
    var spiceMap = { mild: '😊 Mild', medium: '🌶 Medium', spicy: '🌶🌶 Spicy', hot: '🌶🌶 Spicy' };
    lines.push('<div class="info-row"><span class="info-label">Spice</span><span class="info-val">' + (spiceMap[item.spice_level] || item.spice_level) + '</span></div>');
  }
  if (!lines.length) {
    lines.push('<div style="text-align:center;padding:8px;color:#9b8b72;font-size:13px">Full details not available.<br>Ask our staff.</div>');
  }
  return lines.join('');
}

function buildInfoPanelHTML(data) {
  var html = '';

  // Bestseller badge
  if (data.bestseller_badge) {
    html += '<div class="info-bestseller">' + data.bestseller_badge.label + '</div>';
  }

  // Diet + spice tags row
  var topTags = [];
  if (data.tags.diet && data.tags.diet.length) {
    data.tags.diet.forEach(function(t) { topTags.push('<span class="info-tag diet">' + t.display_icon + ' ' + t.tag_name + '</span>'); });
  }
  if (data.tags.spice && data.tags.spice.length) {
    data.tags.spice.forEach(function(t) { topTags.push('<span class="info-tag spice">' + t.display_icon + ' ' + t.tag_name + '</span>'); });
  } else if (data.spice_level && data.spice_level !== 'none') {
    var spiceMap = { mild: '😊 Mild', medium: '🌶 Medium', spicy: '🌶🌶 Spicy', hot: '🌶🌶 Spicy' };
    topTags.push('<span class="info-tag spice">' + spiceMap[data.spice_level] + '</span>');
  }
  if (topTags.length) html += '<div class="info-tag-row">' + topTags.join('') + '</div>';

  // Cuisine
  if (data.cuisine_type) {
    var cuisineEmoji = { indian:'🍛', chinese:'🥢', italian:'🍝', continental:'🍽', mughlai:'🫕', mexican:'🌮', thai:'🍜', mediterranean:'🥙' };
    html += '<div class="info-row"><span class="info-label">Cuisine</span><span class="info-val">' + (cuisineEmoji[data.cuisine_type] || '') + ' ' + data.cuisine_type.charAt(0).toUpperCase() + data.cuisine_type.slice(1) + '</span></div>';
  }

  // Description
  if (data.description) {
    html += '<div class="info-section-title">About</div>';
    html += '<div class="info-val" style="font-size:13px;line-height:1.5;margin-bottom:8px">';
    if (data.safe_tone) html += '<span style="color:#9b8b72;font-style:italic">Based on available information: </span>';
    html += data.description + '</div>';
  } else {
    html += '<div class="info-section-title">About</div>';
    html += '<div style="color:#9b8b72;font-size:13px;margin-bottom:8px">Description not available for this item.</div>';
  }

  // Label tags
  if (data.tags.label && data.tags.label.length) {
    html += '<div class="info-tag-row">';
    data.tags.label.forEach(function(t) { html += '<span class="info-tag label">' + t.display_icon + ' ' + t.tag_name + '</span>'; });
    html += '</div>';
  }

  // Flavor
  if (data.tags.flavor && data.tags.flavor.length) {
    html += '<div class="info-section-title">Flavor</div><div class="info-tag-row">';
    data.tags.flavor.forEach(function(t) { html += '<span class="info-tag flavor">' + t.display_icon + ' ' + t.tag_name + '</span>'; });
    html += '</div>';
  }

  // Experience
  if (data.tags.experience && data.tags.experience.length) {
    html += '<div class="info-section-title">Experience</div><div class="info-tag-row">';
    data.tags.experience.forEach(function(t) { html += '<span class="info-tag experience">' + t.display_icon + ' ' + t.tag_name + '</span>'; });
    html += '</div>';
  }

  // Ingredients
  if (data.ingredients_text) {
    html += '<div class="info-section-title">Ingredients</div>';
    html += '<div class="info-val" style="font-size:13px;line-height:1.5;margin-bottom:8px">' + data.ingredients_text + '</div>';
  }

  // Restrictions (only if tags exist)
  if (data.tags.restriction && data.tags.restriction.length) {
    html += '<div class="info-section-title">Restrictions</div><div class="info-tag-row">';
    data.tags.restriction.forEach(function(t) { html += '<span class="info-tag restriction">' + t.display_icon + ' ' + t.tag_name + '</span>'; });
    html += '</div>';
  }

  // Allergens (only if tags exist)
  if (data.tags.allergen && data.tags.allergen.length) {
    html += '<div class="info-section-title">Allergens</div><div class="info-tag-row">';
    data.tags.allergen.forEach(function(t) { html += '<span class="info-tag allergen">⚠️ ' + t.tag_name + '</span>'; });
    html += '</div>';
    html += '<div class="info-warn">⚠️ Allergen info depends on what the restaurant has confirmed. Please check with staff for allergy concerns.</div>';
  }

  // Bar info
  if (data.is_alcoholic) {
    html += '<div class="info-section-title">Bar Info</div>';
    html += '<div class="info-row"><span class="info-label">Contains</span><span class="info-val">🍸 Alcohol</span></div>';
    if (data.tags.drink_style && data.tags.drink_style.length) {
      html += '<div class="info-tag-row">';
      data.tags.drink_style.forEach(function(t) { html += '<span class="info-tag drink">' + t.display_icon + ' ' + t.tag_name + '</span>'; });
      html += '</div>';
    }
  }

  // Minimum fallback if everything is null
  if (!html.trim()) {
    html = '<div style="text-align:center;padding:8px;color:#9b8b72;font-size:13px">' +
      (data.category ? data.category + '<br>' : '') +
      'Full details not available. Ask our staff.</div>';
  }

  return html;
}

// ══════════════════════════════════════════════
// CART OPERATIONS (unchanged from original)
// ══════════════════════════════════════════════
function addItem(itemId, name, price) {
  var menuItem = allItems.find(function(i) { return i.id === itemId; });
  var catId = menuItem ? menuItem.category_id : '';
  var applicable = allModifiers.filter(function(m) {
    var catMatch  = m.applicable_categories && m.applicable_categories.some(function(c) { return c === catId; });
    var itemMatch = m.applicable_item_ids && m.applicable_item_ids.length > 0 && m.applicable_item_ids.includes(itemId);
    return catMatch || itemMatch;
  });
  if (applicable.length > 0) {
    openModifierModal(itemId, name, price, applicable);
  } else {
    addItemDirect(itemId, name, price, []);
  }
}

function addItemDirect(itemId, name, price, modifiers) {
  var modsTotal = modifiers.reduce(function(s,m) { return s+(m.price||0); }, 0);
  var unitPrice = price + modsTotal;
  var newQty    = cart[itemId] ? cart[itemId].qty + 1 : 1;
  cart[itemId]  = { qty: newQty, notes: cart[itemId] ? cart[itemId].notes : '', name: name, price: unitPrice, modifiers: modifiers };
  renderMenu();
  updateCartUI();
  syncCartItem(itemId, newQty, modifiers);
  var modText = modifiers.length ? ' + ' + modifiers.map(function(m) { return m.name; }).join(', ') : '';
  showToast('✅ ' + name + modText + ' added!');
}

function openModifierModal(itemId, name, price, mods) {
  pendingAddItem = { itemId, name, price };
  document.getElementById('modItemName').textContent = name;
  document.getElementById('modItemPrice').textContent = '₹' + price;
  document.getElementById('modTotal').textContent = price;
  var html = '';
  mods.forEach(function(mod) {
    html += '<div style="display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid #f0ebe3">' +
      '<div style="display:flex;align-items:center;gap:10px">' +
      '<input type="checkbox" id="mod_' + mod.id + '" style="width:20px;height:20px;accent-color:#ea580c;cursor:pointer" ' +
      'onchange="updateModTotal(' + price + ')" data-name="' + mod.name + '" data-price="' + mod.price + '">' +
      '<label for="mod_' + mod.id + '" style="font-size:14px;font-weight:600;cursor:pointer">' + mod.name + '</label>' +
      '</div><span style="color:#ea580c;font-weight:700;font-size:13px">+₹' + mod.price + '</span></div>';
  });
  document.getElementById('modOptions').innerHTML = html;
  document.getElementById('modifierModal').style.display = 'block';
}

function updateModTotal(base) {
  var total = base;
  document.querySelectorAll('[id^="mod_"]:checked').forEach(function(cb) { total += parseInt(cb.dataset.price||0); });
  document.getElementById('modTotal').textContent = total;
}

function confirmModifiers() {
  if (!pendingAddItem) return;
  var item = pendingAddItem;
  var selected = [];
  document.querySelectorAll('[id^="mod_"]:checked').forEach(function(cb) {
    selected.push({ id: cb.id.replace('mod_',''), name: cb.dataset.name, price: parseInt(cb.dataset.price||0) });
  });
  closeModifierModal();
  addItemDirect(item.itemId, item.name, item.price, selected);
}

function skipModifiers() {
  if (!pendingAddItem) return;
  var item = pendingAddItem;
  closeModifierModal();
  addItemDirect(item.itemId, item.name, item.price, []);
}

function closeModifierModal() {
  document.getElementById('modifierModal').style.display = 'none';
  pendingAddItem = null;
}

function changeQty(itemId, name, price, delta) {
  var cur    = cart[itemId] ? cart[itemId].qty : 0;
  var newQty = cur + delta;
  if (newQty <= 0) { delete cart[itemId]; }
  else { cart[itemId] = { qty: newQty, notes: cart[itemId] ? cart[itemId].notes : '', name, price }; }
  var qEl = document.getElementById('qty_' + itemId);
  if (qEl) qEl.textContent = newQty > 0 ? newQty : 0;
  var card = document.getElementById('card_' + itemId);
  if (card) { if (newQty <= 0) card.classList.remove('in-cart'); else card.classList.add('in-cart'); }
  updateCartUI();
  syncCartItem(itemId, newQty < 0 ? 0 : newQty);
}

function updateCartUI() {
  var items = Object.entries(cart);
  var count = items.reduce(function(s,e) { return s+e[1].qty; }, 0);
  var total = items.reduce(function(s,e) { return s+e[1].price*e[1].qty; }, 0);
  var pill  = document.getElementById('cartPill');
  document.getElementById('cartCount').textContent = count;
  document.getElementById('cartPillText').textContent = count === 1 ? '1 item' : count + ' items';
  document.getElementById('cartPillTotal').textContent = count > 0 ? ' — ₹' + total : '';
  if (count > 0) pill.classList.add('visible'); else pill.classList.remove('visible');
}

async function syncCartItem(itemId, qty, modifiers) {
  if (!SESSION_ID) return;
  var item = cart[itemId];
  try {
    var res = await fetch(API_BASE + '/api/order-ui/cart-item/' + SESSION_ID, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        menu_item_id: itemId,
        quantity: qty || 0,
        name:  item ? item.name  : '',
        price: item ? item.price : 0,
        notes: item ? item.notes : null,
        modifiers: modifiers || (item ? item.modifiers : [])
      })
    });
    if (res.status === 409) lockCartAfterOrder();
  } catch(e) { console.error('syncCartItem failed', e); }
}

function lockCartAfterOrder() {
  document.querySelectorAll('.qty-btn, .add-btn, .place-order-btn').forEach(function(btn) {
    btn.disabled = true; btn.style.opacity = '0.4'; btn.style.cursor = 'not-allowed';
  });
  var btn = document.getElementById('placeOrderBtn');
  if (btn) { btn.textContent = '✅ Order Placed'; btn.style.background = '#22c55e'; btn.disabled = true; }
  showToast('✅ Order placed — cart is locked');
}

// ══════════════════════════════════════════════
// ADDRESS
// ══════════════════════════════════════════════
function onAddressInput() {
  var val = document.getElementById('deliveryAddress').value.trim();
  var btn = document.getElementById('placeOrderBtn');
  if (val.length > 5) {
    btn.disabled = false; btn.style.opacity = '1';
    document.getElementById('addressHint').style.display = 'none';
    document.getElementById('deliveryAddress').style.borderColor = '#22c55e';
  } else { btn.disabled = true; btn.style.opacity = '0.5'; }
}

function selectPastAddress(addr) {
  document.getElementById('deliveryAddress').value = addr;
  document.querySelectorAll('.past-addr-chip').forEach(function(el) { el.classList.remove('selected'); });
  event.target.classList.add('selected');
  onAddressInput();
}

async function loadPastAddresses() {
  try {
    var res  = await fetch(API_BASE + '/api/order-ui/past-addresses/' + SESSION_ID);
    var data = await res.json();
    if (!data.addresses || !data.addresses.length) return;
    var container = document.getElementById('pastAddresses');
    container.innerHTML =
      '<div style="font-size:11px;color:#888;margin-bottom:4px">Recent addresses:</div>' +
      data.addresses.map(function(addr) {
        return '<div class="past-addr-chip" onclick="selectPastAddress(\'' + addr.replace(/'/g,"\\'") + '\')">📍 ' + addr + '</div>';
      }).join('') +
      '<div style="font-size:11px;color:#888;margin-top:6px;margin-bottom:2px">Or enter new address:</div>';
  } catch(e) { /* ignore */ }
}

// ══════════════════════════════════════════════
// LOCK UI
// ══════════════════════════════════════════════
function lockUI(billNumber) {
  document.querySelectorAll('.qty-btn, .add-btn').forEach(function(b) {
    b.disabled = true; b.style.opacity = '0.4'; b.style.pointerEvents = 'none';
  });
  var btn = document.getElementById('placeOrderBtn');
  btn.disabled = true; btn.style.background = '#22c55e'; btn.style.opacity = '1';
  btn.textContent = billNumber ? '✅ Order Placed #' + billNumber : '✅ Order Placed';
}

// ══════════════════════════════════════════════
// PLACE ORDER
// ══════════════════════════════════════════════
async function placeOrder(skipAddressCheck) {
  if (Object.keys(cart).length === 0) { showToast('Add items first!'); return; }
  var btn = document.getElementById('placeOrderBtn');
  btn.classList.add('loading'); btn.textContent = 'Placing order…';
  try {
    var addrEl     = document.getElementById('deliveryAddress');
    var address    = addrEl ? addrEl.value.trim() : '';
    var isDelivery = document.getElementById('addressSection').style.display !== 'none';
    if (isDelivery && address.length < 6 && !skipAddressCheck) {
      document.getElementById('addressHint').style.display = 'block';
      if (addrEl) { addrEl.focus(); addrEl.style.borderColor = '#e53e3e'; }
      btn.textContent = 'Place Order →'; btn.classList.remove('loading'); return;
    }
    if (isDelivery && address) {
      await fetch(API_BASE + '/api/order-ui/address/' + SESSION_ID, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ address })
      });
    }
    var res  = await fetch(API_BASE + '/api/order-ui/place-order/' + SESSION_ID, {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({})
    });
    var data = await res.json();
    if (res.status === 410) { showToast('⚠️ Session expired — scan QR to reorder'); btn.textContent = 'Place Order →'; btn.classList.remove('loading'); return; }
    if (data.success) {
      closeCart();
      document.getElementById('cartPill').classList.remove('visible');
      showToast('✅ Order placed! Bill #' + data.bill_number);
      if (sessionMode !== 'dine_in') {
        cart = {}; updateCartUI(); renderMenu(); lockUI(data.bill_number);
      } else {
        cart = {}; updateCartUI(); renderMenu();
        btn.textContent = 'Place Order →'; btn.classList.remove('loading');
      }
    } else { throw new Error(data.error || 'Failed'); }
  } catch(e) {
    showToast('Failed to place order. Try again.');
    btn.textContent = 'Place Order →'; btn.classList.remove('loading');
  }
}

// ══════════════════════════════════════════════
// CART DRAWER
// ══════════════════════════════════════════════
function openCart() { document.getElementById('cartDrawer').classList.add('open'); document.getElementById('drawerOverlay').classList.add('open'); renderCartDrawer(); }
function closeCart() { document.getElementById('cartDrawer').classList.remove('open'); document.getElementById('drawerOverlay').classList.remove('open'); }
function renderCartDrawer() {
  var items = Object.entries(cart);
  var total = items.reduce(function(s,e) { return s+e[1].price*e[1].qty; }, 0);
  var container = document.getElementById('cartItems');
  if (!items.length) {
    container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted)">Cart is empty</div>';
    document.getElementById('cartTotalRow').style.display = 'none'; return;
  }
  container.innerHTML = items.map(function(e) {
    var id = e[0]; var item = e[1];
    return '<div class="cart-item-row">' +
      '<div><div class="cart-item-name">' + item.name + '</div><div class="cart-item-price">₹' + item.price + ' each</div></div>' +
      '<div class="cart-item-qty">' +
      '<button class="qty-btn minus" onclick="changeQty(\'' + id + '\',\'' + item.name.replace(/'/g,"\\'") + '\',' + item.price + ',-1);renderCartDrawer()">−</button>' +
      '<span>' + item.qty + '</span>' +
      '<button class="qty-btn plus" onclick="changeQty(\'' + id + '\',\'' + item.name.replace(/'/g,"\\'") + '\',' + item.price + ',1);renderCartDrawer()">+</button>' +
      '</div></div>';
  }).join('');
  document.getElementById('cartTotal').textContent = '₹' + total;
  document.getElementById('cartTotalRow').style.display = 'flex';
}

// ══════════════════════════════════════════════
// POPULAR
// ══════════════════════════════════════════════
function renderPopular() {
  var popular = allItems.filter(function(i) {
    return i.tags && i.tags.some(function(t) { return t.tag_code === 'popular'; });
  });
  if (!popular.length) {
    popular = allItems.filter(function(i) { return i.popularity_score > 0 || i.owner_popularity_tier >= 2; }).slice(0,4);
  }
  if (!popular.length) return;
  var section = document.getElementById('popularSection');
  var container = document.getElementById('popularItems');
  section.style.display = 'block';
  container.innerHTML = popular.slice(0,4).map(function(item) {
    var safeName = item.name.replace(/'/g,"\\'");
    return '<div class="popular-chip" onclick="addItem(\'' + item.id + '\',\'' + safeName + '\',' + item.price + ')">' +
      '<div class="popular-chip-name">' + item.name + '</div>' +
      '<div class="popular-chip-price">₹' + item.price + '</div>' +
      '<div class="popular-chip-add">+ Add</div>' +
      '</div>';
  }).join('');
}

// ══════════════════════════════════════════════
// UPSELL (unchanged)
// ══════════════════════════════════════════════
var _upsellItem = null;
var _skipAddressCheck = false;

async function startUpsell(skipAddr) {
  _skipAddressCheck = skipAddr || false;
  var addrEl     = document.getElementById('deliveryAddress');
  var address    = addrEl ? addrEl.value.trim() : '';
  var isDelivery = document.getElementById('addressSection').style.display !== 'none';
  if (isDelivery && address.length < 6 && !skipAddr) {
    document.getElementById('addressHint').style.display = 'block';
    if (addrEl) { addrEl.focus(); addrEl.style.borderColor = '#e53e3e'; } return;
  }
  if (Object.keys(cart).length === 0) { showToast('Add items first!'); return; }
  var cartNames = Object.values(cart).map(function(i) { return i.name; });
  showUpsellModal('loading', null);
  try {
    var res  = await fetch(API_BASE + '/api/order-ui/upsell/' + SESSION_ID, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ cartItems: cartNames })
    });
    var data = await res.json();
    if (data.suggestion && data.itemId) {
      _upsellItem = { id: data.itemId, name: data.suggestion, price: data.price };
      showUpsellModal(data.message, _upsellItem);
    } else { hideUpsellModal(); showConfirmModal(_skipAddressCheck); }
  } catch(e) { hideUpsellModal(); await placeOrder(_skipAddressCheck); }
}

function showUpsellModal(msg, item) {
  document.getElementById('upsellOverlay').style.opacity = '1';
  document.getElementById('upsellOverlay').style.pointerEvents = 'all';
  document.getElementById('upsellModal').style.transform = 'translateX(-50%) translateY(0)';
  if (item) {
    document.getElementById('upsellMsg').textContent = msg;
    document.getElementById('upsellLoading').style.display = 'none';
    document.getElementById('upsellItemName').textContent  = item.name;
    document.getElementById('upsellItemPrice').textContent = '₹' + item.price;
    document.getElementById('upsellItem').style.display    = 'block';
  } else if (msg === 'loading') {
    document.getElementById('upsellMsg').textContent      = '';
    document.getElementById('upsellLoading').style.display = 'block';
    document.getElementById('upsellItem').style.display   = 'none';
  } else {
    document.getElementById('upsellMsg').textContent       = msg || 'Ready to place your order?';
    document.getElementById('upsellLoading').style.display = 'none';
    document.getElementById('upsellItem').style.display    = 'none';
  }
}

function hideUpsellModal() {
  document.getElementById('upsellOverlay').style.opacity = '0';
  document.getElementById('upsellOverlay').style.pointerEvents = 'none';
  document.getElementById('upsellModal').style.transform = 'translateX(-50%) translateY(100%)';
  _upsellItem = null;
}

async function addUpsellItem() {
  if (!_upsellItem) return;
  var item = _upsellItem;
  var newQty = cart[item.id] ? cart[item.id].qty + 1 : 1;
  try {
    await fetch(API_BASE + '/api/order-ui/cart-item/' + SESSION_ID, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ menu_item_id: item.id, quantity: newQty, name: item.name, price: item.price })
    });
  } catch(e) { console.error('Upsell save failed', e); }
  try {
    var res  = await fetch(API_BASE + '/api/order-ui/cart/' + SESSION_ID);
    var data = await res.json();
    if (data.items) {
      cart = {};
      data.items.forEach(function(i) { cart[i.menu_item_id] = { qty: i.quantity, notes: i.notes||'', name: i.name, price: i.price }; });
    }
  } catch(e) {}
  renderMenu(); updateCartUI(); showToast('✅ ' + item.name + ' added!');
  hideUpsellModal(); showConfirmModal(_skipAddressCheck);
}

async function skipUpsell() { hideUpsellModal(); showConfirmModal(_skipAddressCheck); }
async function confirmAfterUpsell() { hideUpsellModal(); showConfirmModal(_skipAddressCheck); }

// ══════════════════════════════════════════════
// NOTES
// ══════════════════════════════════════════════
var _notesItemId = null;
function openNotes(itemId) {
  _notesItemId = itemId;
  var item = cart[itemId];
  if (!item) return;
  document.getElementById('notesItemName').textContent = item.name;
  document.getElementById('notesTextarea').value = item.notes || '';
  document.getElementById('notesModal').style.display = 'block';
  setTimeout(function() { document.getElementById('notesTextarea').focus(); }, 300);
}
function closeNotes() { document.getElementById('notesModal').style.display = 'none'; _notesItemId = null; }
function addNoteHint(hint) {
  var ta = document.getElementById('notesTextarea');
  ta.value = ta.value.trim() ? ta.value.trim() + ', ' + hint : hint;
}
function saveNotes() {
  if (!_notesItemId || !cart[_notesItemId]) { closeNotes(); return; }
  cart[_notesItemId].notes = document.getElementById('notesTextarea').value.trim();
  updateCartUI(); syncCartItem(_notesItemId, cart[_notesItemId].qty); closeNotes(); showToast('📝 Note saved!');
}

// ══════════════════════════════════════════════
// ORDER CONFIRMATION
// ══════════════════════════════════════════════
var _confirmSkipAddr = false;
function showConfirmModal(skipAddr) {
  _confirmSkipAddr = skipAddr || false;
  var items = Object.entries(cart);
  if (!items.length) return;
  var total = 0;
  var html = items.map(function(e) {
    var id = e[0], item = e[1];
    total += item.price * item.qty;
    var noteHtml = item.notes ? '<div class="confirm-item-note">📝 ' + item.notes + '</div>' : '';
    return '<div class="confirm-item"><div class="confirm-item-name">' + item.name + '<div style="font-size:12px;color:#9b8b72;font-weight:400">x' + item.qty + '</div>' + noteHtml + '</div><div class="confirm-item-price">₹' + (item.price*item.qty) + '</div></div>';
  }).join('');
  document.getElementById('confirmItems').innerHTML = html;
  document.getElementById('confirmTotal').textContent = '₹' + total;
  var addrEl = document.getElementById('deliveryAddress');
  var addr   = addrEl ? addrEl.value.trim() : '';
  var addrBox = document.getElementById('confirmAddr');
  if (addr) { addrBox.style.display = 'block'; addrBox.innerHTML = '📍 Delivering to: <strong>' + addr + '</strong>'; }
  else if (sessionMode === 'dine_in') { addrBox.style.display = 'block'; addrBox.innerHTML = '🍽️ Dine-in order'; }
  else if (sessionMode === 'takeaway') { addrBox.style.display = 'block'; addrBox.innerHTML = '🏃 Takeaway — collect at counter'; }
  else { addrBox.style.display = 'none'; }
  document.getElementById('confirmModal').style.display = 'block';
}
function closeConfirm() { document.getElementById('confirmModal').style.display = 'none'; }
async function closeConfirmOpenCart() {
  closeConfirm();
  try {
    var res  = await fetch(API_BASE + '/api/order-ui/cart/' + SESSION_ID);
    var data = await res.json();
    if (data.items) { cart = {}; data.items.forEach(function(i) { cart[i.menu_item_id] = { qty:i.quantity, notes:i.notes||'', name:i.name, price:i.price }; }); renderMenu(); updateCartUI(); }
  } catch(e) {}
  openCart();
}
async function confirmAndPlace() {
  var btn = document.getElementById('confirmPlaceBtn');
  btn.textContent = 'Placing…'; btn.disabled = true;
  closeConfirm(); await placeOrder(_confirmSkipAddr);
  btn.textContent = 'Place Order →'; btn.disabled = false;
}

// ══════════════════════════════════════════════
// LANGUAGE (unchanged)
// ══════════════════════════════════════════════
var LANGUAGES = [
  { code:'en',      flag:'🇬🇧', name:'English',   native:'English'    },
  { code:'hi',      flag:'🇮🇳', name:'Hindi',     native:'हिन्दी'      },
  { code:'mr',      flag:'🇮🇳', name:'Marathi',   native:'मराठी'       },
  { code:'hi_LATN', flag:'🇮🇳', name:'Hinglish',  native:'Hinglish'   },
  { code:'ta',      flag:'🇮🇳', name:'Tamil',     native:'தமிழ்'       },
  { code:'te',      flag:'🇮🇳', name:'Telugu',    native:'తెలుగు'      },
  { code:'gu',      flag:'🇮🇳', name:'Gujarati',  native:'ગુજરાતી'     },
  { code:'ml',      flag:'🇮🇳', name:'Malayalam', native:'മലയാളം'      },
  { code:'kn',      flag:'🇮🇳', name:'Kannada',   native:'ಕನ್ನಡ'       },
  { code:'ru',      flag:'🇷🇺', name:'Russian',   native:'Русский'    },
  { code:'zh',      flag:'🇨🇳', name:'Chinese',   native:'中文'        },
  { code:'de',      flag:'🇩🇪', name:'German',    native:'Deutsch'    },
  { code:'fr',      flag:'🇫🇷', name:'French',    native:'Français'   },
  { code:'es',      flag:'🇪🇸', name:'Spanish',   native:'Español'    },
];
var selectedLang = localStorage.getItem('buddy_lang') || 'en';
function getLang() { return LANGUAGES.find(function(l) { return l.code === selectedLang; }) || LANGUAGES[0]; }
function openLangDrawer() {
  var grid = document.getElementById('langGrid');
  grid.innerHTML = LANGUAGES.map(function(l) {
    var sel = l.code === selectedLang ? ' selected' : '';
    return '<button class="lang-option' + sel + '" onclick="selectLang(\'' + l.code + '\')">' +
      '<span class="flag">' + l.flag + '</span>' +
      '<span class="label"><span>' + l.name + '</span><span class="native">' + l.native + '</span></span>' +
      '</button>';
  }).join('');
  document.getElementById('langDrawer').style.display = 'block';
}
function closeLangDrawer() { document.getElementById('langDrawer').style.display = 'none'; }
function selectLang(code) {
  selectedLang = code;
  localStorage.setItem('buddy_lang', code);
  var lang = getLang();
  document.getElementById('langBtn').textContent = lang.flag + ' ' + lang.code.toUpperCase();
  closeLangDrawer();
  // Re-fetch menu in selected language
  fetch(API_BASE + '/api/order-ui/menu/' + SESSION_ID + '?lang=' + code)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      allItems    = data.items      || [];
      categories  = data.categories || [];
      buildFilterChips();
      buildCategoryTabs();
      renderMenu();
      renderPopular();
      showToast(lang.flag + ' Menu updated in ' + lang.name);
    })
    .catch(function(e) { console.error('Menu reload failed', e); showToast('Could not load translation'); });
}

// ══════════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════════
function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(function() { t.classList.remove('show'); }, 2500);
}

// ══════════════════════════════════════════════
// START
// ══════════════════════════════════════════════
init();
</script>

<!-- Modifier Modal -->
<div id="modifierModal" style="display:none;position:fixed;inset:0;z-index:500">
  <div onclick="closeModifierModal()" style="position:absolute;inset:0;background:rgba(0,0,0,0.5)"></div>
  <div style="position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:white;border-radius:24px 24px 0 0;padding:24px 20px 32px;box-sizing:border-box">
    <div style="width:40px;height:4px;background:#ede8df;border-radius:2px;margin:0 auto 16px"></div>
    <div id="modItemName" style="font-family:'Syne',sans-serif;font-size:18px;font-weight:800;margin-bottom:4px"></div>
    <div id="modItemPrice" style="font-size:14px;color:#9b8b72;margin-bottom:16px"></div>
    <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#9b8b72;margin-bottom:4px">Add extras (optional)</div>
    <div id="modOptions"></div>
    <button onclick="confirmModifiers()" style="width:100%;padding:14px;background:#1a1207;border:none;border-radius:12px;color:white;font-family:'Syne',sans-serif;font-size:15px;font-weight:800;cursor:pointer;margin-top:16px">Add to Cart ₹<span id="modTotal">0</span></button>
    <button onclick="skipModifiers()" style="width:100%;padding:10px;background:none;border:none;color:#9b8b72;font-size:13px;cursor:pointer;margin-top:6px">Add without extras</button>
  </div>
</div>
</body>
</html>


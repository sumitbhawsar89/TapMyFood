<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Order</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  body { font-family: 'DM Sans', sans-serif; background: #fdf6e9; color: #1a1207; min-height: 100vh; max-width: 480px; margin: 0 auto; display: flex; flex-direction: column; }

  .header {
    background: #1a1207;
    padding: 24px 20px 20px;
    text-align: center;
  }
  .header-logo { font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; color: #f59e0b; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px; }
  .header-name { font-family: 'Syne', sans-serif; font-size: 24px; font-weight: 800; color: white; }
  .header-sub  { font-size: 13px; color: rgba(255,255,255,0.5); margin-top: 4px; }

  .card {
    background: white;
    border-radius: 20px;
    margin: 20px 16px;
    padding: 24px 20px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    border: 1.5px solid #ede8df;
  }

  .card-title { font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800; margin-bottom: 4px; }
  .card-sub   { font-size: 13px; color: #9b8b72; margin-bottom: 20px; }

  /* ── MODE SELECTOR ── */
  .mode-options { display: flex; gap: 10px; margin-bottom: 24px; }
  .mode-opt {
    flex: 1; border: 2px solid #ede8df; border-radius: 14px;
    padding: 16px 12px; text-align: center; cursor: pointer;
    transition: all 0.15s; background: white;
  }
  .mode-opt.selected { border-color: #ea580c; background: #fff7f0; }
  .mode-opt:active   { transform: scale(0.97); }
  .mode-opt-icon  { font-size: 28px; margin-bottom: 6px; }
  .mode-opt-name  { font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; color: #1a1207; }
  .mode-opt-sub   { font-size: 11px; color: #9b8b72; margin-top: 2px; }
  .mode-opt.selected .mode-opt-name { color: #ea580c; }

  /* ── PHONE INPUT ── */
  .input-label { font-size: 12px; font-weight: 600; color: #666; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
  .phone-wrap { display: flex; gap: 8px; align-items: center; margin-bottom: 6px; }
  .country-code { background: #f5f0e8; border: 1.5px solid #ede8df; border-radius: 10px; padding: 14px 12px; font-size: 15px; font-weight: 600; color: #1a1207; white-space: nowrap; }
  .phone-input { flex: 1; border: 1.5px solid #ede8df; border-radius: 10px; padding: 14px 14px; font-size: 16px; font-family: 'DM Sans', sans-serif; outline: none; background: #faf8f5; color: #1a1207; }
  .phone-input:focus { border-color: #ea580c; background: white; }
  .phone-hint { font-size: 11px; color: #9b8b72; margin-bottom: 20px; }
  .phone-error { font-size: 12px; color: #dc2626; margin-bottom: 12px; display: none; }

  /* ── ADDRESS (delivery only) ── */
  .address-section { display: none; margin-bottom: 20px; }
  .address-textarea { width: 100%; min-height: 72px; border: 1.5px solid #ede8df; border-radius: 10px; padding: 12px 14px; font-size: 14px; font-family: 'DM Sans', sans-serif; resize: none; background: #faf8f5; box-sizing: border-box; outline: none; }
  .address-textarea:focus { border-color: #ea580c; background: white; }

  /* ── BUTTON ── */
  .start-btn {
    width: 100%; padding: 16px; background: #ea580c; color: white;
    border: none; border-radius: 14px; font-family: 'Syne', sans-serif;
    font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.2s;
  }
  .start-btn:active  { transform: scale(0.99); background: #c2440a; }
  .start-btn.loading { opacity: 0.7; pointer-events: none; }
  .start-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ── RETURNING CUSTOMER ── */
  .returning-banner {
    background: #f0fdf4; border: 1.5px solid #86efac; border-radius: 12px;
    padding: 12px 14px; margin-bottom: 16px; display: none;
    font-size: 13px; color: #15803d;
  }
  .returning-banner strong { font-weight: 700; }

  /* ── LOADING / ERROR STATES ── */
  .loading-screen { flex: 1; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 12px; }
  .loading-dot { width: 10px; height: 10px; border-radius: 50%; background: #ea580c; display: inline-block; animation: bounce 1.2s infinite; }
  .loading-dot:nth-child(2) { animation-delay: 0.2s; }
  .loading-dot:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-8px)} }

  .toast { position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%) translateY(20px); background: #1a1207; color: white; padding: 10px 20px; border-radius: 50px; font-size: 13px; font-weight: 500; opacity: 0; pointer-events: none; transition: all 0.3s; z-index: 999; white-space: nowrap; }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  .footer { padding: 16px; text-align: center; font-size: 11px; color: #c4b89a; }
</style>
</head>
<body>

<div id="loadingScreen" class="loading-screen">
  <div><span class="loading-dot"></span><span class="loading-dot"></span><span class="loading-dot"></span></div>
  <div style="font-size:13px;color:#9b8b72">Loading...</div>
</div>

<div id="mainScreen" style="display:none;flex-direction:column;flex:1">
  <div class="header">
    <div class="header-logo">OrderBuddy</div>
    <div class="header-name" id="restaurantName">Restaurant</div>
    <div class="header-sub" id="restaurantSub">Tap to order</div>
  </div>

  <div class="card">
    <div class="card-title">How would you like to order?</div>
    <div class="card-sub">Select your preferred option below</div>

    <!-- Mode selector -->
    <div class="mode-options">
      <div class="mode-opt selected" id="modeDelivery" onclick="selectMode('delivery')">
        <div class="mode-opt-icon">🚗</div>
        <div class="mode-opt-name">Delivery</div>
        <div class="mode-opt-sub">Delivered to your door</div>
      </div>
      <div class="mode-opt" id="modeTakeaway" onclick="selectMode('takeaway')">
        <div class="mode-opt-icon">🏃</div>
        <div class="mode-opt-name">Takeaway</div>
        <div class="mode-opt-sub">Collect at counter</div>
      </div>
    </div>

    <!-- Returning customer banner -->
    <div class="returning-banner" id="returningBanner">
      👋 <strong>Welcome back!</strong> We found your previous order.
    </div>

    <!-- Phone number -->
    <div class="input-label">Your Mobile Number</div>
    <div class="phone-wrap">
      <div class="country-code">🇮🇳 +91</div>
      <input
        class="phone-input"
        id="phoneInput"
        type="tel"
        inputmode="numeric"
        pattern="[0-9]*"
        maxlength="10"
        placeholder="10-digit mobile number"
        oninput="onPhoneInput()"
        onkeydown="if(event.key==='Enter') startOrder()"
      >
    </div>
    <div class="phone-hint">We'll send order updates to this number via WhatsApp</div>
    <div class="phone-error" id="phoneError">⚠️ Please enter a valid 10-digit mobile number</div>

    <!-- Delivery address (shown only for delivery mode) -->
    <div class="address-section" id="addressSection">
      <div class="input-label" style="margin-bottom:8px">📍 Delivery Address</div>
      <textarea
        class="address-textarea"
        id="addressInput"
        placeholder="Flat/House no, Street, Area, City..."
        oninput="onAddressInput()"
      ></textarea>
      <div class="phone-error" id="addressError">⚠️ Please enter your delivery address</div>
    </div>

    <button class="start-btn" id="startBtn" onclick="startOrder()" disabled>
      Browse Menu →
    </button>
  </div>

  <div class="footer">Powered by OrderBuddy</div>
</div>

<div class="toast" id="toast"></div>

<script>
  const API = '';
  const params = new URLSearchParams(window.location.search);
  const restaurantId = params.get('r');
  let selectedMode = 'delivery';
  let restaurant   = null;

  // ── Init ──
  async function init() {
    if (!restaurantId) {
      document.getElementById('loadingScreen').innerHTML =
        '<div style="text-align:center;padding:40px;color:#9b8b72">Invalid link. Please scan the QR code again.</div>';
      return;
    }
    try {
      const res  = await fetch(`${API}/api/order-ui/restaurant?r=${restaurantId}`);
      if (!res.ok) throw new Error('Restaurant not found');
      const data = await res.json();
      restaurant = data.restaurant;

      document.getElementById('restaurantName').textContent = restaurant.name;
      document.getElementById('restaurantSub').textContent  =
        restaurant.address || 'Tap to browse our menu';
      document.title = 'Order — ' + restaurant.name;

      document.getElementById('loadingScreen').style.display = 'none';
      document.getElementById('mainScreen').style.display    = 'flex';

      // Pre-fill phone from URL param (passed by WhatsApp bot)
      const phoneFromUrl = params.get('p');
      if (phoneFromUrl && phoneFromUrl.length === 10 && /^[0-9]+$/.test(phoneFromUrl)) {
        document.getElementById('phoneInput').value = phoneFromUrl;
        validateForm();
        checkReturning(phoneFromUrl);
        // Don't auto-focus if phone is pre-filled — let customer confirm by tapping button
      } else {
        // No pre-fill — focus phone input
        setTimeout(() => document.getElementById('phoneInput').focus(), 300);
      }

    } catch (e) {
      document.getElementById('loadingScreen').innerHTML =
        '<div style="text-align:center;padding:40px;color:#9b8b72">Restaurant not found. Please try again.</div>';
    }
  }

  // ── Mode selection ──
  function selectMode(mode) {
    selectedMode = mode;
    document.getElementById('modeDelivery').classList.toggle('selected', mode === 'delivery');
    document.getElementById('modeTakeaway').classList.toggle('selected', mode === 'takeaway');
    document.getElementById('addressSection').style.display = mode === 'delivery' ? 'block' : 'none';
    validateForm();
  }

  // ── Phone input ──
  function onPhoneInput() {
    const val = document.getElementById('phoneInput').value.replace(/\D/g, '').slice(0, 10);
    document.getElementById('phoneInput').value = val;
    document.getElementById('phoneError').style.display = 'none';
    if (val.length === 10) checkReturning(val);
    validateForm();
  }

  // ── Check returning customer ──
  async function checkReturning(phone) {
    try {
      const res  = await fetch(`${API}/api/order-ui/check-returning?phone=${phone}&r=${restaurantId}`);
      const data = await res.json();
      document.getElementById('returningBanner').style.display = data.returning ? 'block' : 'none';
    } catch { /* ignore */ }
  }

  // ── Address input ──
  function onAddressInput() {
    document.getElementById('addressError').style.display = 'none';
    validateForm();
  }

  // ── Validate form ──
  function validateForm() {
    const phone   = document.getElementById('phoneInput').value;
    const address = document.getElementById('addressInput').value.trim();
    const btn     = document.getElementById('startBtn');
    const phoneOk = phone.length === 10;
    const addrOk  = selectedMode !== 'delivery' || address.length >= 10;
    btn.disabled  = !(phoneOk && addrOk);
  }

  // ── Start order ──
  async function startOrder() {
    const phone   = document.getElementById('phoneInput').value.trim();
    const address = document.getElementById('addressInput').value.trim();

    // Validate
    if (phone.length !== 10) {
      document.getElementById('phoneError').style.display = 'block';
      document.getElementById('phoneInput').focus();
      return;
    }
    if (selectedMode === 'delivery' && address.length < 10) {
      document.getElementById('addressError').style.display = 'block';
      document.getElementById('addressInput').focus();
      return;
    }

    const btn = document.getElementById('startBtn');
    btn.classList.add('loading');
    btn.textContent = 'Opening menu...';

    try {
      const res  = await fetch(`${API}/api/order-ui/start`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({
          restaurant_id: restaurantId,
          phone:         '91' + phone,
          mode:          selectedMode,
          address:       selectedMode === 'delivery' ? address : null,
        })
      });
      const data = await res.json();

      if (!data.session_id) throw new Error(data.error || 'Failed to create session');

      // Redirect to order UI
      window.location.href = `/order/${data.session_id}`;

    } catch (e) {
      showToast('⚠️ Something went wrong. Please try again.');
      btn.classList.remove('loading');
      btn.textContent = 'Browse Menu →';
      btn.disabled    = false;
    }
  }

  // ── Toast ──
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
  }

  init();
</script>
</body>
</html>

